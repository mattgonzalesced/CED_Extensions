<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Fixture Auto-Match"
        Width="1040"
        Height="700"
        MinWidth="900"
        MinHeight="600"
        Background="{DynamicResource CED.Brush.WindowBackground}">
  <Window.Resources>
    <Style x:Key="CED.DataGrid.Header.WrapCompact"
           TargetType="DataGridColumnHeader">
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Height" Value="28"/>
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="Padding" Value="4,2,4,2"/>
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridHeaderBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridHeaderForeground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridHeaderBorder}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
  </Window.Resources>

  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,8">
      <TextBlock Text="Fixture Auto-Match" Style="{DynamicResource CED.Text.Title}"/>
      <TextBlock Text="Match source values to target type parameters, then apply the results."
                 Style="{DynamicResource CED.Text.Secondary}"
                 Margin="0,3,0,0"/>
    </StackPanel>

    <Border Grid.Row="1"
            BorderBrush="{DynamicResource CED.Brush.CardBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CED.CornerRadius.Panel}"
            Background="{DynamicResource CED.Brush.SearchBackground}"
            Padding="10"
            Margin="0,0,0,8">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Name="LinkParamPanel">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0"
                     Name="SourceParamLabel"
                     Text="Source Param:"
                     Style="{DynamicResource CED.Text.CaptionStrong}"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
          <ComboBox Grid.Column="1"
                    Name="SourceParamCombo"
                    Style="{DynamicResource CED.Input.ComboBox.Flat.Compact}"
                    Height="24"/>
          <TextBlock Grid.Column="3"
                     Name="TargetParamLabel"
                     Text="Target Param:"
                     Style="{DynamicResource CED.Text.CaptionStrong}"
                     VerticalAlignment="Center"
                     Margin="0,0,6,0"/>
          <ComboBox Grid.Column="4"
                    Name="LinkTargetParamCombo"
                    Style="{DynamicResource CED.Input.ComboBox.Flat.Compact}"
                    Height="24"/>
          <Button Grid.Column="6"
                  Name="LinkRunMatchButton"
                  Content="Run Match"
                  Width="96"
                  Height="24"
                  Style="{DynamicResource CED.Button.Base}"
                  ToolTip="Match using selected source and target parameters."/>
        </Grid>

        <Grid Grid.Row="1"
              Name="CsvDerivePanel"
              Visibility="Collapsed"
              Margin="0,0,0,0">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="360"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                       Text="Sample Source:"
                       Style="{DynamicResource CED.Text.CaptionStrong}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <TextBox Grid.Column="1"
                     Name="CsvSampleTextBox"
                     Style="{DynamicResource CED.Input.TextBox}"
                     IsReadOnly="True"
                     VerticalAlignment="Center"/>
          </Grid>

          <TextBlock Grid.Row="1"
                     Text="Copy part of the sample string to the inputs below to extract ID values."
                     Style="{DynamicResource CED.Text.Caption}"
                     Margin="0,6,0,6"/>

          <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="170"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="170"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="16"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="10"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="Text After:"
                       Style="{DynamicResource CED.Text.CaptionStrong}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <TextBox Grid.Column="1"
                     Name="CsvAfterTextBox"
                     Style="{DynamicResource CED.Input.TextBox}"
                     VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3"
                       Text="Text Before:"
                       Style="{DynamicResource CED.Text.CaptionStrong}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <TextBox Grid.Column="4"
                     Name="CsvBeforeTextBox"
                     Style="{DynamicResource CED.Input.TextBox}"
                     VerticalAlignment="Center"/>

            <Border Grid.Column="6"
                    Width="1"
                    Height="24"
                    Background="{DynamicResource CED.Brush.CardBorder}"
                    VerticalAlignment="Center"/>

            <TextBlock Grid.Column="8"
                       Text="Target Param:"
                       Style="{DynamicResource CED.Text.CaptionStrong}"
                       VerticalAlignment="Center"
                       Margin="0,0,6,0"/>
            <ComboBox Grid.Column="9"
                      Name="CsvTargetParamCombo"
                      Style="{DynamicResource CED.Input.ComboBox.Flat.Compact}"
                      Height="24"/>
            <Button Grid.Column="11"
                    Name="CsvRunMatchButton"
                    Content="Run Match"
                    Width="96"
                    Height="24"
                    Style="{DynamicResource CED.Button.Base}"
                    ToolTip="Derive source IDs, compare to target parameter values, then map matches."/>
          </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Name="RunStatusText"
                   Text="Ready."
                   Style="{DynamicResource CED.Text.Caption}"
                   VerticalAlignment="Center"
                   Margin="0,8,0,0"/>
      </Grid>
    </Border>

    <Border Grid.Row="2"
            BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
            BorderThickness="1"
            Background="{DynamicResource CED.Brush.ListBackground}">
      <DataGrid Name="MatchGrid"
                Style="{DynamicResource CED.DataGrid.Display}"
                RowStyle="{DynamicResource CED.DataGrid.RowDisabledAware.NeutralSelection}"
                ColumnHeaderStyle="{DynamicResource CED.DataGrid.Header.WrapCompact}"
                AutoGenerateColumns="False"
                HeadersVisibility="Column"
                CanUserAddRows="False"
                CanUserDeleteRows="False"
                CanUserReorderColumns="False"
                CanUserResizeRows="False"
                SelectionUnit="FullRow"
                SelectionMode="Extended"
                IsReadOnly="False"
                AlternationCount="2"
                Margin="0">
        <DataGrid.Columns>
          <DataGridCheckBoxColumn Header="Complete"
                                  Width="0.7*"
                                  Binding="{Binding is_complete, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          <DataGridTextColumn Header="Source Fixture"
                              Width="2.4*"
                              Binding="{Binding source_label}"
                              IsReadOnly="True"
                              CellStyle="{DynamicResource CED.DataGrid.Cell.DisplayReadonly.NeutralSelection}"/>
          <DataGridTextColumn Header="Source Value"
                              Width="1.7*"
                              Binding="{Binding source_value_display}"
                              IsReadOnly="True"
                              CellStyle="{DynamicResource CED.DataGrid.Cell.DisplayReadonly.NeutralSelection}"/>
          <DataGridTextColumn Header="Target Mapping"
                              Width="2.3*"
                              Binding="{Binding target_label}"
                              IsReadOnly="True"
                              CellStyle="{DynamicResource CED.DataGrid.Cell.DisplayReadonly.NeutralSelection}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Border Grid.Row="3"
            BorderBrush="{DynamicResource CED.Brush.CardBorder}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CED.CornerRadius.Panel}"
            Background="{DynamicResource CED.Brush.SearchBackground}"
            Padding="10"
            Margin="0,8,0,0">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0"
                   Name="StatusText"
                   Text="Ready."
                   Style="{DynamicResource CED.Text.Secondary}"
                   VerticalAlignment="Center"/>
        <Button Grid.Column="1"
                Name="CancelButton"
                Content="Cancel"
                Width="86"
                Height="28"
                Style="{DynamicResource CED.Button.Base}"
                Margin="0,0,6,0"/>
        <Button Grid.Column="2"
                Name="OkButton"
                Content="Apply Results"
                Width="106"
                Height="28"
                Style="{DynamicResource CED.Button.Apply}"/>
      </Grid>
    </Border>
  </Grid>
</Window>
