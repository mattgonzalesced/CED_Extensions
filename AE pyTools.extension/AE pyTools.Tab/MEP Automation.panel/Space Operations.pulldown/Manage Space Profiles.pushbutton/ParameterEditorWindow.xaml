<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Element Parameter Overrides"
        Width="760"
        Height="620"
        MinWidth="620"
        MinHeight="520"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="PromptText"
               Text="Choose parameters to store and set their values."
               TextWrapping="Wrap"
               Margin="0,0,0,8"/>

    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" VerticalAlignment="Center">
      <TextBlock Text="Available Parameters:" VerticalAlignment="Center" Margin="0,0,8,0"/>
      <ComboBox x:Name="AvailableParamsCombo" Width="320"/>
      <Button x:Name="AddParamButton" Content="Add" Width="90" Margin="8,0,0,0" Click="OnAddParamClicked"/>
    </StackPanel>

    <GroupBox Grid.Row="2" Header="Selected Parameter Overrides">
      <Grid Margin="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <ListBox x:Name="SelectedParamsList" SelectionChanged="OnSelectedParamChanged"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,0" VerticalAlignment="Center">
          <TextBlock Text="Value:" VerticalAlignment="Center" Margin="0,0,8,0"/>
          <TextBox x:Name="ParamValueText" Width="280"/>
          <Button x:Name="ApplyValueButton" Content="Apply Value" Width="100" Margin="8,0,0,0" Click="OnApplyValueClicked"/>
          <Button x:Name="RemoveParamButton" Content="Remove Selected" Width="120" Margin="8,0,0,0" Click="OnRemoveParamClicked"/>
        </StackPanel>
      </Grid>
    </GroupBox>

    <TextBlock Grid.Row="3"
               Margin="0,8,0,0"
               Text="Tip: Values are stored as text and will be interpreted during placement by storage type."
               TextWrapping="Wrap"/>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button x:Name="SaveButton" Content="Save" Width="100" Margin="0,0,8,0" Click="OnSaveClicked"/>
      <Button x:Name="CancelButton" Content="Cancel" Width="100" Click="OnCancelClicked"/>
    </StackPanel>
  </Grid>
</Window>
