<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adjust Keynote"
        Width="760"
        Height="620"
        MinWidth="680"
        MinHeight="560"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock x:Name="PromptText"
               TextWrapping="Wrap"
               Margin="0,0,0,10"/>

    <GroupBox Grid.Row="1" Header="Offsets (feet)">
      <Grid Margin="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="20"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="100"/>
          <ColumnDefinition Width="20"/>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="100"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="X:" VerticalAlignment="Center"/>
        <TextBox x:Name="OffsetXText" Grid.Column="1" Margin="6,0,0,0"/>
        <TextBlock Grid.Column="3" Text="Y:" VerticalAlignment="Center"/>
        <TextBox x:Name="OffsetYText" Grid.Column="4" Margin="6,0,0,0"/>
        <TextBlock Grid.Column="6" Text="Z:" VerticalAlignment="Center"/>
        <TextBox x:Name="OffsetZText" Grid.Column="7" Margin="6,0,0,0"/>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="2" Header="Keynote Parameter Overrides" Margin="0,10,0,0">
      <Grid Margin="8">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal">
          <TextBlock Text="Available Params:" VerticalAlignment="Center"/>
          <ComboBox x:Name="AvailableParamsCombo" Width="320" Margin="8,0,8,0"/>
          <Button Content="Add Param" Width="90" Click="OnAddParamClicked"/>
        </StackPanel>

        <ListBox x:Name="SelectedParamsList"
                 Grid.Row="1"
                 Margin="0,8,0,8"
                 SelectionChanged="OnSelectedParamChanged"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="Value:" VerticalAlignment="Center"/>
          <TextBox x:Name="ParamValueText" Width="320" Margin="8,0,8,0"/>
          <Button Content="Apply Value" Width="96" Margin="0,0,8,0" Click="OnApplyValueClicked"/>
          <Button Content="Remove Param" Width="100" Click="OnRemoveParamClicked"/>
        </StackPanel>
      </Grid>
    </GroupBox>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
      <Button Content="Save" Width="120" Margin="0,0,8,0" Click="OnSaveClicked"/>
      <Button Content="Cancel" Width="120" Click="OnCancelClicked"/>
    </StackPanel>
  </Grid>
</Window>
