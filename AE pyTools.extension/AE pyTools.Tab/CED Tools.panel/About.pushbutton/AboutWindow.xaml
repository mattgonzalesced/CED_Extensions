<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About AE pyTools"
        Width="760"
        Height="372"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{x:Null}"
        WindowStyle="None"
        AllowsTransparency="True">
    <Window.Resources>
        <SolidColorBrush x:Key="AboutAccentBlueBrush" Color="#0459A4" />
        <SolidColorBrush x:Key="AboutAccentRedBrush" Color="#BE202F" />
        <SolidColorBrush x:Key="AboutAccentGreenBrush" Color="#43A047" />
        <SolidColorBrush x:Key="AboutTextBrush" Color="#000000" />
        <SolidColorBrush x:Key="AboutSubTextBrush" Color="#5F6C78" />
        <SolidColorBrush x:Key="AboutButtonOverlayHoverBrush" Color="#14000000" />
        <SolidColorBrush x:Key="AboutButtonOverlayPressedBrush" Color="#28000000" />
        <SolidColorBrush x:Key="AboutBorderBrush" Color="#D7DEE5" />
        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{StaticResource AboutTextBrush}" />
        </Style>
        <Style x:Key="About.Button.Base" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{StaticResource AboutAccentBlueBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="3,3,3,3" />
            <Setter Property="Padding" Value="12,5,12,5" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                                <Border x:Name="StateOverlay" Background="Transparent" CornerRadius="8" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="StateOverlay" Property="Background" Value="{StaticResource AboutButtonOverlayHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="StateOverlay" Property="Background" Value="{StaticResource AboutButtonOverlayPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="About.Button.Blue" TargetType="{x:Type Button}" BasedOn="{StaticResource About.Button.Base}">
            <Setter Property="Background" Value="{StaticResource AboutAccentBlueBrush}" />
        </Style>
        <Style x:Key="About.Button.Red" TargetType="{x:Type Button}" BasedOn="{StaticResource About.Button.Base}">
            <Setter Property="Background" Value="{StaticResource AboutAccentRedBrush}" />
        </Style>
        <Style x:Key="About.Button.Green" TargetType="{x:Type Button}" BasedOn="{StaticResource About.Button.Base}">
            <Setter Property="Background" Value="{StaticResource AboutAccentGreenBrush}" />
        </Style>
        <Style TargetType="{x:Type Button}" BasedOn="{StaticResource About.Button.Blue}" />
    </Window.Resources>

    <Border Margin="16"
            Background="#FFFFFF"
            BorderBrush="{StaticResource AboutBorderBrush}"
            BorderThickness="1"
            CornerRadius="14">
        <Grid Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="172" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Image x:Name="ced_logo_img"
                   Grid.Column="0"
                   Grid.Row="0"
                   Margin="0,0,6,0"
                   Width="162"
                   Height="150"
                   Stretch="Uniform"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top" />

            <StackPanel Grid.Column="1" Grid.Row="0">
                <DockPanel LastChildFill="False">
                    <TextBlock Text="AE pyTools"
                               FontSize="36"
                               FontWeight="Bold"
                               DockPanel.Dock="Left" />
                    <Button Content="Close"
                            Style="{StaticResource About.Button.Blue}"
                            Width="70"
                            Height="30"
                            Click="close_window"
                            DockPanel.Dock="Right" />
                </DockPanel>
                <TextBlock Text="Custom pyRevit extension for Coolsys Energy Design"
                           Margin="0,4,0,0"
                           FontSize="14"
                           Foreground="{StaticResource AboutSubTextBrush}" />

                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Toolbar Version:" FontWeight="SemiBold" />
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="toolbar_version_tb" Text="Unknown" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="pyRevit Version:" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="pyrevit_version_tb" Text="Unknown" Margin="0,4,0,0" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Authors:" FontWeight="SemiBold" Margin="0,4,0,0" />
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="authors_tb" TextWrapping="Wrap" Margin="0,4,0,0" />
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="Resources"
                           FontWeight="SemiBold"
                           FontSize="15"
                           Margin="0,0,0,6" />
                <WrapPanel>
                    <Button Style="{StaticResource About.Button.Blue}" Content="Update AE pyTools" Click="open_update_ae_pytools" />
                    <Button Style="{StaticResource About.Button.Blue}" Content="Update pyRevit" Click="open_update_pyrevit" />
                    <Button Style="{StaticResource About.Button.Red}" Content="Report Bugs" Click="open_report_bugs" />
                    <Button Style="{StaticResource About.Button.Red}" Content="Request Features" Click="open_request_features" />
                    <Button Style="{StaticResource About.Button.Green}" Content="Designer Hub" Click="open_designer_hub" />
                    <Button Style="{StaticResource About.Button.Green}" Content="Training Videos" Click="open_training_videos" />
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
