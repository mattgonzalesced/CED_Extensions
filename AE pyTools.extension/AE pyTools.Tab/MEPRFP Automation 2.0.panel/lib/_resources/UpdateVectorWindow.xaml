<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Vector (MEPRFP 2.0)"
        Width="1080" Height="640"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      Each row shows a LED or annotation whose offset will be re-captured
      from the current pose of the moved element. When multiple instances
      of the same LED diverge, last-moved wins; the others are flagged.
    </TextBlock>

    <GroupBox Grid.Row="1" Header="Match preview" Padding="8">
      <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="MatchButton" Content="Match selection" Width="140" Margin="0,0,8,0"/>
            <Button x:Name="UncheckAllButton" Content="Uncheck all" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="CheckAllButton" Content="Check all" Width="100"/>
          </StackPanel>
          <TextBlock x:Name="SummaryLabel" Foreground="Gray" VerticalAlignment="Center"/>
        </DockPanel>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="MatchRowsPanel"/>
        </ScrollViewer>
      </DockPanel>
    </GroupBox>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="Gray"/>
      <Button x:Name="UpdateButton" Content="Update checked" Width="160" Margin="0,0,8,0" IsEnabled="False"/>
      <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
