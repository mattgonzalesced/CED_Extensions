<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Space Annotations (MEPRFP 2.0)"
        Width="1180" Height="720"
        MinWidth="900" MinHeight="500"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      Place tags / keynotes / text notes against every space-based
      fixture in the active view (those whose Element_Linker carries
      a <Run FontStyle="Italic">space_id</Run> from Place Space
      Elements). Equipment fixtures are excluded — use
      <Run FontWeight="Bold">Place Element Annotations</Run> for those.
    </TextBlock>

    <DockPanel Grid.Row="1" Margin="0,0,0,6">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
        <CheckBox x:Name="KindTagCheck" Content="Tags" IsChecked="True" Margin="0,0,12,0"/>
        <CheckBox x:Name="KindKeynoteCheck" Content="Keynotes" IsChecked="True" Margin="0,0,12,0"/>
        <CheckBox x:Name="KindTextNoteCheck" Content="Text notes" IsChecked="True" Margin="0,0,18,0"/>
        <CheckBox x:Name="SkipDuplicatesCheck" Content="Skip already-placed" IsChecked="True"
                  ToolTip="Tags / keynotes / text notes already on (or near) the same fixture are flagged and excluded from Place all."/>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <TextBlock x:Name="SummaryLabel" Foreground="Gray"
                   VerticalAlignment="Center" Margin="0,0,12,0"/>
        <Button x:Name="RefreshButton" Content="Refresh" Width="120"/>
      </StackPanel>
    </DockPanel>

    <DataGrid Grid.Row="2" x:Name="PreviewGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              IsReadOnly="True"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              SelectionMode="Extended"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              ColumnWidth="*"
              RowHeight="22">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Kind"
                            Binding="{Binding KindLabel}"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Profile"
                            Binding="{Binding ProfileLabel}"
                            MinWidth="160" Width="1.4*"/>
        <DataGridTextColumn Header="LED Label"
                            Binding="{Binding LedLabel}"
                            MinWidth="180" Width="1.6*"/>
        <DataGridTextColumn Header="Annotation Label"
                            Binding="{Binding AnnLabel}"
                            MinWidth="180" Width="1.6*"/>
        <DataGridTextColumn Header="Skip"
                            Binding="{Binding SkipReason}"
                            MinWidth="180" Width="1.4*"/>
        <DataGridTextColumn Header="Target X (ft)"
                            Binding="{Binding XText}"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Target Y (ft)"
                            Binding="{Binding YText}"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Fixture Id"
                            Binding="{Binding FixtureIdText}"
                            MinWidth="90" Width="0.7*"/>
      </DataGrid.Columns>
    </DataGrid>

    <DockPanel Grid.Row="3" Margin="0,12,0,0">
      <TextBlock DockPanel.Dock="Left" x:Name="StatusLabel"
                 VerticalAlignment="Center" Foreground="Gray"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="PlaceButton" Content="Place all" Width="140" Margin="0,0,8,0"
                ToolTip="Place every previewed annotation in one transaction."/>
        <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
