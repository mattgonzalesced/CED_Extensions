<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Define parameter directives"
        Width="980" Height="600"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      For each child + parameter, choose how the value should resolve.
      <LineBreak/>
      <Run FontWeight="Bold">Static</Run> uses the captured value.
      <Run FontWeight="Bold">By parent</Run> follows a parameter on the parent element.
      <Run FontWeight="Bold">By sibling</Run> follows a parameter on another captured child.
    </TextBlock>

    <!-- Header row -->
    <Border Grid.Row="1" BorderBrush="#888" BorderThickness="0,0,0,1" Padding="0,4,0,4">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="3*"/>
          <ColumnDefinition Width="2*"/>
          <ColumnDefinition Width="120"/>
          <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Child" FontWeight="Bold" Margin="6,0,0,0"/>
        <TextBlock Grid.Column="1" Text="Parameter" FontWeight="Bold"/>
        <TextBlock Grid.Column="2" Text="Captured value" FontWeight="Bold"/>
        <TextBlock Grid.Column="3" Text="Mode" FontWeight="Bold"/>
        <TextBlock Grid.Column="4" Text="Target" FontWeight="Bold"/>
      </Grid>
    </Border>

    <!-- Body: rows added programmatically -->
    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel x:Name="RowsPanel"/>
    </ScrollViewer>

    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="ResetButton" Content="Reset all to static" Width="140" Margin="0,0,8,0"/>
      <Button x:Name="ApplyButton" Content="Apply" Width="100" Margin="0,0,8,0" IsDefault="True"/>
      <Button x:Name="CancelButton" Content="Skip directives" Width="120" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
