<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Classify Spaces (MEPRFP 2.0)"
        Width="1180" Height="760"
        MinWidth="900" MinHeight="540"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Top: client + summary + controls -->
    <DockPanel Grid.Row="0" Margin="0,0,0,8">
      <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
        <TextBlock Text="Client:" VerticalAlignment="Center" Margin="0,0,6,0"/>
        <ComboBox x:Name="ClientCombo" Width="200"
                  ToolTip="Filters which buckets are eligible for auto-classification. Universal buckets always apply."/>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="ResetAllButton" Content="Reset all to auto" Width="160" Margin="0,0,8,0"
                ToolTip="Discard manual overrides and re-apply the keyword-based suggestion to every row."/>
        <Button x:Name="RefreshButton" Content="Refresh from doc" Width="140"/>
      </StackPanel>
    </DockPanel>

    <!-- Counters -->
    <TextBlock Grid.Row="1" x:Name="SummaryLabel" Foreground="Gray" Margin="0,0,0,6"/>

    <!-- Grid -->
    <DataGrid Grid.Row="2" x:Name="SpacesGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              SelectionMode="Extended"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              ColumnWidth="*"
              RowHeight="24">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Level"
                            Binding="{Binding LevelName}"
                            IsReadOnly="True"
                            MinWidth="100" Width="0.8*"/>
        <DataGridTextColumn Header="Number"
                            Binding="{Binding Number}"
                            IsReadOnly="True"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Name"
                            Binding="{Binding Name}"
                            IsReadOnly="True"
                            MinWidth="160" Width="1.5*"/>
        <DataGridTextColumn Header="Auto-detected"
                            Binding="{Binding AutoLabel}"
                            IsReadOnly="True"
                            MinWidth="160" Width="1.4*"/>
        <DataGridTextColumn Header="Assigned buckets"
                            Binding="{Binding AssignedLabel}"
                            IsReadOnly="True"
                            MinWidth="200" Width="1.8*"/>
        <DataGridTemplateColumn Header="" MinWidth="80" Width="0.7*">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <Button Content="Edit..." Tag="{Binding}"
                      Padding="6,2"
                      Margin="2"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Element Id"
                            Binding="{Binding ElementIdText}"
                            IsReadOnly="True"
                            MinWidth="90" Width="0.7*"/>
      </DataGrid.Columns>
    </DataGrid>

    <!-- Bottom: status + buttons -->
    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="Gray"/>
      <Button x:Name="SaveButton" Content="Save classifications" Width="170" Margin="0,0,8,0"
              ToolTip="Persist the assigned bucket list to this project's Extensible Storage. Spaces with no buckets are stored as 'unclassified'."/>
      <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
