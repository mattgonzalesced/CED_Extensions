<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Follow Parent (MEPRFP 2.0)"
        Width="1080" Height="700"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style x:Key="CheckListBoxItem" TargetType="ListBoxItem">
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListBoxItem">
            <Border Background="Transparent" Padding="2">
              <CheckBox IsChecked="{Binding IsSelected,
                                            RelativeSource={RelativeSource TemplatedParent},
                                            Mode=TwoWay}"
                        VerticalContentAlignment="Center">
                <ContentPresenter VerticalAlignment="Center"/>
              </CheckBox>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <GroupBox Grid.Row="0" Header="Filters" Margin="0,0,0,8" Padding="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <DockPanel Grid.Column="0" Margin="0,0,4,0">
          <TextBlock DockPanel.Dock="Top"
                     Text="By category (check to include - leave all unchecked to include all)"/>
          <ListBox x:Name="CategoryList" Height="100"
                   SelectionMode="Multiple"
                   ItemContainerStyle="{StaticResource CheckListBoxItem}"/>
        </DockPanel>
        <DockPanel Grid.Column="1" Margin="4,0,0,0">
          <TextBlock DockPanel.Dock="Top"
                     Text="By profile name (check to include - leave all unchecked to include all)"/>
          <ListBox x:Name="ProfileList" Height="100"
                   SelectionMode="Multiple"
                   ItemContainerStyle="{StaticResource CheckListBoxItem}"/>
        </DockPanel>
      </Grid>
    </GroupBox>

    <GroupBox Grid.Row="1" Header="Match preview" Padding="8">
      <DockPanel>
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
          <CheckBox x:Name="SkipAlignedCheck" DockPanel.Dock="Left"
                    Content="Skip children already aligned with their parent"
                    IsChecked="True" VerticalAlignment="Center"/>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="MatchButton" Content="Match" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="UncheckAllButton" Content="Uncheck all" Width="100" Margin="0,0,8,0"/>
            <Button x:Name="CheckAllButton" Content="Check all" Width="100"/>
          </StackPanel>
          <TextBlock/>
        </DockPanel>
        <TextBlock DockPanel.Dock="Top" x:Name="SummaryLabel"
                   Margin="0,0,0,6" Foreground="Gray"/>
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel x:Name="MatchRowsPanel"/>
        </ScrollViewer>
      </DockPanel>
    </GroupBox>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Margin="0,0,16,0" Foreground="Gray"/>
      <Button x:Name="FollowButton" Content="Follow checked children" Width="200" Margin="0,0,8,0" IsEnabled="False"/>
      <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
