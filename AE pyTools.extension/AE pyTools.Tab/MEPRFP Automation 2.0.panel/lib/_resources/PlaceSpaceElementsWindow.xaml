<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Place Space Elements (MEPRFP 2.0)"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="540"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      Preview of every family instance the placement engine will create.
      Each row is one prospective placement (one anchor point × one LED
      offset). Run the placement to commit them inside one Revit
      transaction; rerunning is safe — re-placement is idempotent only
      to the extent that you delete prior elements first.
    </TextBlock>

    <DockPanel Grid.Row="1" Margin="0,0,0,6">
      <TextBlock x:Name="SummaryLabel" Foreground="Gray"
                 VerticalAlignment="Center"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="SelectAllButton" Content="Select all" Width="100" Margin="0,0,4,0"/>
        <Button x:Name="SelectNoneButton" Content="Select none" Width="100" Margin="0,0,12,0"/>
        <Button x:Name="RefreshButton" Content="Refresh" Width="120"
                ToolTip="Re-collect every plan from the active YAML and saved classifications."/>
      </StackPanel>
    </DockPanel>

    <!-- Note: ``IsReadOnly`` is omitted on the DataGrid so the
         per-row Select checkbox is editable. The text columns are
         each marked IsReadOnly individually. -->
    <DataGrid Grid.Row="2" x:Name="PreviewGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              SelectionMode="Extended"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              ColumnWidth="*">
      <DataGrid.Columns>
        <DataGridTemplateColumn Header="" MinWidth="40" Width="40">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <CheckBox x:Name="SelectCheckBox"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Space"
                            Binding="{Binding SpaceLabel}"
                            IsReadOnly="True"
                            MinWidth="180" Width="1.6*"/>
        <DataGridTextColumn Header="Bucket"
                            Binding="{Binding BucketLabel}"
                            IsReadOnly="True"
                            MinWidth="160" Width="1.4*"/>
        <DataGridTextColumn Header="Profile"
                            Binding="{Binding ProfileLabel}"
                            IsReadOnly="True"
                            MinWidth="160" Width="1.4*"/>
        <DataGridTextColumn Header="LED Label (Family : Type)"
                            Binding="{Binding Label}"
                            IsReadOnly="True"
                            MinWidth="220" Width="2*"/>
        <DataGridTextColumn Header="Anchor"
                            Binding="{Binding KindLabel}"
                            IsReadOnly="True"
                            MinWidth="100" Width="0.8*"/>
        <DataGridTextColumn Header="X (ft)"
                            Binding="{Binding XText}"
                            IsReadOnly="True"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Y (ft)"
                            Binding="{Binding YText}"
                            IsReadOnly="True"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Z (ft)"
                            Binding="{Binding ZText}"
                            IsReadOnly="True"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Rot (deg)"
                            Binding="{Binding RotText}"
                            IsReadOnly="True"
                            MinWidth="80" Width="0.6*"/>
        <DataGridTextColumn Header="Status"
                            Binding="{Binding Status}"
                            IsReadOnly="True"
                            MinWidth="120" Width="1.0*"/>
        <DataGridTemplateColumn Header="Comments"
                                MinWidth="240" Width="3.0*">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Comment}"
                         TextWrapping="Wrap"
                         VerticalAlignment="Center"
                         ToolTip="{Binding Comment}"/>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
    </DataGrid>

    <DockPanel Grid.Row="3" Margin="0,12,0,0">
      <TextBlock DockPanel.Dock="Left" x:Name="StatusLabel"
                 VerticalAlignment="Center" Foreground="Gray"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="PlaceButton" Content="Place selected" Width="140" Margin="0,0,8,0"
                ToolTip="Create the ticked rows' family instances inside one Revit transaction. Untick rows you don't want this run."/>
        <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
