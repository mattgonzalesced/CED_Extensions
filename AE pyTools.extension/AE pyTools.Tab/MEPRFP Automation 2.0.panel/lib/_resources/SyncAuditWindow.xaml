<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Check Synced Relationships (MEPRFP 2.0)"
        Width="1180" Height="720"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Grid.Row="0" Margin="0,0,0,8">
      <TextBlock DockPanel.Dock="Left" FontWeight="Bold" VerticalAlignment="Center"
                 Text="Synced-relationship audit"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="RefreshButton" Content="Refresh" Width="100" Margin="0,0,8,0"/>
        <ComboBox x:Name="BulkActionCombo" Width="180" Margin="0,0,8,0">
          <ComboBoxItem Content="Bulk action..." IsSelected="True"/>
          <ComboBoxItem Content="Set all: Update child"/>
          <ComboBoxItem Content="Set all: Update parent"/>
          <ComboBoxItem Content="Set all: Skip"/>
        </ComboBox>
      </StackPanel>
      <TextBlock x:Name="SummaryLabel" Margin="16,0,0,0" VerticalAlignment="Center" Foreground="Gray"/>
    </DockPanel>

    <!-- Tree-view: Profile -> LED -> Conflict -->
    <TreeView x:Name="ConflictTree" Grid.Row="1">
      <TreeView.Resources>
        <Style TargetType="TreeViewItem">
          <Setter Property="IsExpanded" Value="True"/>
        </Style>
      </TreeView.Resources>
    </TreeView>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <Button x:Name="ApplyButton" Content="Apply selected actions" Width="180" Margin="0,0,8,0" IsDefault="True"/>
      <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
