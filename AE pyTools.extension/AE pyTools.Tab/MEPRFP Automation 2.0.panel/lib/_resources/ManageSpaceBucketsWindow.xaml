<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Space Buckets (MEPRFP 2.0)"
        Width="1100" Height="640"
        MinWidth="800" MinHeight="420"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      Define the keyword categories the auto-classifier matches Space
      names against. Each bucket carries a list of substrings
      (case-insensitive) and an optional client-key restriction (empty
      = universal across clients).
    </TextBlock>

    <DockPanel Grid.Row="1" Margin="0,0,0,6">
      <TextBlock x:Name="SummaryLabel" Foreground="Gray" VerticalAlignment="Center"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="NewButton" Content="New" Width="80" Margin="0,0,4,0"/>
        <Button x:Name="DuplicateButton" Content="Duplicate" Width="100" Margin="0,0,4,0"/>
        <Button x:Name="DeleteButton" Content="Delete" Width="80"/>
      </StackPanel>
    </DockPanel>

    <DataGrid Grid.Row="2" x:Name="BucketGrid"
              AutoGenerateColumns="False"
              CanUserAddRows="False"
              CanUserDeleteRows="False"
              HeadersVisibility="Column"
              GridLinesVisibility="Horizontal"
              SelectionMode="Single"
              HorizontalAlignment="Stretch"
              VerticalAlignment="Stretch"
              HorizontalScrollBarVisibility="Auto"
              VerticalScrollBarVisibility="Auto"
              ColumnWidth="*"
              RowHeight="24">
      <DataGrid.Columns>
        <DataGridTextColumn Header="Name"
                            Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            MinWidth="140" Width="1.4*"/>
        <DataGridTextColumn Header="Client keys (comma-separated; empty = universal)"
                            Binding="{Binding ClientKeysText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            MinWidth="180" Width="1.4*"/>
        <DataGridTextColumn Header="Classification keywords (comma-separated)"
                            Binding="{Binding KeywordsText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                            MinWidth="220" Width="2.4*"/>
        <DataGridTextColumn Header="Bucket Id"
                            Binding="{Binding BucketId}"
                            IsReadOnly="True"
                            MinWidth="120" Width="0.9*"/>
      </DataGrid.Columns>
    </DataGrid>

    <DockPanel Grid.Row="3" Margin="0,12,0,0">
      <TextBlock DockPanel.Dock="Left" x:Name="StatusLabel"
                 VerticalAlignment="Center" Foreground="Gray"/>
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button x:Name="SaveButton" Content="Save" Width="100" Margin="0,0,8,0"/>
        <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
      </StackPanel>
    </DockPanel>
  </Grid>
</Window>
