<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit LED Details"
        Width="980" Height="640"
        MinWidth="780" MinHeight="500"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" x:Name="HeaderLabel" FontWeight="Bold" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>

    <TabControl Grid.Row="1" x:Name="DetailTabs">
      <!-- ===== Parameters tab ===== -->
      <TabItem Header="Parameters" x:Name="ParametersTab">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="Gray" TextWrapping="Wrap">
            Static parameter values written onto the placed family
            instance. Names match the parameter exactly as it appears
            on the family (case-sensitive).
          </TextBlock>
          <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="ParamAddButton" Content="Add" Width="80" Margin="0,0,4,0"/>
              <Button x:Name="ParamDeleteButton" Content="Delete" Width="80"/>
            </StackPanel>
          </DockPanel>
          <DataGrid Grid.Row="2" x:Name="ParamGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    SelectionMode="Single"
                    ColumnWidth="*"
                    RowHeight="22">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Name"
                                  Binding="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="200" Width="1.4*"/>
              <DataGridTextColumn Header="Value"
                                  Binding="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="240" Width="2*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- ===== Offsets tab ===== -->
      <TabItem Header="Offsets" x:Name="OffsetsTab">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="Gray" TextWrapping="Wrap">
            Each row produces one placed instance per anchor point. So
            a door-relative LED with two offsets and three doors yields
            six instances. Z lifts above the floor anchor (e.g. 18 in
            for wall outlets, 96 in for ceiling fixtures).
          </TextBlock>
          <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="OffsetAddButton" Content="Add" Width="80" Margin="0,0,4,0"/>
              <Button x:Name="OffsetDeleteButton" Content="Delete" Width="80"/>
            </StackPanel>
          </DockPanel>
          <DataGrid Grid.Row="2" x:Name="OffsetGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    SelectionMode="Single"
                    ColumnWidth="*"
                    RowHeight="22">
            <DataGrid.Columns>
              <DataGridTextColumn Header="X (in)"
                                  Binding="{Binding XText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="80" Width="1*"/>
              <DataGridTextColumn Header="Y (in)"
                                  Binding="{Binding YText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="80" Width="1*"/>
              <DataGridTextColumn Header="Z (in)"
                                  Binding="{Binding ZText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="80" Width="1*"/>
              <DataGridTextColumn Header="Rotation (deg)"
                                  Binding="{Binding RotText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="100" Width="1.2*"/>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>

      <!-- ===== Annotations tab ===== -->
      <TabItem Header="Annotations" x:Name="AnnotationsTab">
        <Grid Margin="8">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Grid.Row="0" Margin="0,0,0,6" Foreground="Gray" TextWrapping="Wrap">
            Tags / keynotes / text notes attached to this LED. Offsets
            are relative to the host fixture (NOT the space). Use the
            per-row Params... button to edit annotation-specific
            parameters (tag rotation, text content, etc.).
          </TextBlock>
          <DockPanel Grid.Row="1" Margin="0,0,0,6">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="AnnAddButton" Content="Add" Width="80" Margin="0,0,4,0"/>
              <Button x:Name="AnnDeleteButton" Content="Delete" Width="80"/>
            </StackPanel>
          </DockPanel>
          <DataGrid Grid.Row="2" x:Name="AnnGrid"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    HeadersVisibility="Column"
                    GridLinesVisibility="Horizontal"
                    SelectionMode="Single"
                    ColumnWidth="*"
                    RowHeight="24">
            <DataGrid.Columns>
              <DataGridTemplateColumn Header="Kind" MinWidth="100" Width="0.9*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <ComboBox SelectedValue="{Binding Kind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              ItemsSource="{Binding KindOptions}"
                              IsEditable="False"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
              <DataGridTextColumn Header="Label / Tag Type"
                                  Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="180" Width="1.6*"/>
              <DataGridTextColumn Header="Family"
                                  Binding="{Binding FamilyName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="140" Width="1.2*"/>
              <DataGridTextColumn Header="Type"
                                  Binding="{Binding TypeName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="120" Width="1*"/>
              <DataGridTextColumn Header="X (in)"
                                  Binding="{Binding OffsetXText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="70" Width="0.7*"/>
              <DataGridTextColumn Header="Y (in)"
                                  Binding="{Binding OffsetYText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="70" Width="0.7*"/>
              <DataGridTextColumn Header="Z (in)"
                                  Binding="{Binding OffsetZText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="70" Width="0.7*"/>
              <DataGridTextColumn Header="Rot (deg)"
                                  Binding="{Binding OffsetRotText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                  MinWidth="80" Width="0.8*"/>
              <DataGridTemplateColumn Header="" MinWidth="80" Width="0.7*">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate>
                    <Button Content="Params..." Tag="{Binding}"
                            Padding="4,2" Margin="2"/>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>
            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </TabItem>
    </TabControl>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
      <TextBlock x:Name="StatusLabel" VerticalAlignment="Center" Foreground="Gray" Margin="0,0,16,0"/>
      <Button x:Name="OkButton" Content="OK" Width="100" Margin="0,0,8,0" IsDefault="True"/>
      <Button x:Name="CancelButton" Content="Cancel" Width="100" IsCancel="True"/>
    </StackPanel>
  </Grid>
</Window>
