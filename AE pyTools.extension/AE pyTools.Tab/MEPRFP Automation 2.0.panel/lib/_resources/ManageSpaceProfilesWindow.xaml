<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Manage Space Profiles (MEPRFP 2.0)"
        Width="1280" Height="780"
        MinWidth="1000" MinHeight="600"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="12">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Margin="0,0,0,8" TextWrapping="Wrap">
      Space-profile templates. The placement engine unions every profile
      whose <Run FontStyle="Italic">bucket_id</Run> matches a Space's
      assigned buckets, then anchors each LED per its placement rule
      (wall edge / corner / door-relative). Use Save to persist edits to
      the active YAML payload.
    </TextBlock>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320" MinWidth="240"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <!-- Left: profile list + add/delete -->
      <DockPanel Grid.Column="0" Margin="0,0,8,0">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
          <Button x:Name="NewProfileButton" Content="New" Width="68" Margin="0,0,4,0"/>
          <Button x:Name="DuplicateProfileButton" Content="Duplicate" Width="80" Margin="0,0,4,0"/>
          <Button x:Name="DeleteProfileButton" Content="Delete" Width="68"/>
        </StackPanel>
        <TextBlock DockPanel.Dock="Top" x:Name="ProfileSummaryLabel"
                   Foreground="Gray" Margin="0,0,0,6"/>
        <ListBox x:Name="ProfileList"
                 DisplayMemberPath="DisplayName"
                 SelectionMode="Single"/>
      </DockPanel>

      <!-- Right: detail editor -->
      <Grid Grid.Column="1">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- header -->
        <TextBlock Grid.Row="0" x:Name="DetailHeader"
                   FontWeight="Bold" FontSize="14" Margin="0,0,0,8"
                   Text="Select a profile..."/>

        <!-- name + bucket -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="20"/>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="2*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Profile name:" VerticalAlignment="Center"/>
          <TextBox Grid.Column="1" x:Name="NameBox" VerticalContentAlignment="Center"/>
          <TextBlock Grid.Column="3" Text="Bucket:" VerticalAlignment="Center"/>
          <ComboBox  Grid.Column="4" x:Name="BucketCombo"
                     DisplayMemberPath="Display"
                     SelectedValuePath="Id"
                     IsEditable="False"/>
        </Grid>

        <!-- toolbar for the LED grid -->
        <DockPanel Grid.Row="2" Margin="0,0,0,4">
          <TextBlock DockPanel.Dock="Left" x:Name="LedSummaryLabel"
                     Foreground="Gray" VerticalAlignment="Center"/>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="AddLedButton" Content="Add LED" Width="100" Margin="0,0,4,0"/>
            <Button x:Name="DeleteLedButton" Content="Delete LED" Width="110"/>
          </StackPanel>
        </DockPanel>

        <!-- LED grid -->
        <DataGrid Grid.Row="3" x:Name="LedGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  SelectionMode="Single"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  ColumnWidth="*"
                  RowHeight="24">
          <DataGrid.Columns>
            <DataGridTextColumn Header="Linked-set name"
                                Binding="{Binding SetName, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="140" Width="1.4*"/>
            <DataGridTextColumn Header="Label (Family : Type)"
                                Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="180" Width="2*"/>
            <DataGridTextColumn Header="Category"
                                Binding="{Binding Category, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="120" Width="1.2*"/>
            <DataGridTemplateColumn Header="Anchor"
                                    MinWidth="120" Width="1.2*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <ComboBox SelectedValue="{Binding Kind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            ItemsSource="{Binding KindOptions}"
                            IsEditable="False"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Inset (in)"
                                Binding="{Binding InsetText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="80" Width="0.7*"/>
            <DataGridTextColumn Header="Door Off X (in)"
                                Binding="{Binding DoorOffsetXText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="100" Width="0.9*"/>
            <DataGridTextColumn Header="Door Off Y (in)"
                                Binding="{Binding DoorOffsetYText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
                                MinWidth="100" Width="0.9*"/>
            <DataGridTemplateColumn Header="" MinWidth="80" Width="0.7*">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="Details..." Tag="{Binding}"
                          Padding="4,2" Margin="2"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="LED Id"
                                Binding="{Binding LedId}"
                                IsReadOnly="True"
                                MinWidth="100" Width="1*"/>
          </DataGrid.Columns>
        </DataGrid>

        <!-- bottom buttons -->
        <DockPanel Grid.Row="4" Margin="0,12,0,0">
          <TextBlock DockPanel.Dock="Left" x:Name="StatusLabel"
                     VerticalAlignment="Center" Foreground="Gray"/>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="SaveButton" Content="Save" Width="100" Margin="0,0,8,0"
                    ToolTip="Persist all edits to the active YAML payload."/>
            <Button x:Name="CloseButton" Content="Close" Width="100" IsCancel="True"/>
          </StackPanel>
        </DockPanel>
      </Grid>
    </Grid>

    <TextBlock Grid.Row="2" Margin="0,8,0,0" Foreground="Gray" FontStyle="Italic"
               Text="Use the per-row Details... button to edit each LED's parameters, offsets, and annotations."
               TextWrapping="Wrap"/>
  </Grid>
</Window>
