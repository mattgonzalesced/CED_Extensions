<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Alerts Browser"
        Height="620"
        Width="1240"
        MinHeight="440"
        MinWidth="920"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CED.Brush.WindowBackground}">
  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Vertical">
        <TextBlock Text="Alerts Browser" Style="{DynamicResource CED.Text.Title}"/>
        <TextBlock Name="DocumentText" Text="Document: -" Style="{DynamicResource CED.Text.Secondary}" Margin="0,2,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1" Name="CircuitCountText" Text="0 circuits with alerts" Style="{DynamicResource CED.Text.Secondary}" VerticalAlignment="Bottom"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
              BorderThickness="1"
              Background="{DynamicResource CED.Brush.ListBackground}">
        <ListView Name="CircuitList"
                  Style="{DynamicResource CED.ListView.Alerts}"
                  SelectionMode="Single"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True"
                  SelectionChanged="circuit_selection_changed">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource CED.Brush.CardBorder}"
                      BorderThickness="0,0,0,1"
                      Background="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Background}"
                      Padding="8,6">
                <StackPanel>
                  <TextBlock Text="{Binding panel_ckt_text}"
                             FontWeight="Bold"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <TextBlock Text="{Binding load_name}"
                             TextTrimming="CharacterEllipsis"
                             FontSize="11"
                             Opacity="0.92"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <TextBlock Text="{Binding counts_text}"
                             FontSize="10"
                             Opacity="0.88"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <Grid Grid.Column="2">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
          <TextBlock Name="SelectedCircuitText" Text="Select a circuit with alerts" Style="{DynamicResource CED.Text.SectionHeader}"/>
          <TextBlock Name="SelectedCountsText" Text="Alerts: 0" Style="{DynamicResource CED.Text.Secondary}"/>
        </StackPanel>

        <TabControl Grid.Row="1" Name="AlertsTabs" Style="{DynamicResource CED.TabControl.Base}">
          <TabItem Header="Active">
            <Border BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
                    BorderThickness="1"
                    Background="{DynamicResource CED.Brush.ListBackground}"
                    Margin="4">
              <ListView Name="ActiveAlertsList"
                        Style="{DynamicResource CED.ListView.AlertsGrid}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True">
                <ListView.View>
                  <GridView ColumnHeaderContainerStyle="{DynamicResource CED.GridView.Header}">
                    <GridViewColumn Header="Severity" Width="94" DisplayMemberBinding="{Binding severity}"/>
                    <GridViewColumn Header="Group" Width="130" DisplayMemberBinding="{Binding group}"/>
                    <GridViewColumn Header="Alert ID" Width="260" DisplayMemberBinding="{Binding definition_id}"/>
                    <GridViewColumn Header="Message" Width="460">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding message}" TextWrapping="Wrap" MaxWidth="450"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                  </GridView>
                </ListView.View>
              </ListView>
            </Border>
          </TabItem>
          <TabItem Header="Hidden">
            <Border BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
                    BorderThickness="1"
                    Background="{DynamicResource CED.Brush.ListBackground}"
                    Margin="4">
              <ListView Name="HiddenAlertsList"
                        Style="{DynamicResource CED.ListView.AlertsGrid}"
                        VirtualizingPanel.IsVirtualizing="True"
                        VirtualizingPanel.VirtualizationMode="Recycling"
                        ScrollViewer.CanContentScroll="True">
                <ListView.View>
                  <GridView ColumnHeaderContainerStyle="{DynamicResource CED.GridView.Header}">
                    <GridViewColumn Header="Severity" Width="94" DisplayMemberBinding="{Binding severity}"/>
                    <GridViewColumn Header="Group" Width="130" DisplayMemberBinding="{Binding group}"/>
                    <GridViewColumn Header="Alert ID" Width="260" DisplayMemberBinding="{Binding definition_id}"/>
                    <GridViewColumn Header="Message" Width="460">
                      <GridViewColumn.CellTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding message}" TextWrapping="Wrap" MaxWidth="450"/>
                        </DataTemplate>
                      </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                  </GridView>
                </ListView.View>
              </ListView>
            </Border>
          </TabItem>
        </TabControl>
      </Grid>
    </Grid>

    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Style="{DynamicResource CED.Button.Base}" Content="Refresh" Width="84" Height="28" Click="refresh_clicked"/>
      <Button Style="{DynamicResource CED.Button.Base}" Content="Close" Width="84" Height="28" Margin="6,0,0,0" Click="close_clicked"/>
    </StackPanel>
  </Grid>
</Window>
