<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Circuit Properties"
        Height="760"
        Width="1260"
        MinHeight="560"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CED.Brush.WindowBackground}">
  <Window.Resources>
    <Style x:Key="EditorCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.CardBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="EditorLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
    <Style x:Key="EditorInputText" TargetType="TextBox">
      <Setter Property="Height" Value="22"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridEditableBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridDividerStrong}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridReadOnlyBackground}"/>
          <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EditorNumericText" TargetType="TextBox" BasedOn="{StaticResource EditorInputText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoAccentBackground}"/>
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="EditorCombo" TargetType="ComboBox">
      <Setter Property="Height" Value="22"/>
      <Setter Property="MinWidth" Value="74"/>
      <Setter Property="Padding" Value="4,1"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Border}"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridEditableBackground}"/>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridReadOnlyBackground}"/>
          <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EditorRadio" TargetType="RadioButton">
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="PreviewValueBox" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
  </Window.Resources>

  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Edit Circuit Properties" Style="{DynamicResource CED.Text.Title}"/>
        <TextBlock Text="Stage per-circuit overrides, preview recalculated values, then apply all changes."
                   Style="{DynamicResource CED.Text.Secondary}" Margin="0,2,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1" Name="PendingCountText" Text="0 circuits pending"
                 Style="{DynamicResource CED.Text.Secondary}" VerticalAlignment="Bottom"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="320"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
              BorderThickness="1"
              Background="{DynamicResource CED.Brush.ListBackground}">
        <ListView Name="CircuitList"
                  Style="{DynamicResource CED.ListView.Alerts}"
                  SelectionMode="Single"
                  SelectionChanged="circuit_selection_changed"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource CED.Brush.CardBorder}"
                      BorderThickness="0,0,0,1"
                      Background="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Background}"
                      Padding="8,6">
                <StackPanel>
                  <TextBlock Text="{Binding panel_ckt_text}"
                             FontWeight="Bold"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <TextBlock Text="{Binding load_name}"
                             FontSize="11"
                             Opacity="0.92"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <DockPanel Margin="0,2,0,0">
                    <TextBlock Text="{Binding branch_type}"
                               FontSize="10"
                               Opacity="0.88"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                    <TextBlock Text="{Binding status_text}"
                               DockPanel.Dock="Right"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource CED.Brush.TertiaryGreen}"
                               Visibility="{Binding status_visibility}"/>
                  </DockPanel>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <Grid Grid.Column="2" Name="EditorPanelRoot">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
          <TextBlock Name="SelectedCircuitText"
                     Text="Select a circuit"
                     Style="{DynamicResource CED.Text.SectionHeader}"/>
          <TextBlock Name="UnsupportedText"
                     Text="Unsupported circuit type. Editing is disabled."
                     Style="{DynamicResource CED.Text.Secondary}"
                     Foreground="{DynamicResource CED.Brush.SecondaryRed}"
                     Visibility="Collapsed"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                BorderThickness="1"
                Background="{DynamicResource CED.Brush.ListBackground}"
                CornerRadius="4">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="10">
            <StackPanel>
              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Override Mode" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <WrapPanel>
                    <CheckBox Name="UserOverrideCheck"
                              Content="User Override"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="user_override_changed"
                              Unchecked="user_override_changed"/>
                    <CheckBox Name="CustomHotCheck"
                              Content="Custom Hot"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="hot_custom_changed"
                              Unchecked="hot_custom_changed"/>
                    <CheckBox Name="CustomGroundCheck"
                              Content="Custom Ground"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="ground_custom_changed"
                              Unchecked="ground_custom_changed"/>
                    <CheckBox Name="CustomConduitCheck"
                              Content="Custom Conduit"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="conduit_custom_changed"
                              Unchecked="conduit_custom_changed"/>
                  </WrapPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Name="NeutralBehaviorText" Style="{DynamicResource CED.Text.Secondary}" Margin="0,0,16,0"/>
                    <TextBlock Name="IgBehaviorText" Style="{DynamicResource CED.Text.Secondary}"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Circuit Properties" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="66"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="66"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="86"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Rating (A)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Name="RatingTextBox" Style="{StaticResource EditorNumericText}" LostFocus="editable_value_changed"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Frame (A)" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="4" Name="FrameTextBox" Style="{StaticResource EditorNumericText}" LostFocus="editable_value_changed"/>
                    <TextBlock Grid.Row="0" Grid.Column="6" Text="Length Makeup" Style="{StaticResource EditorLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="7" Name="LengthMakeupTextBox" Style="{StaticResource EditorNumericText}" LostFocus="editable_value_changed"/>

                    <TextBlock Grid.Row="1" Grid.Column="6" Text="Total Length" Style="{DynamicResource CED.Text.Secondary}" Margin="0,4,6,0"/>
                    <Border Grid.Row="1" Grid.Column="7" Style="{StaticResource PreviewValueBox}" Margin="0,4,0,0">
                      <TextBlock Name="TotalLengthText" Text="-" HorizontalAlignment="Center"/>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Wire Properties" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Material" Style="{StaticResource EditorLabel}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <RadioButton Name="WireMaterialCuRadio"
                                   GroupName="WireMaterial"
                                   Content="CU"
                                   Style="{StaticResource EditorRadio}"
                                   Checked="editable_value_changed"/>
                      <RadioButton Name="WireMaterialAlRadio"
                                   GroupName="WireMaterial"
                                   Content="AL"
                                   Style="{StaticResource EditorRadio}"
                                   Checked="editable_value_changed"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3" Text="Temperature" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="4" Name="WireTempCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>

                    <TextBlock Grid.Column="6" Text="Insulation" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="7" Name="WireInsulationCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Wire Overrides" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="66"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Conductor" Style="{StaticResource EditorLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Hot" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Neutral" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Ground" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="7" Text="Isolated Ground" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Name="HotSizeCombo" Style="{StaticResource EditorCombo}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="3" Name="NeutralSizeCombo" Style="{StaticResource EditorCombo}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="5" Name="GroundSizeCombo" Style="{StaticResource EditorCombo}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="7" Name="IgSizeCombo" Style="{StaticResource EditorCombo}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Include" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Always" Style="{DynamicResource CED.Text.Secondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <CheckBox Grid.Row="2" Grid.Column="3"
                              Name="IncludeNeutralCheck"
                              Content="Include"
                              HorizontalAlignment="Center"
                              Margin="0,6,0,0"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="include_neutral_changed"
                              Unchecked="include_neutral_changed"/>
                    <TextBlock Grid.Row="2" Grid.Column="5" Text="Always" Style="{DynamicResource CED.Text.Secondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <CheckBox Grid.Row="2" Grid.Column="7"
                              Name="IncludeIGCheck"
                              Content="Include"
                              HorizontalAlignment="Center"
                              Margin="0,6,0,0"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="include_ig_changed"
                              Unchecked="include_ig_changed"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Quantity" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="HotQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="NeutralQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="5" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="GroundQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="7" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="IgQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <TextBlock Grid.Row="3" Grid.Column="9" Text="# Sets" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <TextBox Grid.Row="3" Grid.Column="10" Name="NumberSetsTextBox" Style="{StaticResource EditorNumericText}" Margin="0,6,0,0" LostFocus="editable_value_changed"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Conduit Overrides" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="120"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="76"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Conduit Size" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="1" Name="ConduitSizeCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>
                    <TextBlock Grid.Column="3" Text="Conduit Type" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="4" Name="ConduitTypeCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>
                    <TextBlock Grid.Column="6" Text="Conduit Fill" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="7" Style="{StaticResource PreviewValueBox}" Margin="0">
                      <TextBlock Name="ConduitFillText" Text="-" HorizontalAlignment="Center"/>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Calculated Preview" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="82"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="102"/>
                      <ColumnDefinition Width="28"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="172"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="VD" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="1" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewVoltageDropText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                    <TextBlock Grid.Column="3" Text="Load Current" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="4" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewLoadCurrentText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                    <TextBlock Grid.Column="6" Text="Ampacity" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="7" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewAmpacityText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                  </Grid>
                  <Border Style="{StaticResource PreviewValueBox}">
                    <StackPanel>
                      <TextBlock Text="Wire Summary" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                      <TextBlock Name="PreviewWireSummaryText" Text="-" Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource PreviewValueBox}">
                    <StackPanel>
                      <TextBlock Text="Conduit Summary" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                      <TextBlock Name="PreviewConduitSummaryText" Text="-" Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                  <Border Style="{StaticResource PreviewValueBox}" Background="{DynamicResource CED.Brush.DataGridWarningBackground}">
                    <StackPanel>
                      <TextBlock Text="Warnings" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                      <TextBlock Name="PreviewNoticeText" Text="No warnings." Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>
            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Name="StatusText" Text="Ready" Style="{DynamicResource CED.Text.Secondary}" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Style="{DynamicResource CED.Button.Base}" Content="Cancel" Width="90" Height="28" Click="cancel_clicked"/>
        <Button Style="{DynamicResource CED.Button.Apply}" Content="Apply" Width="90" Height="28" Margin="8,0,0,0" Click="apply_clicked"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
