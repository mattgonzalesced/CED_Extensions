<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Circuit Action"
        Height="560"
        Width="1260"
        MinHeight="420"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CED.Brush.WindowBackground}"
        PreviewMouseDown="window_preview_mouse_down">
  <Window.Resources>
    <ResourceDictionary>
</ResourceDictionary>
  </Window.Resources>

  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Name="TitleText" Grid.Column="0" Text="Action" Style="{DynamicResource CED.Text.SectionHeader}" VerticalAlignment="Center"/>
      <CheckBox Name="ShowUnsupportedToggle"
                Grid.Column="1"
                Content="Show Unsupported Circuits"
                Style="{DynamicResource CED.Input.CheckBox}"
                Checked="show_unsupported_toggled"
                Unchecked="show_unsupported_toggled"/>
    </Grid>

    <Border Grid.Row="1" BorderBrush="{DynamicResource CED.Brush.DataGridBorder}" BorderThickness="1" Background="{DynamicResource CED.Brush.SearchBackground}">
      <DataGrid Name="CircuitGrid"
                Style="{DynamicResource CED.DataGrid.Base}"
                AutoGenerateColumns="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                CanUserAddRows="False"
                CanUserResizeRows="False"
                CanUserResizeColumns="False"
                HeadersVisibility="Column"
                RowHeaderWidth="0"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="{DynamicResource CED.Brush.DataGridAltRow}"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                ColumnHeaderStyle="{DynamicResource HeaderWrapCenter}"
                RowStyle="{DynamicResource CED.DataGrid.RowDisabledAware}"
                SelectionChanged="grid_selection_changed"
                PreviewMouseDown="grid_preview_mouse_down">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="34" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding is_checked, Mode=OneWay}" IsEnabled="{Binding is_enabled}" Click="item_checkbox_clicked"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Circuit" Width="176" IsReadOnly="True" SortMemberPath="panel_ckt_text" CellStyle="{DynamicResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Margin="4,2,4,2">
                  <TextBlock Text="{Binding panel_ckt_text}" FontWeight="Bold" Foreground="{DynamicResource CED.Brush.DataGridRowForeground}"/>
                  <TextBlock Text="{Binding load_name}" Foreground="{DynamicResource CED.Brush.SecondaryText}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Type" Width="76" Binding="{Binding branch_type}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Qty" Width="60" Binding="{Binding current_qty}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Size" Width="72" Binding="{Binding current_size}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Wire" Width="154" Binding="{Binding current_wire}" IsReadOnly="True" CellStyle="{DynamicResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="New&#10;Qty" Width="58" Binding="{Binding new_qty}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource NewQtyCell}"/>
          <DataGridTextColumn Header="New&#10;Size" Width="72" Binding="{Binding new_size}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource NewSizeCell}"/>
          <DataGridTemplateColumn Header="New&#10;Wire" Width="154" IsReadOnly="True" CellStyle="{DynamicResource NewWireCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding new_wire}" FontStyle="{Binding new_wire_font_style}" TextTrimming="CharacterEllipsis"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Remarks" Width="*" Binding="{Binding remarks}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell}" ElementStyle="{DynamicResource RemarksTextCell}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top">
          <Button Style="{DynamicResource CED.Button.Base}" Content="Check All" Width="76" Height="24" Click="check_all_clicked"/>
          <Button Style="{DynamicResource CED.Button.Base}" Content="Uncheck All" Width="84" Height="24" Margin="6,0,0,0" Click="uncheck_all_clicked"/>
          <Border Width="1" Height="20" Margin="14,2,14,0" Background="{DynamicResource CED.Brush.SectionDivider}" VerticalAlignment="Top"/>
          <Button Name="AddButton" Style="{DynamicResource CED.Button.Base}" Content="Add" Width="72" Height="24" VerticalAlignment="Top" Click="add_clicked"/>
          <Button Name="RemoveButton" Style="{DynamicResource CED.Button.Base}" Content="Remove" Width="72" Height="24" Margin="6,0,0,0" VerticalAlignment="Top" Click="remove_clicked"/>
        </StackPanel>
        <TextBlock Name="CheckedStatusText" Margin="2,4,0,0" Style="{DynamicResource CED.Text.Secondary}" Text="0 of 0 checked"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock Name="ChangedStatusText" Margin="0,0,12,0" VerticalAlignment="Center" Style="{DynamicResource CED.Text.Secondary}" Text="0 of 0 circuits to be modified."/>
        <Button Style="{DynamicResource CED.Button.Base}" Content="Cancel" Width="80" Height="24" Click="cancel_clicked"/>
        <Button Style="{DynamicResource CED.Button.Apply}" Content="Apply" Width="80" Height="24" Margin="6,0,0,0" Click="apply_clicked"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>

