<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mark as New/Existing"
        Height="580"
        Width="1420"
        MinHeight="440"
        MinWidth="1100"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CED.Brush.WindowBackground}"
        PreviewMouseDown="window_preview_mouse_down">
  <Window.Resources>
    <ResourceDictionary>
</ResourceDictionary>
  </Window.Resources>

  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Mark as New/Existing" Style="{DynamicResource CED.Text.SectionHeader}" VerticalAlignment="Center"/>
      <CheckBox Name="ShowUnsupportedToggle"
                Grid.Column="1"
                Content="Show Unsupported Circuits"
                Style="{DynamicResource CED.Input.CheckBox}"
                Checked="show_unsupported_toggled"
                Unchecked="show_unsupported_toggled"/>
    </Grid>

    <Border Grid.Row="1" BorderBrush="{DynamicResource CED.Brush.DataGridBorder}" BorderThickness="1" Background="{DynamicResource CED.Brush.SearchBackground}">
      <DataGrid Name="CircuitGrid"
                Style="{DynamicResource CED.DataGrid.Base}"
                AutoGenerateColumns="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                CanUserAddRows="False"
                CanUserResizeRows="False"
                CanUserResizeColumns="False"
                HeadersVisibility="Column"
                RowHeaderWidth="0"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="{DynamicResource CED.Brush.DataGridAltRow}"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                ColumnHeaderStyle="{DynamicResource HeaderWrapCenterTall}"
                RowStyle="{DynamicResource CED.DataGrid.RowDisabledAware}"
                SelectionChanged="grid_selection_changed"
                PreviewMouseDown="grid_preview_mouse_down">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="34" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding is_checked, Mode=OneWay}" IsEnabled="{Binding is_enabled}" Click="item_checkbox_clicked"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Circuit" Width="210" IsReadOnly="True" SortMemberPath="panel_ckt_text" CellStyle="{DynamicResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Margin="4,2,4,2">
                  <TextBlock Text="{Binding panel_ckt_text}" FontWeight="Bold" Foreground="{DynamicResource CED.Brush.DataGridRowForeground}"/>
                  <TextBlock Text="{Binding load_name}" Foreground="{DynamicResource CED.Brush.SecondaryText}" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Type" Width="86" Binding="{Binding branch_type}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource DividerThickReadonlyCell}"/>

          <DataGridTextColumn Header="Current&#10;Schedule Notes" Width="92" Binding="{Binding current_notes}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Conduit/Wire Size" Width="168" Binding="{Binding current_wire}" IsReadOnly="True" CellStyle="{DynamicResource DividerThickReadonlyCell}"/>

          <DataGridTextColumn Header="New&#10;Schedule Notes" Width="92" Binding="{Binding new_notes}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource NewNotesCell}"/>
          <DataGridTextColumn Header="New&#10;Conduit/Wire Size" Width="168" Binding="{Binding new_wire}" IsReadOnly="True" CellStyle="{DynamicResource NewWireStringCell}"/>
          <DataGridTextColumn Header="Remarks" Width="*" Binding="{Binding remarks}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell}" ElementStyle="{DynamicResource RemarksTextCell}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
          <StackPanel Orientation="Horizontal">
            <Button Style="{DynamicResource CED.Button.Base}" Content="Check All" Width="86" Height="28" Click="check_all_clicked"/>
            <Button Style="{DynamicResource CED.Button.Base}" Content="Uncheck All" Width="94" Height="28" Margin="6,0,0,0" Click="uncheck_all_clicked"/>
          </StackPanel>
          <TextBlock Name="CheckedStatusText" Margin="2,4,0,0" Style="{DynamicResource CED.Text.Secondary}" Text="0 of 0 checked"/>
        </StackPanel>

        <Border Margin="12,0,0,0"
                Padding="8,5,10,5"
                BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
                BorderThickness="1"
                CornerRadius="4"
                Background="{DynamicResource CED.Brush.InfoPanelBackground}"
                VerticalAlignment="Top">
          <StackPanel>
            <CheckBox Name="SetNotesCheck"
                      Content="Set Circuit Notes (EX / blank)"
                      IsChecked="True"
                      Style="{DynamicResource CED.Input.CheckBox}"
                      Checked="options_changed"
                      Unchecked="options_changed"/>
            <CheckBox Name="ClearWireCheck"
                      Content="Clear Wire"
                      IsChecked="False"
                      Style="{DynamicResource CED.Input.CheckBox}"
                      Margin="0,4,0,0"
                      Checked="options_changed"
                      Unchecked="options_changed"/>
            <CheckBox Name="ClearConduitCheck"
                      Content="Clear Conduit"
                      IsChecked="False"
                      Style="{DynamicResource CED.Input.CheckBox}"
                      Margin="0,2,0,0"
                      Checked="options_changed"
                      Unchecked="options_changed"/>
          </StackPanel>
        </Border>

        <Button Name="SetExistingButton"
                Style="{DynamicResource CED.Button.Apply}"
                Content="Set as Existing"
                Width="110"
                Height="28"
                Margin="12,0,0,0"
                Click="set_existing_clicked"/>
        <Button Name="SetNewButton"
                Style="{DynamicResource CED.Button.Base}"
                Content="Set as New"
                Width="96"
                Height="28"
                Margin="6,0,0,0"
                Click="set_new_clicked"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock Name="ChangedStatusText" Margin="0,0,12,0" VerticalAlignment="Center" Style="{DynamicResource CED.Text.Secondary}" Text="0 of 0 circuits to be modified"/>
        <Button Style="{DynamicResource CED.Button.Base}" Content="Cancel" Width="80" Height="28" Click="cancel_clicked"/>
        <Button Name="ApplyButton" Style="{DynamicResource CED.Button.Apply}" Content="Apply" Width="80" Height="28" Margin="6,0,0,0" Click="apply_clicked"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
