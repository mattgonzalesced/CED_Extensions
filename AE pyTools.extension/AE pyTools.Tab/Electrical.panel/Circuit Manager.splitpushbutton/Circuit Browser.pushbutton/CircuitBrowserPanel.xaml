<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#EEEEEE">
  <Page.Resources>
    <ResourceDictionary>
<DataTemplate x:Key="CompactTemplate">
        <Border Style="{DynamicResource CED.Circuit.CompactContainer}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding is_checked, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Checked="item_checked"
                      Unchecked="item_unchecked"
                      Margin="0,0,6,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
              <Border Style="{DynamicResource CED.Badge.Base}"
                      Background="{Binding type_tag_bg}"
                      BorderBrush="{Binding type_tag_fg}"
                      Padding="4,0"
                      Margin="0,0,6,0"
                      Visibility="{Binding type_tag_visibility}">
                <TextBlock Text="{Binding type_tag_text}" Foreground="{Binding type_tag_fg}" Style="{DynamicResource CED.Badge.Text}"/>
              </Border>
              <TextBlock Text="{Binding panel}" FontWeight="Bold"/>
              <TextBlock Text=" / "/>
              <TextBlock Text="{Binding circuit_number}" FontWeight="Bold"/>
              <TextBlock Text="   "/>
              <TextBlock Text="{Binding load_name}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
              <TextBlock Text="{Binding rating_poles}" FontWeight="Bold" VerticalAlignment="Center"/>
              <Border Style="{DynamicResource CED.Badge.Info}" Margin="6,0,0,0" Visibility="{Binding neutral_badge_visibility}">
                <TextBlock Text="N" Style="{DynamicResource CED.Badge.Text.Info}"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Warning}" Margin="4,0,0,0" Visibility="{Binding ig_badge_visibility}">
                <TextBlock Text="IG" Style="{DynamicResource CED.Badge.Text.Warning}"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Alert}" Padding="2,0" Margin="4,0,0,0" Visibility="{Binding override_badge_visibility}" ToolTip="User override">
                <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.OverrideIcon}"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Alert}"
                      Padding="2,0"
                      Margin="4,0,0,0"
                      BorderBrush="{DynamicResource CED.Brush.SecondaryRed}"
                      Visibility="{Binding sync_lock_badge_visibility}"
                      ToolTip="{Binding sync_lock_tooltip}">
                <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.SyncBlockedIcon}"/>
              </Border>
            </StackPanel>

            <Button Grid.Column="3"
                    Style="{DynamicResource CED.Circuit.AlertButtonInteractive}"
                    Background="{Binding alert_bg}"
                    BorderBrush="{Binding alert_border}"
                    Margin="6,0,0,0"
                    Visibility="{Binding alert_visibility}"
                    ToolTip="{Binding alert_summary}"
                    Click="alert_tag_clicked"
                    MouseEnter="alert_button_mouse_enter"
                    MouseLeave="alert_button_mouse_leave">
              <TextBlock Text="!" FontWeight="Bold" Foreground="{Binding alert_text_color}"/>
            </Button>
          </Grid>
        </Border>
      </DataTemplate>

      <DataTemplate x:Key="CardTemplate">
        <Border Style="{DynamicResource CED.Circuit.CardContainer}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <CheckBox Grid.Column="0"
                        IsChecked="{Binding is_checked, Mode=TwoWay}"
                        VerticalAlignment="Top"
                        Checked="item_checked"
                        Unchecked="item_unchecked"
                        Margin="0,1,6,0"/>

              <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <TextBlock Text="{Binding panel}" FontWeight="Bold"/>
                <TextBlock Text=" / "/>
                <TextBlock Text="{Binding circuit_number}" FontWeight="Bold"/>
                <TextBlock Text="   "/>
                <TextBlock Text="{Binding load_name}"/>
              </StackPanel>

              <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,0,0,0">
                <TextBlock Text="{Binding rating_poles}" FontWeight="Bold" VerticalAlignment="Top"/>
                <Border Style="{DynamicResource CED.Badge.Info}" Margin="6,0,0,0" Visibility="{Binding neutral_badge_visibility}">
                  <TextBlock Text="N" Style="{DynamicResource CED.Badge.Text.Info}"/>
                </Border>
                <Border Style="{DynamicResource CED.Badge.Warning}" Margin="4,0,0,0" Visibility="{Binding ig_badge_visibility}">
                  <TextBlock Text="IG" Style="{DynamicResource CED.Badge.Text.Warning}"/>
                </Border>
                <Border Style="{DynamicResource CED.Badge.Alert}" Padding="2,0" Margin="4,0,0,0" Visibility="{Binding override_badge_visibility}" ToolTip="User override">
                  <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.OverrideIcon}"/>
                </Border>
                <Border Style="{DynamicResource CED.Badge.Alert}"
                        Padding="2,0"
                        Margin="4,0,0,0"
                        BorderBrush="{DynamicResource CED.Brush.SecondaryRed}"
                        Visibility="{Binding sync_lock_badge_visibility}"
                        ToolTip="{Binding sync_lock_tooltip}">
                  <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.SyncBlockedIcon}"/>
                </Border>
              </StackPanel>

              <Button Grid.Column="3"
                      Style="{DynamicResource CED.Circuit.AlertButtonInteractive}"
                      Background="{Binding alert_bg}"
                      BorderBrush="{Binding alert_border}"
                      Margin="6,0,0,0"
                      Visibility="{Binding alert_visibility}"
                      ToolTip="{Binding alert_summary}"
                      VerticalAlignment="Top"
                      Click="alert_tag_clicked"
                      MouseEnter="alert_button_mouse_enter"
                      MouseLeave="alert_button_mouse_leave">
                <TextBlock Text="!" FontWeight="Bold" Foreground="{Binding alert_text_color}"/>
              </Button>
            </Grid>

            <Grid Grid.Row="1" Margin="22,4,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <StackPanel Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                  <Border Style="{DynamicResource CED.Badge.Base}" Background="{Binding type_tag_bg}" BorderBrush="{Binding type_tag_fg}" Padding="4,0">
                    <TextBlock Text="{Binding type_tag_text}" Foreground="{Binding type_tag_fg}" Style="{DynamicResource CED.Badge.Text}"/>
                  </Border>
                </StackPanel>
                <TextBlock Text="{Binding wire_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
              </StackPanel>

              <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Text="{Binding load_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
                <TextBlock Text="{Binding device_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </DataTemplate>
    </ResourceDictionary>
  </Page.Resources>

  <Grid Name="DockFrameHost" Margin="4">
    <Border Background="{DynamicResource CED.Brush.WindowBackground}"
            BorderBrush="{DynamicResource CED.Brush.Border}"
            BorderThickness="1"
            CornerRadius="{DynamicResource CED.CornerRadius.Panel}"
            Padding="{DynamicResource CED.Thickness.PanelMargin}">
      <Grid PreviewMouseDown="panel_preview_mouse_down" Grid.IsSharedSizeScope="True">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Circuit Browser" Style="{DynamicResource CED.Text.Title}" Margin="0,0,0,6"/>
    <TextBlock Grid.Row="1" Name="DocumentNameText" Text="Document: -" Style="{DynamicResource CED.Text.Secondary}" Margin="0,0,0,6"/>

    <Grid Grid.Row="2" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Grid Grid.Column="0" Height="24" Margin="0,0,6,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="3" Style="{DynamicResource CED.SearchBox.Chrome}"/>
        <Path Grid.Column="0" Data="{DynamicResource CED.Icon.Search}" Fill="{DynamicResource CED.Brush.IconMuted}" Width="14" Height="14" Margin="8,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
        <TextBox Name="SearchBox" Grid.Column="1" Style="{DynamicResource CED.SearchBox.Input}" TextChanged="search_changed" GotFocus="search_got_focus" LostFocus="search_lost_focus"/>
        <TextBlock Name="SearchPlaceholderText" Grid.Column="1" Text="Search" Style="{DynamicResource CED.SearchBox.Placeholder}" Margin="2,0,0,0"/>
        <Button Name="ClearSearchButton" Grid.Column="2" Style="{DynamicResource CED.SearchBox.ClearButton}" Click="clear_search_clicked" ToolTip="Clear search" Visibility="Collapsed">
          <Path Data="{DynamicResource CED.Icon.Close}" Fill="{DynamicResource CED.Brush.IconMuted}" Width="10" Height="10" Stretch="Uniform"/>
        </Button>
      </Grid>

      <Button Name="FilterButton" Grid.Column="1" Style="{DynamicResource CED.Button.Icon}" Height="24" Margin="0,0,6,0" Click="filter_button_clicked" ToolTip="Filter" Padding="0">
        <Grid Width="16" Height="16">
          <Path Data="{DynamicResource CED.Icon.Filter}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
          <TextBlock Name="FilterActiveMark" Text="*" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-2,0" Visibility="Collapsed"/>
        </Grid>
      </Button>

      <Button Name="ActionsButton" Grid.Column="2" Style="{DynamicResource CED.Button.Base}" Width="74" Height="24" Margin="0,0,6,0" Click="actions_button_clicked">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
          <TextBlock Text="Actions" VerticalAlignment="Center"/>
          <Path Data="{DynamicResource CED.Icon.ChevronDown}"
                Width="8"
                Height="6"
                Margin="6,1,0,0"
                Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                Stretch="Uniform"
                VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Name="RefreshButton" Grid.Column="3" Style="{DynamicResource CED.Button.Icon}" Height="24" Margin="0,0,6,0" Click="refresh_clicked" ToolTip="Refresh circuits list" Padding="0">
        <Path Data="{DynamicResource CED.Icon.Refresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="14" Height="14" Stretch="Uniform"/>
      </Button>

      <Button Name="ToggleViewButton" Grid.Column="4" Style="{DynamicResource CED.Button.Icon}" Height="24" Margin="0,0,6,0" Click="toggle_view_clicked" ToolTip="Switch display mode" Padding="0">
        <Grid Width="14" Height="14">
          <Path Name="ToggleListIcon" Data="{DynamicResource CED.Icon.List}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
          <Path Name="ToggleCardIcon" Data="{DynamicResource CED.Icon.Card}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Visibility="Collapsed"/>
        </Grid>
      </Button>

      <Button Name="BrowserOptionsButton" Grid.Column="5" Style="{DynamicResource CED.Button.Icon}" Height="24" Click="browser_options_clicked" ToolTip="Browser options" Padding="0" FontSize="16" FontWeight="Bold" Content="..."/>
    </Grid>

    <Border Grid.Row="3" BorderBrush="{DynamicResource CED.Brush.ListBorder}" BorderThickness="1" Background="{DynamicResource CED.Brush.ListBackground}">
      <ListView Name="CircuitList"
                Style="{DynamicResource CED.ListView.Virtualized}"
                SelectionMode="Extended"
                ItemTemplate="{StaticResource CompactTemplate}"
                HorizontalContentAlignment="Stretch"
                SelectionChanged="selection_changed"
                PreviewMouseDown="list_preview_mouse_down"
                PreviewMouseRightButtonUp="list_preview_mouse_right_button_up"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"/>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{DynamicResource CED.Thickness.RowGap}">
      <Button Name="CheckAllButton" Style="{DynamicResource CED.Button.Base}" Content="Check All" Width="76" Height="22" Click="check_all_clicked"/>
      <Button Name="UncheckAllButton" Style="{DynamicResource CED.Button.Base}" Content="Uncheck All" Width="82" Height="22" Margin="6,0,0,0" Click="uncheck_all_clicked"/>
    </StackPanel>

    <Border Grid.Row="5"
            Grid.RowSpan="2"
            Margin="{DynamicResource CED.Thickness.RowGap}"
            HorizontalAlignment="Left"
            Padding="8,5,10,5"
            BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
            BorderThickness="1"
            CornerRadius="4"
            Background="{DynamicResource CED.Brush.InfoPanelBackground}">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="ActionLabelCol"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Select in Model:" Style="{DynamicResource CED.Text.CaptionStrong}" FontSize="12" VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
            <Button Name="SelectEquipmentButton" Style="{DynamicResource CED.Button.Primary}" Content="Panel" Width="52" Height="22" Margin="0,0,3,0" Click="select_equipment_clicked" ToolTip="Select supplying equipment for checked/selected circuits."/>
            <Button Name="SelectCircuitsButton" Style="{DynamicResource CED.Button.AccentRed}" Content="Circuit" Width="56" Height="22" Margin="0,0,3,0" Click="select_circuits_clicked" ToolTip="Select the circuit elements for checked/selected rows."/>
            <Button Name="SelectDownstreamButton" Style="{DynamicResource CED.Button.Apply}" Content="Device" Width="54" Height="22" Margin="0,0,6,0" Click="select_downstream_clicked" ToolTip="Select downstream devices on checked/selected circuits."/>
            <Button Name="ClearSelectionButton" Style="{DynamicResource CED.Button.IconSmall}" Height="22" Click="clear_revit_selection_clicked" ToolTip="Clear Revit model selection" Padding="0">
              <Path Data="{DynamicResource CED.Icon.Close}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="11" Height="11" Stretch="Uniform"/>
            </Button>
          </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,6,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" SharedSizeGroup="ActionLabelCol"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Calculate:" Style="{DynamicResource CED.Text.CaptionStrong}" FontSize="12" VerticalAlignment="Center"/>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="6,0,0,0">
            <Button Name="CalcAllButton" Style="{DynamicResource CED.Button.Base}" Content="All" Width="40" Height="22" Margin="0,0,3,0" Click="calculate_all_clicked"/>
            <Button Name="CalcSelectedButton" Style="{DynamicResource CED.Button.Base}" Content="Selected" Height="22" Margin="0,0,6,0" Click="calculate_selected_clicked"/>
            <Button Name="CalcSettingsButton" Style="{DynamicResource CED.Button.IconSmall}" Height="22" Click="calculate_settings_clicked" ToolTip="Calculate settings" Padding="0">
              <Path Data="{DynamicResource CED.Icon.Cog}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform"/>
            </Button>
          </StackPanel>
        </Grid>
      </Grid>
    </Border>

    <TextBlock Grid.Row="7" Name="StatusText" Margin="0,8,0,0" Style="{DynamicResource CED.Text.Secondary}" Text="Ready"/>
      </Grid>
    </Border>
  </Grid>
</Page>


