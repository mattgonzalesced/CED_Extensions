<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Calculate Circuits Settings"
        Height="720"
        Width="800"
        MinHeight="560"
        MinWidth="760"
        Background="{DynamicResource CED.Brush.WindowBackground}"
        Foreground="{DynamicResource CED.Brush.PrimaryText}"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SizeToContent="Manual">
    <Window.Resources>
        <Style x:Key="SettingsSectionCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Width" Value="156"/>
            <Setter Property="Margin" Value="0,0,6,8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="SettingsComboToggle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsComboItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemHoverBackground}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
                                <Setter TargetName="ItemRoot" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
                                <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SettingsPercentTextBox" TargetType="TextBox">
            <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
            <Setter Property="Width" Value="58"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <ControlTemplate x:Key="SettingsComboTemplate" TargetType="ComboBox">
            <Grid SnapsToDevicePixels="True">
                <Border x:Name="ComboBorder"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="26"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0"
                                          Margin="8,0,4,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                        <Path Grid.Column="1"
                              Data="{DynamicResource CED.Icon.ChevronDown}"
                              Width="8"
                              Height="6"
                              Stretch="Uniform"
                              Fill="{DynamicResource CED.Brush.IconMuted}"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                        <ToggleButton Grid.ColumnSpan="2"
                                      Style="{StaticResource SettingsComboToggle}"
                                      IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      ClickMode="Press"/>
                    </Grid>
                </Border>
                <Popup Name="PART_Popup"
                       AllowsTransparency="True"
                       Focusable="False"
                       IsOpen="{TemplateBinding IsDropDownOpen}"
                       Placement="Bottom"
                       PopupAnimation="Slide">
                    <Border x:Name="DropDownBorder"
                            Margin="0,2,0,0"
                            Background="{DynamicResource CED.Brush.ListBackground}"
                            BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                        <ScrollViewer MaxHeight="300"
                                      CanContentScroll="True"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
                </Trigger>
                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
                </Trigger>
                <Trigger Property="IsDropDownOpen" Value="True">
                    <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
                </Trigger>
                <Trigger Property="HasItems" Value="False">
                    <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        <Style x:Key="SettingsCombo" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
            <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource SettingsComboItem}"/>
            <Setter Property="Template" Value="{StaticResource SettingsComboTemplate}"/>
            <Setter Property="Width" Value="200"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style x:Key="SettingsDefaultText" TargetType="TextBlock">
            <Setter Property="FontStyle" Value="Italic"/>
            <Setter Property="Foreground" Value="{DynamicResource CED.Brush.SecondaryText}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock Text="Calculate Circuits Settings" Style="{DynamicResource CED.Text.Title}"/>
                <TextBlock Text="Configure conduit, wiring, voltage drop, and write-back behavior."
                           Style="{DynamicResource CED.Text.Secondary}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                <Button x:Name="verify_parameters_btn"
                        Content="Verify Parameters"
                        Style="{DynamicResource CED.Button.Apply}"
                        MinWidth="140"
                        Padding="14,6"
                        ToolTip="Verify and update required electrical shared parameters for this project."/>
                <TextBlock x:Name="verify_parameters_status"
                           Margin="0,6,0,0"
                           HorizontalAlignment="Right"
                           Style="{DynamicResource CED.Text.Secondary}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,10"
                Background="{DynamicResource CED.Brush.ListBackground}"
                BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                BorderThickness="1"
                CornerRadius="{DynamicResource CED.CornerRadius.Panel}"
                Padding="10">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="False">
                <StackPanel Margin="0,0,10,0" Grid.IsSharedSizeScope="True">
                    <Border Style="{StaticResource SettingsSectionCard}">
                        <StackPanel>
                            <TextBlock Text="Conduits" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Minimum Conduit Size" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="min_conduit_size_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="1/2&quot;" Tag="1/2&quot;"/>
                                    <ComboBoxItem Content="3/4&quot;" Tag="3/4&quot;"/>
                                </ComboBox>
                                <TextBlock x:Name="min_conduit_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max Conduit Fill" Style="{StaticResource SettingsLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                                    <TextBox x:Name="max_conduit_fill_tb" Style="{StaticResource SettingsPercentTextBox}" Tag="Max Conduit Fill"/>
                                    <TextBlock x:Name="max_conduit_fill_warn" Text="!" Foreground="{DynamicResource CED.Brush.SecondaryRed}" VerticalAlignment="Center" Visibility="Collapsed" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="max_conduit_fill_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCard}">
                        <StackPanel>
                            <TextBlock Text="Wires" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Neutral Behavior" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="neutral_behavior_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Match hot conductors" Tag="match_hot"/>
                                    <ComboBoxItem Content="Manual neutral" Tag="manual"/>
                                </ComboBox>
                                <TextBlock x:Name="neutral_behavior_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Isolated Ground Behavior" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="isolated_ground_behavior_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Match ground conductors" Tag="match_ground"/>
                                    <ComboBoxItem Content="Manual isolated ground" Tag="manual"/>
                                </ComboBox>
                                <TextBlock x:Name="isolated_ground_behavior_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCard}">
                        <StackPanel>
                            <TextBlock Text="Wire Strings" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wire Material Display" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="wire_material_display_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Aluminum only" Tag="al_only"/>
                                    <ComboBoxItem Content="Copper and Aluminum" Tag="all"/>
                                </ComboBox>
                                <TextBlock x:Name="wire_material_display_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Wire String Separator" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="wire_string_separator_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Use &quot;+&quot; separators" Tag="plus"/>
                                    <ComboBoxItem Content="Use &quot;,&quot; separators" Tag="comma"/>
                                </ComboBox>
                                <TextBlock x:Name="wire_string_separator_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCard}">
                        <StackPanel>
                            <TextBlock Text="Voltage Drop" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max Branch Voltage Drop" Style="{StaticResource SettingsLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,8">
                                    <TextBox x:Name="max_branch_vd_tb" Style="{StaticResource SettingsPercentTextBox}" Tag="Max Branch Voltage Drop"/>
                                    <TextBlock x:Name="max_branch_vd_warn" Text="!" Foreground="{DynamicResource CED.Brush.SecondaryRed}" VerticalAlignment="Center" Visibility="Collapsed" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="max_branch_vd_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Max Feeder Voltage Drop" Style="{StaticResource SettingsLabel}"/>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,8">
                                    <TextBox x:Name="max_feeder_vd_tb" Style="{StaticResource SettingsPercentTextBox}" Tag="Max Feeder Voltage Drop"/>
                                    <TextBlock x:Name="max_feeder_vd_warn" Text="!" Foreground="{DynamicResource CED.Brush.SecondaryRed}" VerticalAlignment="Center" Visibility="Collapsed" Margin="8,0,0,0" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock x:Name="max_feeder_vd_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Feeder VD Method" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="feeder_vd_method_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Demand Load" Tag="demand"/>
                                    <ComboBoxItem Content="Connected Load" Tag="connected"/>
                                    <ComboBoxItem Content="80% of Breaker" Tag="80_percent"/>
                                    <ComboBoxItem Content="100% of Breaker" Tag="100_percent"/>
                                </ComboBox>
                                <TextBlock x:Name="feeder_vd_method_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" Margin="0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCard}">
                        <StackPanel>
                            <TextBlock Text="Data Writeback" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Write results to:" Style="{StaticResource SettingsLabel}" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                    <CheckBox x:Name="write_equipment_cb" Content="Electrical Equipment" Style="{DynamicResource CED.Input.CheckBox}" IsChecked="True" Margin="0,0,0,4"/>
                                    <CheckBox x:Name="write_fixtures_cb" Content="Fixtures and Devices" Style="{DynamicResource CED.Input.CheckBox}" IsChecked="False"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                        <TextBlock x:Name="clear_writeback_alert" Text="!" Foreground="{DynamicResource CED.Brush.SecondaryRed}" Visibility="Collapsed" VerticalAlignment="Center" Margin="0,0,6,0" FontWeight="Bold"/>
                                        <Button x:Name="clear_writeback_btn" Content="Clear persistent write-back data" Style="{DynamicResource CED.Button.Base}" Padding="10,6"/>
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock x:Name="write_results_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" VerticalAlignment="Top"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SettingsSectionCard}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Theme and Accent" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,8"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Theme" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="theme_mode_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Light" Tag="light"/>
                                    <ComboBoxItem Content="Dark" Tag="dark"/>
                                    <ComboBoxItem Content="Dark Alt" Tag="dark_alt"/>
                                </ComboBox>
                                <TextBlock x:Name="theme_mode_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsLabelCol"/>
                                    <ColumnDefinition Width="Auto" SharedSizeGroup="SettingsValueCol"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="Accent" Style="{StaticResource SettingsLabel}"/>
                                <ComboBox x:Name="accent_mode_cb" Grid.Column="1" Style="{StaticResource SettingsCombo}">
                                    <ComboBoxItem Content="Blue" Tag="blue"/>
                                    <ComboBoxItem Content="Red" Tag="red"/>
                                    <ComboBoxItem Content="Green" Tag="green"/>
                                    <ComboBoxItem Content="Neutral" Tag="neutral"/>
                                </ComboBox>
                                <TextBlock x:Name="accent_mode_default" Grid.Column="2" Style="{StaticResource SettingsDefaultText}" Margin="0"/>
                            </Grid>

                            <TextBlock Text="Theme and accent update this window immediately. Changes apply to all tools after Save Settings."
                                       Style="{DynamicResource CED.Text.Secondary}"
                                       TextWrapping="Wrap"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,10"
                MinHeight="110"
                Padding="10"
                BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
                BorderThickness="1"
                CornerRadius="{DynamicResource CED.CornerRadius.Control}"
                Background="{DynamicResource CED.Brush.InfoPanelBackground}">
            <TextBlock x:Name="help_preview"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource CED.Brush.PrimaryText}"/>
        </Border>

        <Grid Grid.Row="3" VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="help_btn"
                    Grid.Column="0"
                    Content="Help"
                    Style="{DynamicResource CED.Button.Base}"
                    Padding="14,6"
                    MinWidth="130"
                    HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="reset_btn"
                        Content="Reset to Defaults"
                        Style="{DynamicResource CED.Button.Base}"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        MinWidth="130"/>
                <Button x:Name="cancel_btn"
                        Content="Cancel"
                        Style="{DynamicResource CED.Button.Base}"
                        Margin="0,0,8,0"
                        Padding="14,6"
                        MinWidth="90"/>
                <Button x:Name="save_btn"
                        Content="Save Settings"
                        Style="{DynamicResource CED.Button.Apply}"
                        Padding="16,6"
                        MinWidth="120"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
