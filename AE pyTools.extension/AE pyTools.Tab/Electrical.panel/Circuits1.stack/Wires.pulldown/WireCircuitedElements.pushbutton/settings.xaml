<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Background="#F5F7FA"
        Title="Wire Settings">
    <Border Padding="18">
        <Grid MinWidth="520">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="190"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Row="0"
                       Grid.ColumnSpan="3"
                       Text="Wire Circuited Elements Settings"
                       FontSize="18"
                       FontWeight="SemiBold"/>

            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Default Wire Type"/>
            <ComboBox x:Name="WireTypeCombo" Grid.Row="2" Grid.Column="2" MinWidth="250"/>

            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Branch Wiring Type"/>
            <ComboBox x:Name="BranchWiringCombo" Grid.Row="4" Grid.Column="2" MinWidth="150"/>

            <TextBlock Grid.Row="6" Grid.Column="0" VerticalAlignment="Center" Text="Home Run Wiring Type"/>
            <ComboBox x:Name="HomeRunWiringCombo" Grid.Row="6" Grid.Column="2" MinWidth="150"/>

            <TextBlock Grid.Row="8" Grid.Column="0" VerticalAlignment="Center" Text="Home Run Length"/>
            <TextBox x:Name="HomeRunLengthText" Grid.Row="8" Grid.Column="2" MinWidth="120" HorizontalAlignment="Left"/>

            <StackPanel Grid.Row="10" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Width="90"
                        Margin="0,0,8,0"
                        Click="on_cancel"/>
                <Button Content="Save"
                        Width="90"
                        Click="on_save"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
