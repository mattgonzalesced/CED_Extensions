<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource CED.Brush.WindowBackground}">
  <Page.Resources>
    <ResourceDictionary>
      <Geometry x:Key="IconSearch">M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z</Geometry>
      <Geometry x:Key="IconFilterMenu">M12 18.88A1 1 0 0 1 11.71 19.71A1 1 0 0 1 10.3 19.71L6.3 15.71A1 1 0 0 1 6 14.87V9.75L1.21 3.62A1 1 0 0 1 1.38 2.22A1 1 0 0 1 2 2H16A1 1 0 0 1 16.62 2.22A1 1 0 0 1 16.79 3.62L12 9.75V18.88M4 4L8 9.06V14.58L10 16.58V9.05L14 4M13 16L18 21L23 16Z</Geometry>
      <Geometry x:Key="IconClose">M19,6.41L17.59,5L12,10.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L12,13.41L17.59,19L19,17.59L13.41,12L19,6.41Z</Geometry>
      <Geometry x:Key="IconCog">M12,8A4,4 0 0,1 16,12A4,4 0 0,1 12,16A4,4 0 0,1 8,12A4,4 0 0,1 12,8M12,10A2,2 0 0,0 10,12A2,2 0 0,0 12,14A2,2 0 0,0 14,12A2,2 0 0,0 12,10M10,22C9.75,22 9.54,21.82 9.5,21.58L9.13,18.93C8.5,18.68 7.96,18.34 7.44,17.94L4.95,18.95C4.73,19.03 4.46,18.95 4.34,18.73L2.34,15.27C2.21,15.05 2.27,14.78 2.46,14.63L4.57,12.97L4.5,12L4.57,11L2.46,9.37C2.27,9.22 2.21,8.95 2.34,8.73L4.34,5.27C4.46,5.05 4.73,4.96 4.95,5.05L7.44,6.05C7.96,5.66 8.5,5.32 9.13,5.07L9.5,2.42C9.54,2.18 9.75,2 10,2H14C14.25,2 14.46,2.18 14.5,2.42L14.87,5.07C15.5,5.32 16.04,5.66 16.56,6.05L19.05,5.05C19.27,4.96 19.54,5.05 19.66,5.27L21.66,8.73C21.79,8.95 21.73,9.22 21.54,9.37L19.43,11L19.5,12L19.43,13L21.54,14.63C21.73,14.78 21.79,15.05 21.66,15.27L19.66,18.73C19.54,18.95 19.27,19.04 19.05,18.95L16.56,17.95C16.04,18.34 15.5,18.68 14.87,18.93L14.5,21.58C14.46,21.82 14.25,22 14,22H10</Geometry>
      <Geometry x:Key="IconRefresh">M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z</Geometry>
      <Geometry x:Key="IconAccount">M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z</Geometry>
      <Geometry x:Key="IconList">M3,4H7V8H3V4M9,5V7H21V5H9M3,10H7V14H3V10M9,11V13H21V11H9M3,16H7V20H3V16M9,17V19H21V17H9</Geometry>
      <Geometry x:Key="IconCard">M20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20M4,6V18H20V6H4M6,9H18V11H6V9M6,13H16V15H6V13Z</Geometry>
      
    <DataTemplate x:Key="CompactTemplate">
      <Border BorderBrush="{DynamicResource CED.Brush.CardBorder}" BorderThickness="1" CornerRadius="3" Margin="0,0,0,1" Padding="4" Background="{DynamicResource CED.Brush.SearchBackground}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <CheckBox Grid.Column="0"
                    IsChecked="{Binding is_checked, Mode=TwoWay}"
                    VerticalAlignment="Center"
                    Checked="item_checked"
                    Unchecked="item_unchecked"
                    Margin="0,0,6,0"/>

          <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
            <Border Background="{Binding type_tag_bg}" BorderBrush="{Binding type_tag_fg}" BorderThickness="1" CornerRadius="2" Padding="4,0" Margin="0,0,6,0" Visibility="{Binding type_tag_visibility}">
              <TextBlock Text="{Binding type_tag_text}" Foreground="{Binding type_tag_fg}" FontWeight="Bold" FontSize="10"/>
            </Border>
            <TextBlock Text="{Binding panel}" FontWeight="Bold"/>
            <TextBlock Text=" / "/>
            <TextBlock Text="{Binding circuit_number}" FontWeight="Bold"/>
            <TextBlock Text="   "/>
            <TextBlock Text="{Binding load_name}"/>
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8,0,0,0">
            <TextBlock Text="{Binding rating_poles}" FontWeight="Bold" VerticalAlignment="Center"/>
            <Border Background="#E8F1FF" BorderBrush="#2B62A8" BorderThickness="1" CornerRadius="2" Padding="3,0" Margin="6,0,0,0" Visibility="{Binding neutral_badge_visibility}">
              <TextBlock Text="N" Foreground="#1E4B86" FontWeight="Bold" FontSize="10"/>
            </Border>
            <Border Background="#FFF1E8" BorderBrush="#9A5D2E" BorderThickness="1" CornerRadius="2" Padding="3,0" Margin="4,0,0,0" Visibility="{Binding ig_badge_visibility}">
              <TextBlock Text="IG" Foreground="#7A451D" FontWeight="Bold" FontSize="10"/>
            </Border>
            <Border BorderBrush="{DynamicResource CED.Brush.SelectionBadge}" BorderThickness="1" CornerRadius="2" Padding="2,0" Margin="4,0,0,0" Background="Transparent" Visibility="{Binding override_badge_visibility}" ToolTip="User override">
              <Path Data="{StaticResource IconAccount}" Fill="{DynamicResource CED.Brush.SelectionBadge}" Width="10" Height="10" Stretch="Uniform"/>
            </Border>
          </StackPanel>

          <Button Grid.Column="3"
                  Style="{x:Null}"
                  Background="{Binding alert_bg}"
                  BorderBrush="{Binding alert_border}"
                  BorderThickness="1"
                  Padding="4,0"
                  Margin="6,0,0,0"
                  Visibility="{Binding alert_visibility}"
                  ToolTip="{Binding alert_summary}"
                  Click="alert_tag_clicked"
                  MinWidth="20"
                  MinHeight="0"
                  Height="18">
            <TextBlock Text="!" FontWeight="Bold" Foreground="{Binding alert_text_color}"/>
          </Button>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="CardTemplate">
      <Border BorderBrush="{DynamicResource CED.Brush.CardBorder}" BorderThickness="1" CornerRadius="4" Margin="0,0,0,1" Padding="6" Background="{DynamicResource CED.Brush.SearchBackground}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding is_checked, Mode=TwoWay}"
                      VerticalAlignment="Top"
                      Checked="item_checked"
                      Unchecked="item_unchecked"
                      Margin="0,1,6,0"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
              <TextBlock Text="{Binding panel}" FontWeight="Bold"/>
              <TextBlock Text=" / "/>
              <TextBlock Text="{Binding circuit_number}" FontWeight="Bold"/>
              <TextBlock Text="   "/>
              <TextBlock Text="{Binding load_name}"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8,0,0,0">
              <TextBlock Text="{Binding rating_poles}" FontWeight="Bold" VerticalAlignment="Top"/>
              <Border Background="#E8F1FF" BorderBrush="#2B62A8" BorderThickness="1" CornerRadius="2" Padding="3,0" Margin="6,0,0,0" Visibility="{Binding neutral_badge_visibility}">
                <TextBlock Text="N" Foreground="#1E4B86" FontWeight="Bold" FontSize="10"/>
              </Border>
              <Border Background="#FFF1E8" BorderBrush="#9A5D2E" BorderThickness="1" CornerRadius="2" Padding="3,0" Margin="4,0,0,0" Visibility="{Binding ig_badge_visibility}">
                <TextBlock Text="IG" Foreground="#7A451D" FontWeight="Bold" FontSize="10"/>
              </Border>
              <Border BorderBrush="{DynamicResource CED.Brush.SelectionBadge}" BorderThickness="1" CornerRadius="2" Padding="2,0" Margin="4,0,0,0" Background="Transparent" Visibility="{Binding override_badge_visibility}" ToolTip="User override">
                <Path Data="{StaticResource IconAccount}" Fill="{DynamicResource CED.Brush.SelectionBadge}" Width="10" Height="10" Stretch="Uniform"/>
              </Border>
            </StackPanel>

            <Button Grid.Column="3"
                    Style="{x:Null}"
                    Background="{Binding alert_bg}"
                    BorderBrush="{Binding alert_border}"
                    BorderThickness="1"
                    Padding="4,0"
                    Margin="6,0,0,0"
                    Visibility="{Binding alert_visibility}"
                    ToolTip="{Binding alert_summary}"
                    VerticalAlignment="Top"
                    Click="alert_tag_clicked"
                    MinWidth="20"
                    MinHeight="0"
                    Height="18">
              <TextBlock Text="!" FontWeight="Bold" Foreground="{Binding alert_text_color}"/>
            </Button>
          </Grid>

          <Grid Grid.Row="1" Margin="22,4,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
              <StackPanel Orientation="Horizontal">
                <Border Background="{Binding type_tag_bg}" BorderBrush="{Binding type_tag_fg}" BorderThickness="1" CornerRadius="2" Padding="4,0">
                  <TextBlock Text="{Binding type_tag_text}" Foreground="{Binding type_tag_fg}" FontWeight="Bold" FontSize="10"/>
                </Border>
              </StackPanel>
              <TextBlock Text="{Binding wire_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
              <TextBlock Text="{Binding load_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
              <TextBlock Text="{Binding device_line}" Foreground="{DynamicResource CED.Brush.SecondaryText}"/>
            </StackPanel>
          </Grid>
        </Grid>
      </Border>
    </DataTemplate>
    </ResourceDictionary>
  </Page.Resources>

  <Grid Margin="8" PreviewMouseDown="panel_preview_mouse_down">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Circuit Browser" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource CED.Brush.PrimaryText}" Margin="0,0,0,6"/>
    <TextBlock Grid.Row="1" Name="DocumentNameText" Text="Document: -" Foreground="{DynamicResource CED.Brush.SecondaryText}" Margin="0,0,0,6"/>

    <Grid Grid.Row="2" Margin="0,0,0,6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Grid Grid.Column="0" Height="24" Margin="0,0,6,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Border Grid.ColumnSpan="3" BorderBrush="{DynamicResource CED.Brush.SearchBorder}" BorderThickness="1" Background="{DynamicResource CED.Brush.SearchBackground}" CornerRadius="4"/>
        <Path Grid.Column="0" Data="{StaticResource IconSearch}" Fill="{DynamicResource CED.Brush.IconMuted}" Width="14" Height="14" Margin="8,0,6,0" VerticalAlignment="Center" Stretch="Uniform"/>
        <TextBox Name="SearchBox" Grid.Column="1" Height="22" VerticalContentAlignment="Center" BorderThickness="0" Background="Transparent" TextChanged="search_changed" GotFocus="search_got_focus" LostFocus="search_lost_focus"/>
        <TextBlock Name="SearchPlaceholderText" Grid.Column="1" Text="Search" Foreground="{DynamicResource CED.Brush.PlaceholderText}" VerticalAlignment="Center" IsHitTestVisible="False" Margin="2,0,0,0"/>
        <Button Name="ClearSearchButton" Grid.Column="2" Width="20" Height="20" Margin="2,0,2,0" Click="clear_search_clicked" ToolTip="Clear search" Background="Transparent" BorderThickness="0" Visibility="Collapsed" Style="{x:Null}">
          <Path Data="{StaticResource IconClose}" Fill="{DynamicResource CED.Brush.IconMuted}" Width="10" Height="10" Stretch="Uniform"/>
        </Button>
      </Grid>
      <Button Name="FilterButton" Grid.Column="1" Width="28" Height="24" Margin="0,0,6,0" Click="filter_button_clicked" Background="#FFFFFF" Foreground="#1F2E3D" ToolTip="Filter" Padding="0">
        <Grid Width="16" Height="16">
          <Path Data="{StaticResource IconFilterMenu}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
          <TextBlock Name="FilterActiveMark" Text="*" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-5,-2,0" Visibility="Collapsed"/>
        </Grid>
      </Button>
      <Button Name="ActionsButton" Grid.Column="2" Content="Actions" Width="64" Height="24" Margin="0,0,6,0" Click="actions_button_clicked"/>
      <Button Name="RefreshButton" Grid.Column="3" Width="28" Height="24" MinHeight="0" MinWidth="0" Margin="0,0,6,0" Click="refresh_clicked" ToolTip="Refresh circuits" Padding="0">
        <Path Data="{StaticResource IconRefresh}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="14" Height="14" Stretch="Uniform"/>
      </Button>
      <Button Name="ToggleViewButton" Grid.Column="4" Width="28" Height="24" Margin="0,0,6,0" Click="toggle_view_clicked" ToolTip="Switch display mode" Padding="0">
        <Grid Width="14" Height="14">
          <Path Name="ToggleListIcon" Data="{StaticResource IconList}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform"/>
          <Path Name="ToggleCardIcon" Data="{StaticResource IconCard}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Stretch="Uniform" Visibility="Collapsed"/>
        </Grid>
      </Button>
      <Button Name="BrowserOptionsButton" Grid.Column="5" Width="28" Height="24" Click="browser_options_clicked" ToolTip="Browser options" Padding="0" FontSize="16" FontWeight="Bold" Content="..."/>
    </Grid>

    <Border Grid.Row="3" BorderBrush="{DynamicResource CED.Brush.ListBorder}" BorderThickness="1" Background="{DynamicResource CED.Brush.ListBackground}">
      <ListView Name="CircuitList"
                SelectionMode="Extended"
                ItemTemplate="{StaticResource CompactTemplate}"
                HorizontalContentAlignment="Stretch"
                SelectionChanged="selection_changed"
                PreviewMouseDown="list_preview_mouse_down"
                PreviewMouseRightButtonUp="list_preview_mouse_right_button_up"/>
    </Border>

    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,6,0,0">
      <Button Name="CheckAllButton" Content="Check All" Width="76" Height="22" Click="check_all_clicked"/>
      <Button Name="UncheckAllButton" Content="Uncheck All" Width="82" Height="22" Margin="6,0,0,0" Click="uncheck_all_clicked"/>
    </StackPanel>

    <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,6,0,0">
      <TextBlock Text="Select in Model:" FontWeight="Bold" Foreground="{DynamicResource CED.Brush.PrimaryText}" VerticalAlignment="Center"/>
      <Button Name="SelectEquipmentButton" Content="Panel" Width="52" Height="22" Margin="6,0,3,0" Click="select_equipment_clicked" ToolTip="Select supplying equipment for checked/selected circuits." Background="#0459A4" Foreground="#FFFFFF" BorderBrush="#0459A4"/>
      <Button Name="SelectCircuitsButton" Content="Circuit" Width="56" Height="22" Margin="0,0,3,0" Click="select_circuits_clicked" ToolTip="Select the circuit elements for checked/selected rows." Background="#BE202F" Foreground="#FFFFFF" BorderBrush="#BE202F"/>
      <Button Name="SelectDownstreamButton" Content="Device" Width="54" Height="22" Margin="0,0,6,0" Click="select_downstream_clicked" ToolTip="Select downstream devices on checked/selected circuits." Background="#43A047" Foreground="#FFFFFF" BorderBrush="#43A047"/>
      <Button Name="ClearSelectionButton" Width="24" Height="22" MinHeight="0" MinWidth="0" Click="clear_revit_selection_clicked" ToolTip="Clear Revit model selection" Padding="0">
        <Path Data="{StaticResource IconClose}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="11" Height="11" Stretch="Uniform"/>
      </Button>
    </StackPanel>

    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,6,0,0">
      <TextBlock Text="Calculate:" FontWeight="Bold" Foreground="{DynamicResource CED.Brush.PrimaryText}" VerticalAlignment="Center"/>
      <Button Name="CalcSelectedButton" Content="Selected" Height="22" Margin="6,0,3,0" Click="calculate_selected_clicked"/>
      <Button Name="CalcAllButton" Content="All" Width="40" Height="22" Click="calculate_all_clicked"/>
      <Button Name="CalcSettingsButton" Width="24" Height="22" MinHeight="0" MinWidth="0" Margin="6,0,0,0" Click="calculate_settings_clicked" ToolTip="Calculate settings" Padding="0">
        <Path Data="{StaticResource IconCog}" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" Width="12" Height="12" Stretch="Uniform"/>
      </Button>
    </StackPanel>

    <TextBlock Grid.Row="7" Name="StatusText" Margin="0,8,0,0" Foreground="{DynamicResource CED.Brush.SecondaryText}" Text="Ready"/>
  </Grid>
</Page>



