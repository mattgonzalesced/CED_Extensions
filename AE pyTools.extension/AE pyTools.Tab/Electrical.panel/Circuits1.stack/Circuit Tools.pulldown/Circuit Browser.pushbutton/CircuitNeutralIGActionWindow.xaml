<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Circuit Action"
        Height="560"
        Width="1260"
        MinHeight="420"
        MinWidth="940"
        WindowStartupLocation="CenterOwner"
        Background="#F2F3F5"
        PreviewMouseDown="window_preview_mouse_down">
  <Window.Resources>
    <ResourceDictionary>
      
    </ResourceDictionary>
  </Window.Resources>
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Name="TitleText" Grid.Column="0" Text="Action" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
      <CheckBox Name="ShowUnsupportedToggle"
                Grid.Column="1"
                Content="Show Unsupported Circuits"
                VerticalAlignment="Center"
                Checked="show_unsupported_toggled"
                Unchecked="show_unsupported_toggled"/>
    </Grid>

    <Border Grid.Row="1" BorderBrush="#AAB4C0" BorderThickness="1" Background="#FFFFFF">
      <DataGrid Name="CircuitGrid"
                AutoGenerateColumns="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                CanUserAddRows="False"
                CanUserResizeRows="False"
                CanUserResizeColumns="False"
                HeadersVisibility="Column"
                RowHeaderWidth="0"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="#F9FBFD"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                SelectionChanged="grid_selection_changed"
                PreviewMouseDown="grid_preview_mouse_down">
        <DataGrid.Resources>
          <Style x:Key="HeaderWrapCenter" TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="ContentTemplate">
              <Setter.Value>
                <DataTemplate>
                  <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
                </DataTemplate>
              </Setter.Value>
            </Setter>
          </Style>
          <Style x:Key="CenterTextCell" TargetType="TextBlock">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
          </Style>
          <Style x:Key="RemarksTextCell" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="2,0,2,0"/>
          </Style>
          <Style x:Key="BaseCell" TargetType="DataGridCell">
            <Setter Property="BorderBrush" Value="#D7DEE8"/>
            <Setter Property="BorderThickness" Value="0,0,1,0"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
            </Style.Triggers>
          </Style>
          <Style x:Key="ReadonlyCell" TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}">
            <Setter Property="Background" Value="#F2F4F7"/>
            <Setter Property="Foreground" Value="#33414F"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
            </Style.Triggers>
          </Style>
          <Style x:Key="DividerThickReadonlyCell" TargetType="DataGridCell" BasedOn="{StaticResource ReadonlyCell}">
            <Setter Property="BorderBrush" Value="#8E9AA8"/>
            <Setter Property="BorderThickness" Value="0,0,2,0"/>
          </Style>
          <Style x:Key="NewQtyCell" TargetType="DataGridCell" BasedOn="{StaticResource ReadonlyCell}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding new_qty_changed}" Value="True">
                <Setter Property="Background" Value="#FFF8D6"/>
              </DataTrigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
            </Style.Triggers>
          </Style>
          <Style x:Key="NewSizeCell" TargetType="DataGridCell" BasedOn="{StaticResource ReadonlyCell}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding new_size_changed}" Value="True">
                <Setter Property="Background" Value="#FFF8D6"/>
              </DataTrigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
            </Style.Triggers>
          </Style>
          <Style x:Key="NewWireCell" TargetType="DataGridCell" BasedOn="{StaticResource DividerThickReadonlyCell}">
            <Style.Triggers>
              <DataTrigger Binding="{Binding new_wire_changed}" Value="True">
                <Setter Property="Background" Value="#FFF8D6"/>
              </DataTrigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
            </Style.Triggers>
          </Style>
        </DataGrid.Resources>
        <DataGrid.ColumnHeaderStyle>
          <StaticResource ResourceKey="HeaderWrapCenter"/>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
              <DataTrigger Binding="{Binding is_enabled}" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="34" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding is_checked, Mode=OneWay}" IsEnabled="{Binding is_enabled}" Click="item_checkbox_clicked"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Circuit" Width="176" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Margin="4,2,4,2">
                  <TextBlock Text="{Binding panel_ckt_text}" FontWeight="Bold" Foreground="#1F2A36"/>
                  <TextBlock Text="{Binding load_name}" Foreground="#3A4754" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Type" Width="76" Binding="{Binding branch_type}" IsReadOnly="True" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Qty" Width="60" Binding="{Binding current_qty}" IsReadOnly="True" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Size" Width="72" Binding="{Binding current_size}" IsReadOnly="True" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Wire" Width="154" Binding="{Binding current_wire}" IsReadOnly="True" CellStyle="{StaticResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="New&#10;Qty" Width="58" Binding="{Binding new_qty}" IsReadOnly="True" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource NewQtyCell}"/>
          <DataGridTextColumn Header="New&#10;Size" Width="72" Binding="{Binding new_size}" IsReadOnly="True" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource NewSizeCell}"/>
          <DataGridTemplateColumn Header="New&#10;Wire" Width="154" IsReadOnly="True" CellStyle="{StaticResource NewWireCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding new_wire}" FontStyle="{Binding new_wire_font_style}" TextTrimming="CharacterEllipsis"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Remarks" Width="*" Binding="{Binding remarks}" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}" ElementStyle="{StaticResource RemarksTextCell}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
          <StackPanel Orientation="Horizontal">
            <Button Content="Check All" Width="76" Height="24" Click="check_all_clicked"/>
            <Button Content="Uncheck All" Width="84" Height="24" Margin="6,0,0,0" Click="uncheck_all_clicked"/>
          </StackPanel>
          <TextBlock Name="CheckedStatusText" Margin="2,4,0,0" Foreground="#3A4754" Text="0 of 0 checked"/>
        </StackPanel>
        <Border Width="1" Height="22" Margin="14,0,14,0" Background="#C4CFDB" VerticalAlignment="Center"/>
        <Button Content="Add" Width="72" Height="24" VerticalAlignment="Center" Click="add_clicked"/>
        <Button Content="Remove" Width="72" Height="24" Margin="6,0,0,0" VerticalAlignment="Center" Click="remove_clicked"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock Name="ChangedStatusText" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#3A4754" Text="0 of 0 circuits to be modified."/>
        <Button Content="Cancel" Width="80" Height="24" Click="cancel_clicked"/>
        <Button Content="Apply" Width="80" Height="24" Margin="6,0,0,0" Click="apply_clicked" Background="#DFF2D8" BorderBrush="#4E8A4A"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>



