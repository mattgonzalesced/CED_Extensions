<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Auto Size Breaker"
        Height="560"
        Width="1300"
        MinHeight="420"
        MinWidth="980"
        WindowStartupLocation="CenterOwner"
        Background="#F2F3F5"
        PreviewMouseDown="window_preview_mouse_down">
  <Window.Resources>
    <ResourceDictionary>
      <Style x:Key="HeaderWrapCenter" TargetType="DataGridColumnHeader">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Height" Value="42"/>
        <Setter Property="ContentTemplate">
          <Setter.Value>
            <DataTemplate>
              <TextBlock Text="{Binding}" TextWrapping="Wrap" TextAlignment="Center" VerticalAlignment="Center"/>
            </DataTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="CenterTextCell" TargetType="TextBlock">
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
      </Style>
      <Style x:Key="CenterTextEdit" TargetType="TextBox">
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
      </Style>
      <Style x:Key="RemarksTextCell" TargetType="TextBlock">
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="2,0,2,0"/>
      </Style>
      <Style x:Key="BaseCell" TargetType="DataGridCell">
        <Setter Property="BorderBrush" Value="#D7DEE8"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
        <Style.Triggers>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#DCEBFA"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="ReadonlyCell" TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}">
        <Setter Property="Background" Value="#F2F4F7"/>
        <Setter Property="Foreground" Value="#33414F"/>
        <Style.Triggers>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#DCEBFA"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="DividerThickReadonlyCell" TargetType="DataGridCell" BasedOn="{StaticResource ReadonlyCell}">
        <Setter Property="BorderBrush" Value="#8E9AA8"/>
        <Setter Property="BorderThickness" Value="0,0,2,0"/>
      </Style>
      <Style x:Key="DividerThinCell" TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}"/>
      <Style x:Key="DividerThickCell" TargetType="DataGridCell" BasedOn="{StaticResource BaseCell}">
        <Setter Property="BorderBrush" Value="#8E9AA8"/>
        <Setter Property="BorderThickness" Value="0,0,2,0"/>
      </Style>
      <Style x:Key="NewValueCell" TargetType="DataGridCell" BasedOn="{StaticResource DividerThinCell}">
        <Style.Triggers>
          <DataTrigger Binding="{Binding is_enabled}" Value="False">
            <Setter Property="Background" Value="#F0F2F4"/>
            <Setter Property="Foreground" Value="#8994A0"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding new_rating_changed}" Value="True">
            <Setter Property="Background" Value="#FFF8D6"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding rating_warning_level}" Value="1">
            <Setter Property="Background" Value="#FDEACB"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding rating_warning_level}" Value="2">
            <Setter Property="Background" Value="#F9D6D6"/>
          </DataTrigger>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#DCEBFA"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
          </Trigger>
        </Style.Triggers>
      </Style>
      <Style x:Key="NewFrameCell" TargetType="DataGridCell" BasedOn="{StaticResource DividerThickCell}">
        <Style.Triggers>
          <DataTrigger Binding="{Binding is_enabled}" Value="False">
            <Setter Property="Background" Value="#F0F2F4"/>
            <Setter Property="Foreground" Value="#8994A0"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding new_frame_changed}" Value="True">
            <Setter Property="Background" Value="#FFF8D6"/>
          </DataTrigger>
          <DataTrigger Binding="{Binding new_frame_warning}" Value="True">
            <Setter Property="Background" Value="#FDEACB"/>
          </DataTrigger>
          <Trigger Property="IsSelected" Value="True">
            <Setter Property="Background" Value="#DCEBFA"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
          </Trigger>
        </Style.Triggers>
      </Style>
    </ResourceDictionary>
  </Window.Resources>
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <TextBlock Text="Auto Size Breaker / Frame" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
        <CheckBox Name="ShowChangedOnlyToggle"
                  Content="Show Changed Only"
                  Margin="14,0,0,0"
                  VerticalAlignment="Center"
                  Checked="row_filter_toggled"
                  Unchecked="row_filter_toggled"/>
      </StackPanel>
      <CheckBox Name="ShowUnsupportedToggle"
                Grid.Column="1"
                Content="Show Unsupported Circuits"
                VerticalAlignment="Center"
                Checked="show_unsupported_toggled"
                Unchecked="show_unsupported_toggled"/>
    </Grid>

    <Border Grid.Row="1" BorderBrush="#AAB4C0" BorderThickness="1" Background="#FFFFFF">
      <DataGrid Name="CircuitGrid"
                AutoGenerateColumns="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                CanUserAddRows="False"
                CanUserResizeRows="False"
                CanUserResizeColumns="False"
                HeadersVisibility="Column"
                RowHeaderWidth="0"
                GridLinesVisibility="Horizontal"
                AlternatingRowBackground="#F9FBFD"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                CellEditEnding="breaker_cell_edit_ending"
                SelectionChanged="grid_selection_changed"
                PreviewMouseDown="grid_preview_mouse_down">
        <DataGrid.ColumnHeaderStyle>
          <StaticResource ResourceKey="HeaderWrapCenter"/>
        </DataGrid.ColumnHeaderStyle>
        <DataGrid.RowStyle>
          <Style TargetType="DataGridRow">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#1F2A36"/>
            <Style.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="#DCEBFA"/>
                <Setter Property="Foreground" Value="#1F2A36"/>
              </Trigger>
              <DataTrigger Binding="{Binding is_enabled}" Value="False">
                <Setter Property="Opacity" Value="0.45"/>
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </DataGrid.RowStyle>
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="34" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding is_checked, Mode=OneWay}" IsEnabled="{Binding is_enabled}" Click="item_checkbox_clicked"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTemplateColumn Header="Circuit" Width="260" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <StackPanel Margin="4,2,4,2">
                  <TextBlock Text="{Binding panel_ckt_text}" FontWeight="Bold" Foreground="#1F2A36"/>
                  <TextBlock Text="{Binding load_name}" Foreground="#3A4754" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Type" Width="78" Binding="{Binding branch_type}" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}" ElementStyle="{StaticResource CenterTextCell}"/>
          <DataGridTextColumn Header="Load&#10;Current" Width="92" Binding="{Binding current_load_current}" IsReadOnly="True" SortMemberPath="current_load_current" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Rating" Width="86" Binding="{Binding current_rating}" IsReadOnly="True" SortMemberPath="current_rating" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource ReadonlyCell}"/>
          <DataGridTextColumn Header="Current&#10;Frame" Width="86" Binding="{Binding current_frame}" IsReadOnly="True" SortMemberPath="current_frame" ElementStyle="{StaticResource CenterTextCell}" CellStyle="{StaticResource DividerThickReadonlyCell}"/>
          <DataGridTextColumn Header="New&#10;Rating" Width="90" Binding="{Binding new_rating, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsReadOnly="False" SortMemberPath="new_rating" ElementStyle="{StaticResource CenterTextCell}" EditingElementStyle="{StaticResource CenterTextEdit}" CellStyle="{StaticResource NewValueCell}"/>
          <DataGridTextColumn Header="New&#10;Frame" Width="86" Binding="{Binding new_frame, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" IsReadOnly="False" SortMemberPath="new_frame" ElementStyle="{StaticResource CenterTextCell}" EditingElementStyle="{StaticResource CenterTextEdit}" CellStyle="{StaticResource NewFrameCell}"/>
          <DataGridTextColumn Header="Remarks" Width="*" Binding="{Binding remarks}" IsReadOnly="True" CellStyle="{StaticResource ReadonlyCell}" ElementStyle="{StaticResource RemarksTextCell}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
        <StackPanel VerticalAlignment="Center" Margin="0,0,10,0">
          <StackPanel Orientation="Horizontal">
            <Button Content="Check All" Width="86" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="check_all_clicked"/>
            <Button Content="Uncheck All" Width="94" Height="28" Margin="6,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="uncheck_all_clicked"/>
          </StackPanel>
          <TextBlock Name="CheckedStatusText" Margin="2,4,0,0" Foreground="#3A4754" Text="0 of 0 checked"/>
        </StackPanel>
        <Border Margin="12,0,0,0" Padding="8,4,10,4" BorderBrush="#C8D3E0" BorderThickness="1" CornerRadius="4" Background="#F6F9FD" VerticalAlignment="Center">
          <StackPanel>
            <Border Padding="6,3,8,3" BorderBrush="#9BB8D9" BorderThickness="1" CornerRadius="3" Background="#EDF5FF">
              <StackPanel Orientation="Horizontal">
                <CheckBox Name="AutoBreakerCheck" Content="Autosize Breakers" IsChecked="True" VerticalAlignment="Center"/>
                <CheckBox Name="UpsizeOnlyToggle" Content="Upsize Only" IsChecked="False" Margin="12,0,0,0" VerticalAlignment="Center"/>
              </StackPanel>
            </Border>
            <CheckBox Name="AutoFrameCheck" Content="Autosize Frames" IsChecked="True" Margin="0,4,0,0" VerticalAlignment="Center"/>
            <CheckBox Name="Allow15AToggle" Content="Allow 15A minimum" IsChecked="False" Margin="0,2,0,0" VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
        <Button Name="AutosizePreviewButton" Content="Autosize Preview" Width="120" Height="28" Margin="12,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="apply_autosized_clicked"/>
        <Button Name="ResetButton" Content="Reset Selected" Width="106" Height="28" Margin="6,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="reset_clicked"/>
      </StackPanel>

      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
        <TextBlock Name="ChangedStatusText" Margin="0,0,12,0" VerticalAlignment="Center" Foreground="#3A4754" Text="0 of 0 circuits to be modified"/>
        <Button Content="Cancel" Width="80" Height="28" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="cancel_clicked"/>
        <Button Name="ApplyButton" Content="Apply" Width="80" Height="28" Margin="6,0,0,0" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Click="apply_clicked" Background="#DFF2D8" BorderBrush="#4E8A4A"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>



