<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Calculation Summary"
        Height="520"
        Width="960"
        MinHeight="360"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        Background="#F2F3F5">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="8"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="Calculation Summary" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Name="RuntimeCountText" Text="Runtime-only alerts: 0" FontWeight="SemiBold" Margin="0,0,0,6"/>
      <Border Grid.Row="1" BorderBrush="#AAB4C0" BorderThickness="1" Background="#FFFFFF">
        <ListView Name="RuntimeList">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Panel" Width="120" DisplayMemberBinding="{Binding panel}"/>
              <GridViewColumn Header="Number" Width="90" DisplayMemberBinding="{Binding number}"/>
              <GridViewColumn Header="Severity" Width="90" DisplayMemberBinding="{Binding severity}"/>
              <GridViewColumn Header="Group" Width="130" DisplayMemberBinding="{Binding group}"/>
              <GridViewColumn Header="Message" Width="480">
                <GridViewColumn.CellTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding message}" TextWrapping="Wrap" MaxWidth="470"/>
                  </DataTemplate>
                </GridViewColumn.CellTemplate>
              </GridViewColumn>
            </GridView>
          </ListView.View>
        </ListView>
      </Border>
    </Grid>

    <Grid Grid.Row="3">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>
      <TextBlock Grid.Row="0" Name="LockedCountText" Text="Locked items: 0" FontWeight="SemiBold" Margin="0,0,0,6"/>
      <Border Grid.Row="1" BorderBrush="#AAB4C0" BorderThickness="1" Background="#FFFFFF">
        <ListView Name="LockedList">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Panel" Width="120" DisplayMemberBinding="{Binding panel}"/>
              <GridViewColumn Header="Number" Width="90" DisplayMemberBinding="{Binding number}"/>
              <GridViewColumn Header="Circuit" Width="120" DisplayMemberBinding="{Binding circuit}"/>
              <GridViewColumn Header="Circuit Owner" Width="160" DisplayMemberBinding="{Binding circuit_owner}"/>
              <GridViewColumn Header="Device Owner" Width="180" DisplayMemberBinding="{Binding device_owner}"/>
            </GridView>
          </ListView.View>
        </ListView>
      </Border>
    </Grid>

    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button Content="Close" Width="80" Height="24" Click="close_clicked"/>
    </StackPanel>
  </Grid>
</Window>
