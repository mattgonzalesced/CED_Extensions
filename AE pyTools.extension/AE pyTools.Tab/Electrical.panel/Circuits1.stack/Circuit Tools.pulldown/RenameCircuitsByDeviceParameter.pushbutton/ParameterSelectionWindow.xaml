<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Circuits by Device Parameter"
        Height="560"
        Width="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeaderText"
                   Grid.Row="0"
                   Text="Select one text parameter for each circuit."
                   FontWeight="Bold"
                   Margin="0,0,0,6"/>

        <TextBlock Grid.Row="1"
                   Text="Only parameters common to connected selected devices are listed for each circuit."
                   Margin="0,0,0,10"/>

        <Border Grid.Row="2"
                BorderBrush="#FFBFBFBF"
                BorderThickness="1"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel x:Name="CircuitRowsPanel"/>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,10,0,0">
            <Button x:Name="ApplyButton"
                    Content="Rename Circuits"
                    Width="130"
                    Margin="0,0,8,0"
                    IsDefault="True"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="90"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
