<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename Circuits by Device Parameter"
        Height="820"
        Width="1450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Circuits (select one or many)" Margin="0,0,10,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Use Ctrl/Shift to select multiple circuits. Active circuit is the first selected."
                               Margin="0,0,0,6"/>
                    <ListBox x:Name="CircuitList"
                             Grid.Row="1"
                             Height="180"
                             DisplayMemberPath="Display"
                             SelectionMode="Extended"
                             SelectionChanged="CircuitList_SelectionChanged"/>
                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0">
                        <Button x:Name="ApplyToSelectedButton"
                                Content="Apply Builder to Selected"
                                Width="165"
                                Margin="0,0,8,0"
                                Click="ApplyToSelectedButton_Click"/>
                        <Button x:Name="ApplyToAllButton"
                                Content="Apply Builder to All"
                                Width="145"
                                Click="ApplyToAllButton_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <StackPanel Grid.Column="1">
                <GroupBox Header="Quick Add" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="CustomFieldCombo"
                                  Grid.Row="0"
                                  Grid.Column="0"
                                  IsEditable="True"
                                  Margin="0,0,8,6"/>
                        <Button x:Name="AddCustomFieldButton"
                                Grid.Row="0"
                                Grid.Column="1"
                                Content="Add Custom Field"
                                Click="AddCustomFieldButton_Click"
                                Margin="0,0,0,6"/>

                        <ComboBox x:Name="SeparatorCombo"
                                  Grid.Row="1"
                                  Grid.Column="0"
                                  IsEditable="True"
                                  Margin="0,0,8,0"/>
                        <Button x:Name="AddSeparatorButton"
                                Grid.Row="1"
                                Grid.Column="1"
                                Content="Add Separator"
                                Click="AddSeparatorButton_Click"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Saved Builders" Margin="0,0,0,8">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ComboBox x:Name="SavedTemplateCombo"
                                  Grid.Row="0"
                                  IsEditable="False"
                                  Margin="0,0,0,6"/>
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBox x:Name="TemplateNameText"
                                     Width="220"
                                     Margin="0,0,8,0"/>
                            <Button x:Name="SaveTemplateButton"
                                    Content="Save"
                                    Width="80"
                                    Click="SaveTemplateButton_Click"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Button x:Name="LoadTemplateButton"
                                    Content="Load to Active"
                                    Width="110"
                                    Margin="0,0,8,0"
                                    Click="LoadTemplateButton_Click"/>
                            <Button x:Name="DeleteTemplateButton"
                                    Content="Delete"
                                    Width="80"
                                    Click="DeleteTemplateButton_Click"/>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Rename Options">
                    <StackPanel Margin="8">
                        <CheckBox x:Name="IncrementSelectedCheckBox"
                                  Checked="IncrementSelectedCheckBox_Changed"
                                  Unchecked="IncrementSelectedCheckBox_Changed"
                                  Content="Increment selected duplicates (append ' #2', ' #3', ... )"/>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="1.4*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Available Parameters (Active Circuit)" Margin="0,0,10,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="AvailableParamsList" Grid.Row="0"/>
                    <Button x:Name="AddToStringButton"
                            Grid.Row="1"
                            Content="Add to String"
                            Margin="0,8,0,0"
                            Click="AddToStringButton_Click"/>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="1" Header="String Parts (Active Circuit)" Margin="0,0,10,0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <ListBox x:Name="StringPartsList"
                             Grid.Row="0"
                             SelectionMode="Extended"/>
                    <StackPanel Grid.Row="1"
                                Orientation="Horizontal"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0">
                        <Button x:Name="RemoveFromStringButton"
                                Content="Remove"
                                Width="85"
                                Margin="0,0,8,0"
                                Click="RemoveFromStringButton_Click"/>
                        <Button x:Name="MoveUpButton"
                                Content="Move Up"
                                Width="85"
                                Margin="0,0,8,0"
                                Click="MoveUpButton_Click"/>
                        <Button x:Name="MoveDownButton"
                                Content="Move Down"
                                Width="85"
                                Margin="0,0,8,0"
                                Click="MoveDownButton_Click"/>
                        <Button x:Name="ClearStringButton"
                                Content="Clear"
                                Width="85"
                                Click="ClearStringButton_Click"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Grid.Column="2" Header="Preview" Margin="0">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="ActiveCircuitText"
                               Grid.Row="0"
                               Text="Active Circuit: "
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="PreviewTextBox"
                             Grid.Row="1"
                             Height="28"
                             TextChanged="PreviewTextBox_TextChanged"
                             Margin="0,0,0,8"/>
                    <TextBlock Grid.Row="2"
                               Text="Selected Circuit Previews"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                    <ListBox x:Name="SelectedPreviewList"
                             Grid.Row="3"
                             DisplayMemberPath="Display"
                             SelectionChanged="SelectedPreviewList_SelectionChanged"/>
                </Grid>
            </GroupBox>
        </Grid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="RenameButton"
                    Content="Rename Circuits"
                    Width="130"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="RenameButton_Click"/>
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Width="90"
                    IsCancel="True"
                    Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
