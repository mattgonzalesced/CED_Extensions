<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="System Tagger"
        Height="420"
        Width="560"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">
  <Grid Margin="10">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>
    <TextBlock Text="Paste SYS NO. values from Excel (full block is OK):" Margin="0,0,0,6"/>
    <TextBox x:Name="InputBox"
             Grid.Row="1"
             AcceptsReturn="True"
             TextWrapping="NoWrap"
             VerticalScrollBarVisibility="Auto"
             HorizontalScrollBarVisibility="Auto"
             MinHeight="220"/>
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
      <Button x:Name="OkButton" Content="OK" Width="90" Margin="0,0,8,0" Click="OkButton_Click"/>
      <Button x:Name="CancelButton" Content="Cancel" Width="90" Click="CancelButton_Click"/>
    </StackPanel>
  </Grid>
</Window>
