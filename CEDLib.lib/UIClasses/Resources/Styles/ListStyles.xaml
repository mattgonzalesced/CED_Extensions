<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="CED.ScrollBar.Menu.Thumb" TargetType="Thumb">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.IconMuted}"/>
    <Setter Property="MinHeight" Value="8"/>
    <Setter Property="MinWidth" Value="8"/>
    <Setter Property="Opacity" Value="0.45"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Thumb">
          <Border x:Name="Pill"
                  Background="{TemplateBinding Background}"
                  CornerRadius="4"
                  Margin="0"/>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Pill" Property="Opacity" Value="0.68"/>
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
              <Setter TargetName="Pill" Property="Opacity" Value="0.86"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.ScrollBar.Menu.Button" TargetType="RepeatButton">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridCellBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="RepeatButton">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="3">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.ScrollBar.Menu.EndButton" TargetType="RepeatButton" BasedOn="{StaticResource CED.ScrollBar.Menu.Button}">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
    <Setter Property="Opacity" Value="0.85"/>
  </Style>

  <Style x:Key="CED.ScrollBar.Menu.TrackButton" TargetType="RepeatButton" BasedOn="{StaticResource CED.ScrollBar.Menu.Button}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderBrush" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
  </Style>

  <ControlTemplate x:Key="CED.ScrollBar.Menu.Template.Vertical" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Grid.RowDefinitions>
        <RowDefinition Height="16"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="16"/>
      </Grid.RowDefinitions>
      <RepeatButton Grid.Row="0"
                    Style="{StaticResource CED.ScrollBar.Menu.EndButton}"
                    Command="ScrollBar.LineUpCommand">
        <Path Data="M1,7 L4,3 L7,7 Z"
              Fill="{DynamicResource CED.Brush.IconMuted}"
              Stretch="Fill"
              Width="8"
              Height="6"/>
      </RepeatButton>
      <Border x:Name="TrackChrome"
              Grid.Row="1"
              Margin="0,1,0,1"
              Background="{DynamicResource CED.Brush.SearchBackground}"
              BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
              BorderThickness="1"
              CornerRadius="4">
        <Grid>
          <Border x:Name="TrackStateOverlay" Background="Transparent" CornerRadius="6"/>
          <Track x:Name="PART_Track"
                 IsDirectionReversed="True"
                 HorizontalAlignment="Center"
                 Width="8"
                 Margin="1"
                 Minimum="{TemplateBinding Minimum}"
                 Maximum="{TemplateBinding Maximum}"
                 Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                 ViewportSize="{TemplateBinding ViewportSize}">
            <Track.DecreaseRepeatButton>
              <RepeatButton Style="{StaticResource CED.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageUpCommand"/>
            </Track.DecreaseRepeatButton>
            <Track.Thumb>
  <Thumb x:Name="ThumbElement"
         Style="{StaticResource CED.ScrollBar.Menu.Thumb}"/>
</Track.Thumb>
            <Track.IncreaseRepeatButton>
              <RepeatButton Style="{StaticResource CED.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageDownCommand"/>
            </Track.IncreaseRepeatButton>
          </Track>
        </Grid>
      </Border>
      <RepeatButton Grid.Row="2"
                    Style="{StaticResource CED.ScrollBar.Menu.EndButton}"
                    Command="ScrollBar.LineDownCommand">
        <Path Data="M1,3 L4,7 L7,3 Z"
              Fill="{DynamicResource CED.Brush.IconMuted}"
              Stretch="Fill"
              Width="8"
              Height="6"/>
      </RepeatButton>
    </Grid>
    <ControlTemplate.Triggers>
<MultiTrigger>
  <MultiTrigger.Conditions>
    <Condition SourceName="PART_Track" Property="IsMouseOver" Value="True"/>
    <Condition SourceName="ThumbElement" Property="IsMouseOver" Value="False"/>
  </MultiTrigger.Conditions>
  <Setter TargetName="TrackStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
</MultiTrigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <ControlTemplate x:Key="CED.ScrollBar.Menu.Template.Horizontal" TargetType="ScrollBar">
    <Grid Background="Transparent">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="16"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="16"/>
      </Grid.ColumnDefinitions>
      <RepeatButton Grid.Column="0"
                    Style="{StaticResource CED.ScrollBar.Menu.EndButton}"
                    Command="ScrollBar.LineLeftCommand">
        <Path Data="M7,1 L3,4 L7,7 Z"
              Fill="{DynamicResource CED.Brush.IconMuted}"
              Stretch="Fill"
              Width="6"
              Height="8"/>
      </RepeatButton>
      <Border x:Name="TrackChrome"
              Grid.Column="1"
              Margin="1,0,1,0"
              Background="{DynamicResource CED.Brush.SearchBackground}"
              BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
              BorderThickness="1"
              CornerRadius="6">
        <Grid>
          <Border x:Name="TrackStateOverlay" Background="Transparent" CornerRadius="4"/>
          <Track x:Name="PART_Track"
                 IsDirectionReversed="False"
                 VerticalAlignment="Center"
                 Height="8"
                 Margin="1"
                 Minimum="{TemplateBinding Minimum}"
                 Maximum="{TemplateBinding Maximum}"
                 Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                 ViewportSize="{TemplateBinding ViewportSize}">
            <Track.DecreaseRepeatButton>
              <RepeatButton Style="{StaticResource CED.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageLeftCommand"/>
            </Track.DecreaseRepeatButton>
            <Track.Thumb>
              <Thumb x:Name="ThumbElement"
                     Style="{StaticResource CED.ScrollBar.Menu.Thumb}"/>
            </Track.Thumb>
            <Track.IncreaseRepeatButton>
              <RepeatButton Style="{StaticResource CED.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageRightCommand"/>
            </Track.IncreaseRepeatButton>
          </Track>
        </Grid>
      </Border>
      <RepeatButton Grid.Column="2"
                    Style="{StaticResource CED.ScrollBar.Menu.EndButton}"
                    Command="ScrollBar.LineRightCommand">
        <Path Data="M3,1 L7,4 L3,7 Z"
              Fill="{DynamicResource CED.Brush.IconMuted}"
              Stretch="Fill"
              Width="6"
              Height="8"/>
      </RepeatButton>
    </Grid>
    <ControlTemplate.Triggers>
<MultiTrigger>
  <MultiTrigger.Conditions>
    <Condition SourceName="PART_Track" Property="IsMouseOver" Value="True"/>
    <Condition SourceName="ThumbElement" Property="IsMouseOver" Value="False"/>
  </MultiTrigger.Conditions>
  <Setter TargetName="TrackStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
</MultiTrigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style x:Key="CED.ScrollBar.Menu" TargetType="ScrollBar">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.IconMuted}"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
    <Setter Property="UseLayoutRounding" Value="True"/>
    <Setter Property="Width" Value="12"/>
    <Setter Property="Height" Value="Auto"/>
    <Setter Property="MinWidth" Value="12"/>
    <Setter Property="MinHeight" Value="12"/>
    <Setter Property="Template" Value="{StaticResource CED.ScrollBar.Menu.Template.Vertical}"/>
    <Style.Triggers>
      <Trigger Property="Orientation" Value="Horizontal">
        <Setter Property="Height" Value="12"/>
        <Setter Property="Width" Value="Auto"/>
        <Setter Property="MinHeight" Value="12"/>
        <Setter Property="Template" Value="{StaticResource CED.ScrollBar.Menu.Template.Horizontal}"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style TargetType="ScrollBar" BasedOn="{StaticResource CED.ScrollBar.Menu}"/>

  <ControlTemplate x:Key="CED.ScrollViewer.Themed.Template" TargetType="ScrollViewer">
    <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>
      <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                              Grid.Row="0"
                              Grid.Column="0"
                              CanContentScroll="{TemplateBinding CanContentScroll}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                              Margin="{TemplateBinding Padding}"/>
      <ScrollBar x:Name="PART_VerticalScrollBar"
                 Grid.Row="0"
                 Grid.Column="1"
                 Orientation="Vertical"
                 Minimum="0"
                 Maximum="{TemplateBinding ScrollableHeight}"
                 ViewportSize="{TemplateBinding ViewportHeight}"
                 Value="{TemplateBinding VerticalOffset}"
                 Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
      <ScrollBar x:Name="PART_HorizontalScrollBar"
                 Grid.Row="1"
                 Grid.Column="0"
                 Orientation="Horizontal"
                 Minimum="0"
                 Maximum="{TemplateBinding ScrollableWidth}"
                 ViewportSize="{TemplateBinding ViewportWidth}"
                 Value="{TemplateBinding HorizontalOffset}"
                 Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
      <Border x:Name="PART_Corner"
              Grid.Row="1"
              Grid.Column="1"
              Background="{DynamicResource CED.Brush.ListBackground}"
              BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
              BorderThickness="1"
              Visibility="Collapsed"/>
    </Grid>
    <ControlTemplate.Triggers>
      <MultiTrigger>
        <MultiTrigger.Conditions>
          <Condition Property="ComputedHorizontalScrollBarVisibility" Value="Visible"/>
          <Condition Property="ComputedVerticalScrollBarVisibility" Value="Visible"/>
        </MultiTrigger.Conditions>
        <Setter TargetName="PART_Corner" Property="Visibility" Value="Visible"/>
      </MultiTrigger>
    </ControlTemplate.Triggers>
  </ControlTemplate>

  <Style x:Key="CED.ScrollViewer.Themed" TargetType="ScrollViewer">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.ListBorder}"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Template" Value="{DynamicResource CED.ScrollViewer.Themed.Template}"/>
  </Style>

  <Style x:Key="CED.ContextMenu.Base" TargetType="ContextMenu">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.CardBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
    <Setter Property="Padding" Value="1"/>
    <Setter Property="HasDropShadow" Value="False"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="ItemContainerStyle" Value="{DynamicResource CED.MenuItem.Base}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ContextMenu">
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{DynamicResource CED.CornerRadius.Control}"
                  Padding="{TemplateBinding Padding}">
            <ScrollViewer CanContentScroll="True"
                          Background="Transparent"
                          BorderThickness="0"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource CED.ScrollBar.Menu}"/>
              </ScrollViewer.Resources>
              <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
            </ScrollViewer>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.Separator.Menu" TargetType="Separator">
    <Setter Property="Margin" Value="8,4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Separator">
          <Border Height="1" Background="{DynamicResource CED.Brush.DataGridCellBorder}"/>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.MenuItem.Base" TargetType="MenuItem">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="OverridesDefaultStyle" Value="True"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="MenuItem">
          <Border x:Name="ItemBorder"
                  Background="{TemplateBinding Background}"
                  CornerRadius="4"
                  Margin="0,1,2,1">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="IconCol" Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="CheckCol" Width="0"/>
                <ColumnDefinition x:Name="SubmenuCol" Width="0"/>
              </Grid.ColumnDefinitions>
              <ContentPresenter x:Name="IconPresenter"
                                Grid.Column="0"
                                ContentSource="Icon"
                                VerticalAlignment="Center"
                                Margin="4,0,6,0"/>
              <ContentPresenter x:Name="HeaderPresenter"
                                Grid.Column="1"
                                ContentSource="Header"
                                RecognizesAccessKey="True"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>
              <Path x:Name="CheckGlyph"
                    Grid.Column="2"
                    Width="10"
                    Height="10"
                    Margin="6,0,8,0"
                    Data="{DynamicResource CED.Icon.Check}"
                    Fill="{TemplateBinding Foreground}"
                    Stretch="Uniform"
                    Visibility="Collapsed"/>
              <Path x:Name="SubmenuGlyph"
                    Grid.Column="3"
                    Width="8"
                    Height="8"
                    Margin="6,0,8,0"
                    Data="M0,0 L0,8 L5,4 Z"
                    Fill="{TemplateBinding Foreground}"
                    Stretch="Fill"
                    Visibility="Collapsed"/>
              <Popup x:Name="SubmenuPopup"
                     Placement="Right"
                     AllowsTransparency="True"
                     Focusable="False"
                     IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}">
                <Border Background="{DynamicResource CED.Brush.ListItemBackground}"
                        BorderBrush="{DynamicResource CED.Brush.CardBorder}"
                        BorderThickness="1"
                        CornerRadius="{DynamicResource CED.CornerRadius.Control}"
                        Padding="1">
                  <ScrollViewer CanContentScroll="True"
                                Background="Transparent"
                                BorderThickness="0"
                                HorizontalScrollBarVisibility="Disabled"
                                VerticalScrollBarVisibility="Auto">
                    <ScrollViewer.Resources>
                      <Style TargetType="ScrollBar" BasedOn="{StaticResource CED.ScrollBar.Menu}"/>
                    </ScrollViewer.Resources>
                    <StackPanel IsItemsHost="True"/>
                  </ScrollViewer>
                </Border>
              </Popup>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="Icon" Value="{x:Null}">
              <Setter TargetName="IconCol" Property="Width" Value="0"/>
              <Setter TargetName="IconPresenter" Property="Visibility" Value="Collapsed"/>
            </Trigger>
            <Trigger Property="IsCheckable" Value="True">
              <Setter TargetName="CheckCol" Property="Width" Value="Auto"/>
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsCheckable" Value="True"/>
                <Condition Property="IsChecked" Value="True"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible"/>
            </MultiTrigger>
            <Trigger Property="HasItems" Value="True">
              <Setter TargetName="SubmenuCol" Property="Width" Value="Auto"/>
              <Setter TargetName="SubmenuGlyph" Property="Visibility" Value="Visible"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
            </Trigger>
            <MultiTrigger>
              <MultiTrigger.Conditions>
                <Condition Property="IsCheckable" Value="True"/>
                <Condition Property="IsChecked" Value="True"/>
                <Condition Property="Tag" Value="__ced_type_filter_no_shade__"/>
              </MultiTrigger.Conditions>
              <Setter TargetName="ItemBorder" Property="Background" Value="Transparent"/>
            </MultiTrigger>
            <Trigger Property="IsHighlighted" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
            </Trigger>
            <Trigger Property="IsKeyboardFocused" Value="True">
              <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ItemBorder" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.ListView.Virtualized" TargetType="ListView">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.ListBorder}"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.NeutralDark}"/>
    <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
    <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
    <Setter Property="ScrollViewer.CanContentScroll" Value="True"/>
  </Style>

  <Style x:Key="CED.ListViewItem.Base" TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.NeutralDark}"/>
  </Style>

  <Style x:Key="CED.ListViewItem.SurfaceBehavior" TargetType="ListViewItem" BasedOn="{StaticResource CED.ListViewItem.Base}">
    <Setter Property="Background" Value="Transparent"/>
    <Setter Property="BorderThickness" Value="0"/>
    <Setter Property="Padding" Value="0"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListViewItem">
          <Border Background="Transparent" SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}"/>
          </Border>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.DataGrid.Base" TargetType="DataGrid">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridBorder}"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridRowForeground}"/>
    <Setter Property="RowBackground" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
    <Setter Property="AlternatingRowBackground" Value="{DynamicResource CED.Brush.DataGridAltRow}"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
    <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource CED.Brush.DataGridCellBorder}"/>
    <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource CED.Brush.DataGridCellBorder}"/>
  </Style>

  <Style x:Key="CED.GridView.Header" TargetType="GridViewColumnHeader">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridHeaderBackground}"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridHeaderForeground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridHeaderBorder}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Padding" Value="8,4"/>
    <Setter Property="HorizontalContentAlignment" Value="Left"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="GridViewColumnHeader">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.DataGridHeaderHoverBackground}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.DataGridHeaderPressedBackground}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.ListView.Alerts" TargetType="ListView" BasedOn="{StaticResource CED.ListView.Virtualized}">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridBorder}"/>
    <Setter Property="ItemContainerStyle" Value="{DynamicResource CED.ListViewItem.Alerts}"/>
  </Style>

  <Style x:Key="CED.ListView.AlertsGrid" TargetType="ListView" BasedOn="{StaticResource CED.ListView.Virtualized}">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridBorder}"/>
    <Setter Property="ItemContainerStyle" Value="{DynamicResource CED.ListViewItem.AlertsGrid}"/>
  </Style>

  <Style x:Key="CED.ListViewItem.Alerts" TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridCellBorder}"/>
    <Setter Property="BorderThickness" Value="0,0,0,1"/>
    <Setter Property="Padding" Value="2,1"/>
    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ListViewItem">
          <Border x:Name="ItemRoot"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  SnapsToDevicePixels="True">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Margin="{TemplateBinding Padding}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemHoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
              <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="ItemRoot" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Background" Value="{DynamicResource CED.Brush.CircuitItemHoverBackground}"/>
      </Trigger>
      <Trigger Property="IsSelected" Value="True">
        <Setter Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
        <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      </Trigger>
      <Trigger Property="IsEnabled" Value="False">
        <Setter Property="Opacity" Value="0.55"/>
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="CED.ListViewItem.AlertsGrid" TargetType="ListViewItem" BasedOn="{StaticResource CED.ListViewItem.Alerts}"/>

  <Style x:Key="CED.TabItem.Base" TargetType="TabItem">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.TabInactiveForeground}"/>
    <Setter Property="Background" Value="{DynamicResource CED.Brush.TabInactiveBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridHeaderBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="10,4"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabItem">
          <Border x:Name="HeaderBorder"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="1,1,1,0"
                  CornerRadius="4,4,0,0"
                  Margin="0,0,3,0">
            <ContentPresenter ContentSource="Header"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Margin="{TemplateBinding Padding}"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource CED.Brush.TabHoverBackground}"/>
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
              <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource CED.Brush.TabActiveBackground}"/>
              <Setter TargetName="HeaderBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridBorder}"/>
              <Setter Property="Foreground" Value="{DynamicResource CED.Brush.TabActiveForeground}"/>
              <Setter Property="Panel.ZIndex" Value="10"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="HeaderBorder" Property="Opacity" Value="0.6"/>
              <Setter Property="Foreground" Value="{DynamicResource CED.Brush.SecondaryText}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="CED.TabControl.Base" TargetType="TabControl">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="TabControl">
          <Grid ClipToBounds="True">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TabPanel Grid.Row="0"
                      IsItemsHost="True"
                      Margin="0,0,0,-1"
                      Panel.ZIndex="1"
                      Background="Transparent"/>
            <Border Grid.Row="1"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
              <ContentPresenter x:Name="PART_SelectedContentHost"
                                ContentSource="SelectedContent"
                                Margin="0"/>
            </Border>
          </Grid>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Setter Property="ItemContainerStyle" Value="{DynamicResource CED.TabItem.Base}"/>
  </Style>
</ResourceDictionary>
