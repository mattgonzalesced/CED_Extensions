<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="CED.Text.Title" TargetType="TextBlock">
    <Setter Property="FontSize" Value="20"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style x:Key="CED.Text.SectionHeader" TargetType="TextBlock">
    <Setter Property="FontSize" Value="16"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style x:Key="CED.Text.Body" TargetType="TextBlock">
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style x:Key="CED.Text.Primary" TargetType="TextBlock" BasedOn="{StaticResource CED.Text.Body}">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style x:Key="CED.Text.Secondary" TargetType="TextBlock" BasedOn="{StaticResource CED.Text.Body}">
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.SecondaryText}"/>
  </Style>

  <Style x:Key="CED.Text.Caption" TargetType="TextBlock" BasedOn="{StaticResource CED.Text.Body}">
    <Setter Property="FontSize" Value="10"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.SecondaryText}"/>
  </Style>

  <Style x:Key="CED.Text.CaptionStrong" TargetType="TextBlock" BasedOn="{StaticResource CED.Text.Caption}">
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
  </Style>
</ResourceDictionary>
