<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="CED.Path.IconMuted" TargetType="Path">
    <Setter Property="Fill" Value="{DynamicResource CED.Brush.IconMuted}"/>
    <Setter Property="Stretch" Value="Uniform"/>
    <Setter Property="Width" Value="14"/>
    <Setter Property="Height" Value="14"/>
    <Setter Property="SnapsToDevicePixels" Value="True"/>
  </Style>

  <Style x:Key="CED.Separator.Horizontal" TargetType="Border">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Background" Value="{DynamicResource CED.Brush.SectionDivider}"/>
    <Setter Property="Margin" Value="0,6,0,6"/>
  </Style>

  <Style x:Key="CED.Text.EmptyState" TargetType="TextBlock" BasedOn="{StaticResource CED.Text.Secondary}">
    <Setter Property="TextAlignment" Value="Center"/>
    <Setter Property="TextWrapping" Value="Wrap"/>
    <Setter Property="Margin" Value="12"/>
  </Style>

  <Style x:Key="CED.Row.SurfaceOverlay" TargetType="Border">
    <Setter Property="Background" Value="{DynamicResource CED.Brush.CircuitItemHoverBackground}"/>
    <Setter Property="Opacity" Value="0"/>
    <Setter Property="CornerRadius" Value="{DynamicResource CED.CornerRadius.Control}"/>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="True">
        <Setter Property="Opacity" Value="1"/>
      </Trigger>
    </Style.Triggers>
  </Style>
</ResourceDictionary>
