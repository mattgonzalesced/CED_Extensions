<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Style x:Key="CED.Circuit.CompactContainer" TargetType="Border">
    <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.CardBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="3"/>
    <Setter Property="Margin" Value="{DynamicResource CED.Thickness.ItemGap}"/>
    <Setter Property="Padding" Value="4"/>
    <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
    <Style.Triggers>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="surface"/>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Tag}" Value="{x:Null}"/>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsMouseOver}" Value="True"/>
        </MultiDataTrigger.Conditions>
        <Setter Property="Background" Value="{DynamicResource CED.Brush.CircuitItemHoverBackground}"/>
      </MultiDataTrigger>
      <MultiDataTrigger>
        <MultiDataTrigger.Conditions>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListView}, Path=Tag}" Value="surface"/>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Tag}" Value="{x:Null}"/>
          <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=IsSelected}" Value="True"/>
        </MultiDataTrigger.Conditions>
        <Setter Property="Background" Value="{DynamicResource CED.Brush.CircuitItemSelectedBackground}"/>
      </MultiDataTrigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="CED.Circuit.CardContainer" TargetType="Border" BasedOn="{StaticResource CED.Circuit.CompactContainer}">
    <Setter Property="CornerRadius" Value="4"/>
    <Setter Property="Padding" Value="6"/>
  </Style>
</ResourceDictionary>
