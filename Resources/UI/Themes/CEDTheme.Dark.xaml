<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="CED.Color.PrimaryBlue">#3B8ED8</Color>
  <Color x:Key="CED.Color.SecondaryRed">#D15762</Color>
  <Color x:Key="CED.Color.TertiaryGreen">#58B95E</Color>
  <Color x:Key="CED.Color.NeutralDark">#E6E6E6</Color>
  <Color x:Key="CED.Color.Surface">#1C2127</Color>
  <Color x:Key="CED.Color.SurfaceAlt">#252B33</Color>
  <Color x:Key="CED.Color.Border">#3A434F</Color>

  <SolidColorBrush x:Key="CED.Brush.PrimaryBlue" Color="{StaticResource CED.Color.PrimaryBlue}"/>
  <SolidColorBrush x:Key="CED.Brush.SecondaryRed" Color="{StaticResource CED.Color.SecondaryRed}"/>
  <SolidColorBrush x:Key="CED.Brush.TertiaryGreen" Color="{StaticResource CED.Color.TertiaryGreen}"/>
  <SolidColorBrush x:Key="CED.Brush.NeutralDark" Color="{StaticResource CED.Color.NeutralDark}"/>
  <SolidColorBrush x:Key="CED.Brush.Surface" Color="{StaticResource CED.Color.Surface}"/>
  <SolidColorBrush x:Key="CED.Brush.SurfaceAlt" Color="{StaticResource CED.Color.SurfaceAlt}"/>
  <SolidColorBrush x:Key="CED.Brush.Border" Color="{StaticResource CED.Color.Border}"/>
  <SolidColorBrush x:Key="CED.Brush.WindowBackground" Color="#171B20"/>
  <SolidColorBrush x:Key="CED.Brush.HeadingText" Color="#E5EDF9"/>
  <SolidColorBrush x:Key="CED.Brush.PrimaryText" Color="#E5EDF9"/>
  <SolidColorBrush x:Key="CED.Brush.SecondaryText" Color="#B4C0CE"/>
  <SolidColorBrush x:Key="CED.Brush.SearchBorder" Color="#3A434F"/>
  <SolidColorBrush x:Key="CED.Brush.SearchBackground" Color="#1F252C"/>
  <SolidColorBrush x:Key="CED.Brush.IconMuted" Color="#A8B6C6"/>
  <SolidColorBrush x:Key="CED.Brush.PlaceholderText" Color="#7E8C9A"/>
  <SolidColorBrush x:Key="CED.Brush.ListBorder" Color="#252C34"/>
  <SolidColorBrush x:Key="CED.Brush.ListBackground" Color="#171C22"/>
  <SolidColorBrush x:Key="CED.Brush.CardBorder" Color="#2B323C"/>
  <SolidColorBrush x:Key="CED.Brush.SelectionBadge" Color="#9DB1C8"/>

  <Style TargetType="Button">
    <Setter Property="Foreground" Value="#DCE6F2"/>
    <Setter Property="Background" Value="#2A3139"/>
    <Setter Property="BorderBrush" Value="#4A5664"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,2"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  SnapsToDevicePixels="True">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="#36404B"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource CED.Brush.PrimaryBlue}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource CED.Brush.SurfaceAlt}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Foreground" Value="#DCE6F2"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
  </Style>

  <Style TargetType="GridViewColumnHeader">
    <Setter Property="Background" Value="{StaticResource CED.Brush.SurfaceAlt}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Foreground" Value="#DCE6F2"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="#E7EEF7"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,3"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style TargetType="ListView">
    <Setter Property="Background" Value="{StaticResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.ListBorder}"/>
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.PrimaryText}"/>
    <Setter Property="Background" Value="#1F252C"/>
  </Style>

  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="#1F252C"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="Foreground" Value="#D7E0EB"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="Foreground" Value="#D7E0EB"/>
    <Setter Property="Background" Value="#1F252C"/>
  </Style>
</ResourceDictionary>
