<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Color x:Key="CED.Color.PrimaryBlue">#0459A4</Color>
  <Color x:Key="CED.Color.SecondaryRed">#BE202F</Color>
  <Color x:Key="CED.Color.TertiaryGreen">#43A047</Color>
  <Color x:Key="CED.Color.NeutralDark">#323130</Color>
  <Color x:Key="CED.Color.Surface">#F4F7FB</Color>
  <Color x:Key="CED.Color.SurfaceAlt">#EAF1F9</Color>
  <Color x:Key="CED.Color.Border">#B8C8DB</Color>

  <SolidColorBrush x:Key="CED.Brush.PrimaryBlue" Color="{StaticResource CED.Color.PrimaryBlue}"/>
  <SolidColorBrush x:Key="CED.Brush.SecondaryRed" Color="{StaticResource CED.Color.SecondaryRed}"/>
  <SolidColorBrush x:Key="CED.Brush.TertiaryGreen" Color="{StaticResource CED.Color.TertiaryGreen}"/>
  <SolidColorBrush x:Key="CED.Brush.NeutralDark" Color="{StaticResource CED.Color.NeutralDark}"/>
  <SolidColorBrush x:Key="CED.Brush.Surface" Color="{StaticResource CED.Color.Surface}"/>
  <SolidColorBrush x:Key="CED.Brush.SurfaceAlt" Color="{StaticResource CED.Color.SurfaceAlt}"/>
  <SolidColorBrush x:Key="CED.Brush.Border" Color="{StaticResource CED.Color.Border}"/>
  <SolidColorBrush x:Key="CED.Brush.WindowBackground" Color="#F2F3F5"/>
  <SolidColorBrush x:Key="CED.Brush.HeadingText" Color="#1F2E3D"/>
  <SolidColorBrush x:Key="CED.Brush.PrimaryText" Color="#1F2E3D"/>
  <SolidColorBrush x:Key="CED.Brush.SecondaryText" Color="#4A5866"/>
  <SolidColorBrush x:Key="CED.Brush.SearchBorder" Color="#B8C8DB"/>
  <SolidColorBrush x:Key="CED.Brush.SearchBackground" Color="#FFFFFF"/>
  <SolidColorBrush x:Key="CED.Brush.IconMuted" Color="#718091"/>
  <SolidColorBrush x:Key="CED.Brush.PlaceholderText" Color="#A1ADBA"/>
  <SolidColorBrush x:Key="CED.Brush.ListBorder" Color="#9CA9B6"/>
  <SolidColorBrush x:Key="CED.Brush.ListBackground" Color="#EEF1F4"/>
  <SolidColorBrush x:Key="CED.Brush.CardBorder" Color="#B4C0CD"/>
  <SolidColorBrush x:Key="CED.Brush.SelectionBadge" Color="#5F6F82"/>

  <Style TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.PrimaryBlue}"/>
    <Setter Property="Background" Value="White"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.PrimaryBlue}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="8,2"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="MinHeight" Value="28"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
    <Setter Property="VerticalContentAlignment" Value="Center"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Root"
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="6"
                  SnapsToDevicePixels="True">
            <ContentPresenter Margin="{TemplateBinding Padding}"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              RecognizesAccessKey="True"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource CED.Brush.SurfaceAlt}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Root" Property="Background" Value="{StaticResource CED.Brush.PrimaryBlue}"/>
              <Setter Property="Foreground" Value="White"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style TargetType="DataGridColumnHeader">
    <Setter Property="Background" Value="{StaticResource CED.Brush.SurfaceAlt}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
  </Style>

  <Style TargetType="GridViewColumnHeader">
    <Setter Property="Background" Value="{StaticResource CED.Brush.SurfaceAlt}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="0,0,1,1"/>
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="Padding" Value="8,6"/>
    <Setter Property="HorizontalContentAlignment" Value="Center"/>
  </Style>

  <Style TargetType="TextBox">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="Padding" Value="6,3"/>
  </Style>

  <Style TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.PrimaryText}"/>
  </Style>

  <Style TargetType="ListView">
    <Setter Property="Background" Value="{StaticResource CED.Brush.ListBackground}"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.ListBorder}"/>
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
  </Style>

  <Style TargetType="ListViewItem">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
  </Style>

  <Style TargetType="DataGrid">
    <Setter Property="Background" Value="White"/>
    <Setter Property="BorderBrush" Value="{StaticResource CED.Brush.Border}"/>
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
    <Setter Property="GridLinesVisibility" Value="Horizontal"/>
  </Style>

  <Style TargetType="DataGridRow">
    <Setter Property="Foreground" Value="{StaticResource CED.Brush.NeutralDark}"/>
    <Setter Property="Background" Value="White"/>
  </Style>
</ResourceDictionary>
