<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        Title="Quick Spare/Space"
        Height="300"
        Width="700"
        MinHeight="260"
        MinWidth="620"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CED.Brush.WindowBackground}">
  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,8">
      <TextBlock Text="Quick Spare/Space" Style="{DynamicResource CED.Text.Title}"/>
      <TextBlock Name="PanelInfoText"
                 Margin="0,2,0,0"
                 Text="Panel"
                 TextWrapping="Wrap"
                 Style="{DynamicResource CED.Text.Secondary}"/>
    </StackPanel>

    <Grid Grid.Row="2">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>
      <Border Grid.Column="0"
              Padding="8"
              BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
              BorderThickness="1"
              CornerRadius="4"
              Background="{DynamicResource CED.Brush.InfoPanelBackground}">
        <StackPanel Orientation="Vertical">
          <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Mode:"
                       Margin="0,0,8,0"
                       VerticalAlignment="Center"
                       Style="{DynamicResource CED.Text.Secondary}"
                       Foreground="{DynamicResource CED.Brush.PrimaryText}"/>
            <RadioButton Name="ModeFillRadio"
                         Content="Fill With"
                         GroupName="QuickMode"
                         IsChecked="True"
                         Foreground="{DynamicResource CED.Brush.PrimaryText}"
                         Margin="0,0,14,0"
                         Checked="quick_mode_changed"/>
            <RadioButton Name="ModeRemoveRadio"
                         Content="Remove All"
                         GroupName="QuickMode"
                         Foreground="{DynamicResource CED.Brush.PrimaryText}"
                         Checked="quick_mode_changed"/>
          </StackPanel>
          <StackPanel Orientation="Vertical">
            <Button Name="ActionSpareButton"
                    Style="{DynamicResource CED.Button.Base}"
                    Content="Spare"
                    Width="130"
                    Height="30"
                    Click="quick_spare_clicked"/>
            <Button Name="ActionSpaceButton"
                    Style="{DynamicResource CED.Button.Base}"
                    Content="Space"
                    Width="130"
                    Height="30"
                    Margin="0,6,0,0"
                    Click="quick_space_clicked"/>
            <Button Name="ActionBothButton"
                    Style="{DynamicResource CED.Button.Base}"
                    Content="Both"
                    Width="130"
                    Height="30"
                    Margin="0,6,0,0"
                    Click="quick_both_clicked"/>
          </StackPanel>
        </StackPanel>
      </Border>
      <StackPanel Grid.Column="1"
                  Margin="12,0,0,0"
                  VerticalAlignment="Top">
        <TextBlock Name="QuickGuidanceText"
                   TextWrapping="Wrap"
                   Style="{DynamicResource CED.Text.Secondary}"
                   Text="All available slots on selected panels will be filled with default spares/spaces."/>
        <TextBlock Name="QuickDefaultDefinitionText"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   Style="{DynamicResource CED.Text.Secondary}"
                   Text="Default spare/space definition:
- Unlocked
- No schedule notes
- Default load name
- Default rating"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
