<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sw="clr-namespace:System.Windows;assembly=PresentationFramework"
        Title="Add / Remove Spares and Spaces"
        Height="680"
        Width="880"
        MinHeight="520"
        MinWidth="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CED.Brush.WindowBackground}"
        PreviewMouseDown="window_preview_mouse_down">
  <Window.Resources>
    <SolidColorBrush x:Key="{x:Static sw:SystemColors.HighlightBrushKey}" Color="{DynamicResource CED.Color.CircuitItemSelectedBackground}"/>
    <SolidColorBrush x:Key="{x:Static sw:SystemColors.InactiveSelectionHighlightBrushKey}" Color="{DynamicResource CED.Color.CircuitItemSelectedBackground}"/>
    <SolidColorBrush x:Key="{x:Static sw:SystemColors.HighlightTextBrushKey}" Color="{DynamicResource CED.Color.PrimaryText}"/>
    <SolidColorBrush x:Key="{x:Static sw:SystemColors.InactiveSelectionHighlightTextBrushKey}" Color="{DynamicResource CED.Color.PrimaryText}"/>
  </Window.Resources>
  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0" Orientation="Vertical">
        <TextBlock Text="Add / Remove Spares and Spaces" Style="{DynamicResource CED.Text.Title}"/>
        <TextBlock Text="Stage add/remove actions by panel schedule, then apply once."
                   Style="{DynamicResource CED.Text.Secondary}"
                   Margin="0,2,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1"
                 Name="StatusText"
                 Text="Ready"
                 Style="{DynamicResource CED.Text.Secondary}"
                 VerticalAlignment="Bottom"/>
    </Grid>

    <Border Grid.Row="1"
            BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
            BorderThickness="1"
            Background="{DynamicResource CED.Brush.SearchBackground}">
      <DataGrid Name="PanelsList"
                Style="{DynamicResource CED.DataGrid.Base}"
                AutoGenerateColumns="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                Focusable="False"
                IsTabStop="False"
                CanUserAddRows="False"
                CanUserResizeRows="False"
                CanUserResizeColumns="True"
                HeadersVisibility="Column"
                RowHeaderWidth="0"
                GridLinesVisibility="Horizontal"
                EnableRowVirtualization="True"
                EnableColumnVirtualization="True"
                VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling"
                ScrollViewer.CanContentScroll="True"
                ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                ColumnHeaderStyle="{DynamicResource HeaderWrapCenter}"
                RowStyle="{DynamicResource CED.DataGrid.RowDisabledAware.NeutralSelection}"
                CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"
                SelectionChanged="grid_selection_changed"
                PreviewMouseDown="grid_preview_mouse_down">
        <DataGrid.Columns>
          <DataGridTemplateColumn Header="" Width="42" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <CheckBox IsChecked="{Binding is_checked, Mode=OneWay}"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Click="item_checkbox_clicked"/>
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
          <DataGridTextColumn Header="Panel Name" Width="3*" MinWidth="180" Binding="{Binding panel_name}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"/>
          <DataGridTextColumn Header="Part Type" Width="1.5*" MinWidth="120" Binding="{Binding part_type}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"/>
          <DataGridTextColumn Header="Dist. System" Width="2.5*" MinWidth="160" Binding="{Binding dist_system_name}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"/>
          <DataGridTextColumn Header="Open Slots" Width="1*" MinWidth="90" Binding="{Binding open_slots_text}" IsReadOnly="True" ElementStyle="{DynamicResource CenterTextCell}" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"/>
          <DataGridTextColumn Header="Action" Width="2*" MinWidth="150" Binding="{Binding action_text}" IsReadOnly="True" CellStyle="{DynamicResource ReadonlyCell.NeutralSelection}"/>
        </DataGrid.Columns>
      </DataGrid>
    </Border>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Top" Margin="0,0,10,2">
        <StackPanel Orientation="Horizontal">
          <Button Name="CheckAllButton"
                  Style="{DynamicResource CED.Button.Base}"
                  Content="Check All"
                  Width="76"
                  Height="24"
                  Click="check_all_clicked"/>
          <Button Name="UncheckAllButton"
                  Style="{DynamicResource CED.Button.Base}"
                  Content="Check None"
                  Width="84"
                  Height="24"
                  Margin="6,0,0,0"
                  Click="uncheck_all_clicked"/>
        </StackPanel>
        <TextBlock Name="CheckedStatusText"
                   Margin="2,4,0,0"
                   Style="{DynamicResource CED.Text.Secondary}"
                   Text="0 of 0 checked"/>
      </StackPanel>

      <Border Grid.Column="0"
              Width="1"
              Height="20"
              Margin="16,0,0,0"
              VerticalAlignment="Center"
              HorizontalAlignment="Right"
              Background="{DynamicResource CED.Brush.SectionDivider}"/>

      <Border Grid.Column="1"
              Padding="6,4"
              Margin="24,0,0,0"
              BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
              BorderThickness="1"
              CornerRadius="3"
              Background="{DynamicResource CED.Brush.InfoPanelBackground}">
        <StackPanel Orientation="Vertical">
          <TextBlock Text="Mode:" Margin="0,0,0,4" Style="{DynamicResource CED.Text.Secondary}" Foreground="{DynamicResource CED.Brush.PrimaryText}"/>
          <RadioButton Name="ModeSpareRadio" Content="Spare" GroupName="Mode" Foreground="{DynamicResource CED.Brush.PrimaryText}"/>
          <RadioButton Name="ModeSpaceRadio" Content="Space" GroupName="Mode" Foreground="{DynamicResource CED.Brush.PrimaryText}" Margin="0,2,0,0"/>
          <RadioButton Name="ModeBothRadio" Content="Both" GroupName="Mode" Foreground="{DynamicResource CED.Brush.PrimaryText}" IsChecked="True" Margin="0,2,0,0"/>
        </StackPanel>
      </Border>

      <StackPanel Grid.Column="2" Orientation="Vertical" Margin="8,0,0,0" VerticalAlignment="Top">
        <Button Name="StageAddButton"
                Style="{DynamicResource CED.Button.Base}"
                Content="Add"
                Width="72"
                Height="24"
                Click="stage_add_clicked"/>
        <Button Name="StageRemoveButton"
                Style="{DynamicResource CED.Button.Base}"
                Content="Remove"
                Width="72"
                Height="24"
                Margin="0,4,0,0"
                Click="stage_remove_clicked"/>
      </StackPanel>

      <Border Grid.Column="4"
              Width="1"
              Height="20"
              Margin="14,0,0,0"
              VerticalAlignment="Center"
              Background="{DynamicResource CED.Brush.SectionDivider}"/>

      <StackPanel Grid.Column="6" Orientation="Horizontal">
        <Button Name="ResetSelectedButton"
                Style="{DynamicResource CED.Button.Base}"
                Content="Reset Selected"
                Width="96"
                Height="24"
                Margin="0,0,10,0"
                Click="reset_selected_clicked"/>
        <TextBlock Name="StagedStatusText"
                   Style="{DynamicResource CED.Text.Secondary}"
                   VerticalAlignment="Center"
                   Margin="0,0,10,0"
                   Text="0 panel(s) staged"/>
        <Button Name="CancelButton"
                Style="{DynamicResource CED.Button.Base}"
                Content="Cancel"
                Width="90"
                Height="24"
                Click="cancel_clicked"/>
        <Button Name="ApplyButton"
                Style="{DynamicResource CED.Button.Apply}"
                Content="Apply"
                Width="90"
                Height="24"
                Margin="6,0,0,0"
                Click="apply_clicked"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
