<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Circuit Properties"
        Height="760"
        Width="880"
        MinHeight="560"
        MinWidth="880"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource CED.Brush.WindowBackground}">
  <Window.Resources>
    <Style x:Key="EditorCard" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.ListItemBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.CardBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="4"/>
      <Setter Property="Padding" Value="10"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>
    <Style x:Key="EditorLabel" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>
    <Style x:Key="EditorInputText" TargetType="TextBox">
      <Setter Property="Height" Value="24"/>
      <Setter Property="Padding" Value="4,1"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3"
                    Padding="{TemplateBinding Padding}"
                    SnapsToDevicePixels="True">
              <ScrollViewer x:Name="PART_ContentHost" Margin="0" VerticalAlignment="Center"/>
            </Border>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <Trigger Property="IsEnabled" Value="False">
          <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
          <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
          <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
          <Setter Property="Opacity" Value="0.55"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EditorNumericText" TargetType="TextBox" BasedOn="{StaticResource EditorInputText}">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
    </Style>
    <Style x:Key="EditorComboScrollThumb" TargetType="Thumb">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.IconMuted}"/>
      <Setter Property="Opacity" Value="0.72"/>
      <Setter Property="MinHeight" Value="10"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Thumb">
            <Border x:Name="ThumbPill" Background="{TemplateBinding Background}" CornerRadius="3"/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbPill" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbPill" Property="Opacity" Value="0.98"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <Style x:Key="EditorComboScrollTrackButton" TargetType="RepeatButton">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RepeatButton">
            <Border x:Name="TrackHit" Background="{TemplateBinding Background}" CornerRadius="3"/>
            <ControlTemplate.Triggers>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="TrackHit" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
    <ControlTemplate x:Key="EditorComboScrollBar.Template.Vertical" TargetType="ScrollBar">
      <Border Background="{DynamicResource CED.Brush.WindowBackground}" Opacity="0.18" CornerRadius="3" Width="8">
        <Track x:Name="PART_Track"
               IsDirectionReversed="True"
               Margin="1"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
          <Track.DecreaseRepeatButton>
            <RepeatButton Style="{StaticResource EditorComboScrollTrackButton}" Command="ScrollBar.PageUpCommand"/>
          </Track.DecreaseRepeatButton>
          <Track.Thumb>
            <Thumb Style="{StaticResource EditorComboScrollThumb}"/>
          </Track.Thumb>
          <Track.IncreaseRepeatButton>
            <RepeatButton Style="{StaticResource EditorComboScrollTrackButton}" Command="ScrollBar.PageDownCommand"/>
          </Track.IncreaseRepeatButton>
        </Track>
      </Border>
    </ControlTemplate>
    <ControlTemplate x:Key="EditorComboScrollBar.Template.Horizontal" TargetType="ScrollBar">
      <Border Background="{DynamicResource CED.Brush.WindowBackground}" Opacity="0.18" CornerRadius="3" Height="8">
        <Track x:Name="PART_Track"
               IsDirectionReversed="False"
               Margin="1"
               Minimum="{TemplateBinding Minimum}"
               Maximum="{TemplateBinding Maximum}"
               Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
               ViewportSize="{TemplateBinding ViewportSize}">
          <Track.DecreaseRepeatButton>
            <RepeatButton Style="{StaticResource EditorComboScrollTrackButton}" Command="ScrollBar.PageLeftCommand"/>
          </Track.DecreaseRepeatButton>
          <Track.Thumb>
            <Thumb Style="{StaticResource EditorComboScrollThumb}"/>
          </Track.Thumb>
          <Track.IncreaseRepeatButton>
            <RepeatButton Style="{StaticResource EditorComboScrollTrackButton}" Command="ScrollBar.PageRightCommand"/>
          </Track.IncreaseRepeatButton>
        </Track>
      </Border>
    </ControlTemplate>
    <Style x:Key="EditorComboScrollBar" TargetType="ScrollBar">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Width" Value="10"/>
      <Setter Property="MinWidth" Value="10"/>
      <Setter Property="Template" Value="{StaticResource EditorComboScrollBar.Template.Vertical}"/>
      <Style.Triggers>
        <Trigger Property="Orientation" Value="Horizontal">
          <Setter Property="Height" Value="10"/>
          <Setter Property="MinHeight" Value="10"/>
          <Setter Property="Template" Value="{StaticResource EditorComboScrollBar.Template.Horizontal}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <ControlTemplate x:Key="EditorComboTemplate" TargetType="ComboBox">
      <Grid SnapsToDevicePixels="True">
        <Border x:Name="ComboBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="26"/>
            </Grid.ColumnDefinitions>
            <ContentPresenter Grid.Column="0"
                              Margin="6,0,6,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
            <Path Grid.Column="1"
                  Data="{DynamicResource CED.Icon.ChevronDown}"
                  Width="8"
                  Height="6"
                  Stretch="Uniform"
                  Fill="{DynamicResource CED.Brush.IconMuted}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
            <ToggleButton Grid.ColumnSpan="2"
                          Style="{DynamicResource CED.Input.ComboBox.ToggleOverlay}"
                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                          ClickMode="Press"/>
            <Border x:Name="ComboStateOverlay"
                    Grid.ColumnSpan="2"
                    Background="Transparent"
                    CornerRadius="6"
                    IsHitTestVisible="False"/>
          </Grid>
        </Border>
        <Popup Name="PART_Popup"
               AllowsTransparency="True"
               Focusable="False"
               IsOpen="{TemplateBinding IsDropDownOpen}"
               Placement="Bottom"
               PopupAnimation="Slide">
          <Border x:Name="DropDownBorder"
                  Margin="0,2,0,0"
                  Background="{DynamicResource CED.Brush.ListBackground}"
                  BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                  BorderThickness="1"
                  CornerRadius="6"
                  MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
            <ScrollViewer MaxHeight="300"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource EditorComboScrollBar}"/>
              </ScrollViewer.Resources>
              <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
            </ScrollViewer>
          </Border>
        </Popup>
      </Grid>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
        </Trigger>
        <Trigger Property="IsKeyboardFocusWithin" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
        </Trigger>
        <Trigger Property="IsDropDownOpen" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
        </Trigger>
        <Trigger Property="HasItems" Value="False">
          <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <ControlTemplate x:Key="EditorComboTemplate.CenteredValue" TargetType="ComboBox">
      <Grid SnapsToDevicePixels="True">
        <Border x:Name="ComboBorder"
                Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="6">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="26"/>
            </Grid.ColumnDefinitions>
            <ContentPresenter Grid.Column="0"
                              Margin="6,0,4,0"
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Content="{TemplateBinding SelectionBoxItem}"
                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
            <Path Grid.Column="1"
                  Data="{DynamicResource CED.Icon.ChevronDown}"
                  Width="8"
                  Height="6"
                  Stretch="Uniform"
                  Fill="{DynamicResource CED.Brush.IconMuted}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"/>
            <ToggleButton Grid.ColumnSpan="2"
                          Style="{DynamicResource CED.Input.ComboBox.ToggleOverlay}"
                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                          ClickMode="Press"/>
            <Border x:Name="ComboStateOverlay"
                    Grid.ColumnSpan="2"
                    Background="Transparent"
                    CornerRadius="6"
                    IsHitTestVisible="False"/>
          </Grid>
        </Border>
        <Popup Name="PART_Popup"
               AllowsTransparency="True"
               Focusable="False"
               IsOpen="{TemplateBinding IsDropDownOpen}"
               Placement="Bottom"
               PopupAnimation="Slide">
          <Border x:Name="DropDownBorder"
                  Margin="0,2,0,0"
                  Background="{DynamicResource CED.Brush.ListBackground}"
                  BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                  BorderThickness="1"
                  CornerRadius="6"
                  MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
            <ScrollViewer MaxHeight="300"
                          CanContentScroll="True"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ScrollViewer.Resources>
                <Style TargetType="ScrollBar" BasedOn="{StaticResource EditorComboScrollBar}"/>
              </ScrollViewer.Resources>
              <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
            </ScrollViewer>
          </Border>
        </Popup>
      </Grid>
      <ControlTemplate.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
        </Trigger>
        <Trigger Property="IsKeyboardFocusWithin" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
        </Trigger>
        <Trigger Property="IsDropDownOpen" Value="True">
          <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
          <Setter TargetName="ComboStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
        </Trigger>
        <Trigger Property="HasItems" Value="False">
          <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24"/>
        </Trigger>
        <Trigger Property="IsEnabled" Value="False">
          <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55"/>
        </Trigger>
      </ControlTemplate.Triggers>
    </ControlTemplate>
    <Style x:Key="EditorCombo" TargetType="ComboBox">
      <Setter Property="Height" Value="24"/>
      <Setter Property="MinWidth" Value="74"/>
      <Setter Property="Padding" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Border}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="ItemContainerStyle" Value="{DynamicResource CED.Input.ComboBoxItem.Flat}"/>
      <Setter Property="Template" Value="{StaticResource EditorComboTemplate}"/>
    </Style>
    <Style x:Key="EditorCombo.CenteredValue" TargetType="ComboBox" BasedOn="{StaticResource EditorCombo}">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Template" Value="{StaticResource EditorComboTemplate.CenteredValue}"/>
    </Style>

    <Style x:Key="EditorState.Text.Readonly" TargetType="TextBox" BasedOn="{StaticResource EditorNumericText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style x:Key="EditorState.Text.Auto" TargetType="TextBox" BasedOn="{StaticResource EditorNumericText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridEditableBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridDividerStrong}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
        </Trigger>
        <Trigger Property="IsKeyboardFocusWithin" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EditorState.Text.Manual" TargetType="TextBox" BasedOn="{StaticResource EditorNumericText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoAccentBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.AccentBlue}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="EditorState.Input.Readonly" TargetType="TextBox" BasedOn="{StaticResource EditorInputText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Opacity" Value="0.55"/>
    </Style>
    <Style x:Key="EditorState.Input.Auto" TargetType="TextBox" BasedOn="{StaticResource EditorInputText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridEditableBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridDividerStrong}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
        </Trigger>
        <Trigger Property="IsKeyboardFocusWithin" Value="True">
          <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.Accent}"/>
        </Trigger>
      </Style.Triggers>
    </Style>
    <Style x:Key="EditorState.Input.Manual" TargetType="TextBox" BasedOn="{StaticResource EditorInputText}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoAccentBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.AccentBlue}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>

    <Style x:Key="EditorState.Combo.Readonly" TargetType="ComboBox" BasedOn="{StaticResource EditorCombo}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style x:Key="EditorState.Combo.Auto" TargetType="ComboBox" BasedOn="{StaticResource EditorCombo}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.DataGridEditableBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridDividerStrong}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style x:Key="EditorState.Combo.Manual" TargetType="ComboBox" BasedOn="{StaticResource EditorCombo}">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoAccentBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.AccentBlue}"/>
      <Setter Property="BorderThickness" Value="2"/>
    </Style>
    <Style x:Key="EditorState.Combo.Center.Readonly" TargetType="ComboBox" BasedOn="{StaticResource EditorState.Combo.Readonly}">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Template" Value="{StaticResource EditorComboTemplate.CenteredValue}"/>
    </Style>
    <Style x:Key="EditorState.Combo.Center.Auto" TargetType="ComboBox" BasedOn="{StaticResource EditorState.Combo.Auto}">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Template" Value="{StaticResource EditorComboTemplate.CenteredValue}"/>
    </Style>
    <Style x:Key="EditorState.Combo.Center.Manual" TargetType="ComboBox" BasedOn="{StaticResource EditorState.Combo.Manual}">
      <Setter Property="HorizontalContentAlignment" Value="Center"/>
      <Setter Property="Template" Value="{StaticResource EditorComboTemplate.CenteredValue}"/>
    </Style>
    <Style x:Key="EditorRadio" TargetType="RadioButton">
      <Setter Property="Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
      <Setter Property="Margin" Value="0,0,10,0"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>
    <Style x:Key="PreviewValueBox" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource CED.Brush.InfoPanelBackground}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.InfoPanelBorder}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="3"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
      <Setter Property="TextElement.Foreground" Value="{DynamicResource CED.Brush.PrimaryText}"/>
    </Style>
  </Window.Resources>

  <Grid Margin="{DynamicResource CED.Thickness.ContentMargin}">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid Grid.Row="0" Margin="0,0,0,8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Grid.Column="0">
        <TextBlock Text="Edit Circuit Properties" Style="{DynamicResource CED.Text.Title}"/>
        <TextBlock Text="Stage per-circuit overrides, preview recalculated values, then apply all changes."
                   Style="{DynamicResource CED.Text.Secondary}" Margin="0,2,0,0"/>
      </StackPanel>
      <TextBlock Grid.Column="1" Name="PendingCountText" Text="0 circuits pending"
                 Style="{DynamicResource CED.Text.Secondary}" VerticalAlignment="Bottom"/>
    </Grid>

    <Grid Grid.Row="1">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" MinWidth="180"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="620"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              BorderBrush="{DynamicResource CED.Brush.DataGridBorder}"
              BorderThickness="1"
              Background="{DynamicResource CED.Brush.ListBackground}">
        <ListView Name="CircuitList"
                  Style="{DynamicResource CED.ListView.Alerts}"
                  SelectionMode="Single"
                  SelectionChanged="circuit_selection_changed"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling"
                  ScrollViewer.CanContentScroll="True">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="{DynamicResource CED.Brush.CardBorder}"
                      BorderThickness="0,0,0,1"
                      Background="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Background}"
                      Padding="8,6">
                <StackPanel>
                  <TextBlock Text="{Binding panel_ckt_text}"
                             FontWeight="Bold"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <TextBlock Text="{Binding load_name}"
                             FontSize="11"
                             Opacity="0.92"
                             TextTrimming="CharacterEllipsis"
                             Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                  <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding branch_type}"
                               FontSize="10"
                               Opacity="0.88"
                               Foreground="{Binding RelativeSource={RelativeSource AncestorType=ListViewItem}, Path=Foreground}"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding status_text}"
                               HorizontalAlignment="Right"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Visibility="{Binding status_visibility}">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Foreground" Value="{DynamicResource CED.Brush.AccentGreen}"/>
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding status_text}" Value="Locked">
                              <Setter Property="Foreground" Value="{DynamicResource CED.Brush.AccentRed}"/>
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <Grid Grid.Column="2" Name="EditorPanelRoot">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,8">
          <TextBlock Name="SelectedCircuitText"
                     Text="Select a circuit"
                     Style="{DynamicResource CED.Text.SectionHeader}"/>
          <TextBlock Name="UnsupportedText"
                     Text="Unsupported circuit type. Editing is disabled."
                     Style="{DynamicResource CED.Text.Secondary}"
                     Foreground="{DynamicResource CED.Brush.AccentRed}"
                     Visibility="Collapsed"
                     Margin="0,2,0,0"/>
          <TextBox Name="BlockedInfoTextBox"
                   Visibility="Collapsed"
                   Margin="0,4,0,0"
                   IsReadOnly="True"
                   TextWrapping="Wrap"
                   Style="{StaticResource EditorInputText}"
                   Background="{DynamicResource CED.Brush.InfoPanelBackground}"
                   BorderBrush="{DynamicResource CED.Brush.InfoPanelBorder}"
                   Foreground="{DynamicResource CED.Brush.DataGridReadOnlyForeground}"/>
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="{DynamicResource CED.Brush.ListBorder}"
                BorderThickness="1"
                Background="{DynamicResource CED.Brush.ListBackground}"
                CornerRadius="4">
          <ScrollViewer VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled"
                        Padding="10">
            <StackPanel>
              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Calculation Preview" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="74"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="90"/>
                      <ColumnDefinition Width="14"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="74"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Load Current" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="1" Name="PreviewLoadCurrentBox" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewLoadCurrentText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                    <TextBlock Grid.Column="3" Text="Ampacity" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="4" Name="PreviewAmpacityBox" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewAmpacityText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                    <TextBlock Grid.Column="6" Text="VD" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="7" Name="PreviewVoltageDropBox" Style="{StaticResource PreviewValueBox}">
                      <TextBlock Name="PreviewVoltageDropText" Text="-" Style="{DynamicResource CED.Text.Primary}"/>
                    </Border>
                  </Grid>
                  <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="8"/>
                      <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource PreviewValueBox}">
                      <StackPanel>
                        <TextBlock Text="Conduit &amp; Wire String" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                        <TextBlock Name="PreviewConduitSummaryText" Text="-" Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PreviewValueBox}">
                      <StackPanel>
                        <TextBlock Text="Wire String" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                        <TextBlock Name="PreviewWireSummaryText" Text="-" Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                      </StackPanel>
                    </Border>
                  </Grid>
                  <Border Name="PreviewNoticeBox" Style="{StaticResource PreviewValueBox}">
                    <StackPanel>
                      <TextBlock Text="Warnings" Style="{DynamicResource CED.Text.CaptionStrong}"/>
                      <TextBlock Name="PreviewNoticeText" Text="No warnings." Style="{DynamicResource CED.Text.Primary}" TextWrapping="Wrap"/>
                    </StackPanel>
                  </Border>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Circuit Properties" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid Grid.IsSharedSizeScope="True">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropLeftLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Name" Style="{StaticResource EditorLabel}"/>
                      <TextBox Grid.Column="2"
                               Name="LoadNameTextBox"
                               HorizontalAlignment="Stretch"
                               HorizontalContentAlignment="Left"
                               Style="{StaticResource EditorInputText}"
                               LostFocus="editable_value_changed"/>
                    </Grid>
                    <Grid Grid.Row="0" Grid.Column="4">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightValueCol"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Sched Notes" Style="{StaticResource EditorLabel}"/>
                      <TextBox Grid.Column="2"
                               Name="ScheduleNotesTextBox"
                               Width="78"
                               HorizontalAlignment="Left"
                               Style="{StaticResource EditorInputText}"
                               LostFocus="editable_value_changed"/>
                    </Grid>

                    <Grid Grid.Row="1" Grid.Column="0" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropLeftLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Type" Style="{StaticResource EditorLabel}"/>
                      <Border Grid.Column="2" Style="{StaticResource PreviewValueBox}" Margin="0">
                        <TextBlock Name="CircuitTypeText" Text="-" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                      </Border>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="2" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropMidLabelCol"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="78" SharedSizeGroup="CircuitPropMidValueCol"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Rating (A)" Style="{StaticResource EditorLabel}"/>
                      <TextBox Grid.Column="2"
                               Name="RatingTextBox"
                               Width="78"
                               HorizontalAlignment="Right"
                               Style="{StaticResource EditorNumericText}"
                               LostFocus="editable_value_changed"/>
                    </Grid>
                    <Grid Grid.Row="1" Grid.Column="4" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightValueCol"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Length Makeup (+/-)" Style="{StaticResource EditorLabel}"/>
                      <TextBox Grid.Column="2"
                               Name="LengthMakeupTextBox"
                               Width="78"
                               HorizontalAlignment="Left"
                               Style="{StaticResource EditorInputText}"
                               HorizontalContentAlignment="Left"
                               LostFocus="editable_value_changed"/>
                    </Grid>

                    <Grid Grid.Row="2" Grid.Column="0" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropLeftLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Volts" Style="{StaticResource EditorLabel}"/>
                      <Border Grid.Column="2" Style="{StaticResource PreviewValueBox}" Margin="0">
                        <TextBlock Name="VoltsText" Text="-" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                      </Border>
                    </Grid>
                    <Grid Grid.Row="2" Grid.Column="2" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropMidLabelCol"/>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="78" SharedSizeGroup="CircuitPropMidValueCol"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Frame (A)" Style="{StaticResource EditorLabel}"/>
                      <TextBox Grid.Column="2"
                               Name="FrameTextBox"
                               Width="78"
                               HorizontalAlignment="Right"
                               Style="{StaticResource EditorNumericText}"
                               LostFocus="editable_value_changed"/>
                    </Grid>
                    <Grid Grid.Row="2" Grid.Column="4" Margin="0,6,0,0">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightLabelCol"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto" SharedSizeGroup="CircuitPropRightValueCol"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Grid.Column="0" Text="Total Length" Style="{DynamicResource CED.Text.Secondary}"/>
                      <Border Grid.Column="2" Style="{StaticResource PreviewValueBox}" Margin="0" Width="78" HorizontalAlignment="Left">
                        <TextBlock Name="TotalLengthText" Text="-" HorizontalAlignment="Left" Margin="4,0,0,0"/>
                      </Border>
                    </Grid>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Wire Properties" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="90"/>
                      <ColumnDefinition Width="12"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="98"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Material" Style="{StaticResource EditorLabel}"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                      <RadioButton Name="WireMaterialCuRadio"
                                   GroupName="WireMaterial"
                                   Content="CU"
                                   Style="{StaticResource EditorRadio}"
                                   Checked="editable_value_changed"/>
                      <RadioButton Name="WireMaterialAlRadio"
                                   GroupName="WireMaterial"
                                   Content="AL"
                                   Style="{StaticResource EditorRadio}"
                                   Checked="editable_value_changed"/>
                    </StackPanel>

                    <TextBlock Grid.Column="3" Text="Temperature" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="4" Name="WireTempCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>

                    <TextBlock Grid.Column="6" Text="Insulation" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="7" Name="WireInsulationCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Override Mode" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <WrapPanel>
                    <CheckBox Name="UserOverrideCheck"
                              Content="User Override"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="user_override_changed"
                              Unchecked="user_override_changed"/>
                    <CheckBox Name="CustomHotCheck"
                              Content="Include Hot"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="hot_custom_changed"
                              Unchecked="hot_custom_changed"/>
                    <CheckBox Name="CustomGroundCheck"
                              Content="Include Ground"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Margin="0,0,16,0"
                              Checked="ground_custom_changed"
                              Unchecked="ground_custom_changed"/>
                    <CheckBox Name="CustomConduitCheck"
                              Content="Include Conduit"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="conduit_custom_changed"
                              Unchecked="conduit_custom_changed"/>
                  </WrapPanel>
                  <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Name="NeutralBehaviorText" Style="{DynamicResource CED.Text.Secondary}" Margin="0,0,16,0"/>
                    <TextBlock Name="IgBehaviorText" Style="{DynamicResource CED.Text.Secondary}"/>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel Grid.IsSharedSizeScope="True">
                  <TextBlock Text="Wire Overrides" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" SharedSizeGroup="WireOverrideLabelCol"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                      <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Conductor" Style="{StaticResource EditorLabel}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Hot" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Neutral" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Ground" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Row="0" Grid.Column="7" Text="Isolated Ground" Style="{StaticResource EditorLabel}" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Size" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Name="HotSizeCombo" Style="{StaticResource EditorCombo.CenteredValue}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="3" Name="NeutralSizeCombo" Style="{StaticResource EditorCombo.CenteredValue}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="5" Name="GroundSizeCombo" Style="{StaticResource EditorCombo.CenteredValue}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>
                    <ComboBox Grid.Row="1" Grid.Column="7" Name="IgSizeCombo" Style="{StaticResource EditorCombo.CenteredValue}" Margin="0,6,0,0" SelectionChanged="editable_value_changed"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Include" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Name="HotIncludeStateText" Text="Yes" Style="{DynamicResource CED.Text.Secondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <CheckBox Grid.Row="2" Grid.Column="3"
                              Name="IncludeNeutralCheck"
                              Content="Include"
                              HorizontalAlignment="Center"
                              Margin="0,6,0,0"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="include_neutral_changed"
                              Unchecked="include_neutral_changed"/>
                    <TextBlock Grid.Row="2" Grid.Column="5" Name="GroundIncludeStateText" Text="Yes" Style="{DynamicResource CED.Text.Secondary}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                    <CheckBox Grid.Row="2" Grid.Column="7"
                              Name="IncludeIGCheck"
                              Content="Include"
                              HorizontalAlignment="Center"
                              Margin="0,6,0,0"
                              Style="{DynamicResource CED.Input.CheckBox}"
                              Checked="include_ig_changed"
                              Unchecked="include_ig_changed"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Quantity" Style="{StaticResource EditorLabel}" Margin="0,6,6,0"/>
                    <Border Grid.Row="3" Grid.Column="1" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="HotQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="3" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="NeutralQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="5" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="GroundQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                    <Border Grid.Row="3" Grid.Column="7" Style="{StaticResource PreviewValueBox}" Margin="0,6,0,0">
                      <TextBlock Name="IgQtyValueText" Text="0" HorizontalAlignment="Center"/>
                    </Border>
                  </Grid>
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto" SharedSizeGroup="WireOverrideLabelCol"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="92"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="# Sets" Style="{StaticResource EditorLabel}" Margin="0,0,6,0"/>
                    <TextBox Grid.Column="1" Name="NumberSetsTextBox" Style="{StaticResource EditorNumericText}" LostFocus="editable_value_changed"/>
                  </Grid>
                </StackPanel>
              </Border>

              <Border Style="{StaticResource EditorCard}">
                <StackPanel>
                  <TextBlock Text="Conduit Overrides" Style="{DynamicResource CED.Text.SectionHeader}" Margin="0,0,0,6"/>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="92"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="96"/>
                      <ColumnDefinition Width="16"/>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="76"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Conduit Size" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="1" Name="ConduitSizeCombo" Style="{StaticResource EditorCombo.CenteredValue}" SelectionChanged="editable_value_changed"/>
                    <TextBlock Grid.Column="3" Text="Conduit Type" Style="{StaticResource EditorLabel}"/>
                    <ComboBox Grid.Column="4" Name="ConduitTypeCombo" Style="{StaticResource EditorCombo}" SelectionChanged="editable_value_changed"/>
                    <TextBlock Grid.Column="6" Text="Conduit Fill" Style="{StaticResource EditorLabel}"/>
                    <Border Grid.Column="7" Name="ConduitFillBox" Style="{StaticResource PreviewValueBox}" Margin="0">
                      <TextBlock Name="ConduitFillText" Text="-" HorizontalAlignment="Center"/>
                    </Border>
                  </Grid>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </Border>
      </Grid>
    </Grid>

    <Grid Grid.Row="2" Margin="0,8,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Name="StatusText" Text="Ready" Style="{DynamicResource CED.Text.Secondary}" VerticalAlignment="Center"/>
      <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
        <Button Name="ResetButton" Style="{DynamicResource CED.Button.Base}" Content="Reset" Width="90" Height="28" Click="reset_clicked" IsEnabled="False"/>
        <Button Style="{DynamicResource CED.Button.Base}" Content="Cancel" Width="90" Height="28" Margin="8,0,0,0" Click="cancel_clicked"/>
        <Button Style="{DynamicResource CED.Button.Apply}" Content="Apply" Width="90" Height="28" Margin="8,0,0,0" Click="apply_clicked"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
