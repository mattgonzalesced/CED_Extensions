<Page xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
      Background="#EEEEEE">
  <Page.Resources>
    <ResourceDictionary>
      <Style x:Key="CircuitBrowser.ScrollBar.Menu.Thumb" TargetType="{x:Type primitives:Thumb}">
        <Setter Property="Background" Value="{DynamicResource CED.Brush.IconMuted}"/>
        <Setter Property="MinHeight" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Opacity" Value="0.45"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type primitives:Thumb}">
              <Border x:Name="Pill" Background="{TemplateBinding Background}" CornerRadius="4"/>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Pill" Property="Opacity" Value="0.68"/>
                </Trigger>
                <Trigger Property="IsMouseCaptured" Value="True">
                  <Setter TargetName="Pill" Property="Opacity" Value="0.86"/>
                </Trigger>
                <Trigger Property="IsDragging" Value="True">
                  <Setter TargetName="Pill" Property="Opacity" Value="0.86"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="CircuitBrowser.ScrollBar.Menu.Button" TargetType="{x:Type primitives:RepeatButton}">
        <Setter Property="Background" Value="{DynamicResource CED.Brush.SearchBackground}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource CED.Brush.DataGridCellBorder}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
          <Setter.Value>
            <ControlTemplate TargetType="{x:Type primitives:RepeatButton}">
              <Border x:Name="Root"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="3">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
              </Border>
              <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                  <Setter TargetName="Root" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayPressed}"/>
                </Trigger>
              </ControlTemplate.Triggers>
            </ControlTemplate>
          </Setter.Value>
        </Setter>
      </Style>
      <Style x:Key="CircuitBrowser.ScrollBar.Menu.TrackButton" TargetType="{x:Type primitives:RepeatButton}" BasedOn="{StaticResource CircuitBrowser.ScrollBar.Menu.Button}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
      </Style>
      <ControlTemplate x:Key="CircuitBrowser.ScrollBar.Menu.Template.Vertical" TargetType="{x:Type ScrollBar}">
        <Grid Background="Transparent">
          <Grid.RowDefinitions>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
          </Grid.RowDefinitions>
          <primitives:RepeatButton Grid.Row="0"
                                   Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Button}"
                                   Command="ScrollBar.LineUpCommand">
            <Viewbox Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Data="M1,7 L4,3 L7,7 Z"
                    Fill="{DynamicResource CED.Brush.IconMuted}"
                    Stretch="Fill"/>
            </Viewbox>
          </primitives:RepeatButton>
          <Border x:Name="TrackChrome"
                  Grid.Row="1"
                  Margin="0"
                  Background="{DynamicResource CED.Brush.SearchBackground}"
                  BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
                  BorderThickness="1"
                  CornerRadius="4">
            <Grid>
              <Border x:Name="TrackStateOverlay" Background="Transparent" CornerRadius="4"/>
              <primitives:Track x:Name="PART_Track"
                                IsDirectionReversed="True"
                                HorizontalAlignment="Center"
                                Width="8"
                                Margin="0"
                                Minimum="{TemplateBinding Minimum}"
                                Maximum="{TemplateBinding Maximum}"
                                Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                ViewportSize="{TemplateBinding ViewportSize}">
                <primitives:Track.DecreaseRepeatButton>
                  <primitives:RepeatButton Style="{StaticResource CircuitBrowser.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageUpCommand"/>
                </primitives:Track.DecreaseRepeatButton>
                <primitives:Track.Thumb>
                  <primitives:Thumb Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Thumb}"/>
                </primitives:Track.Thumb>
                <primitives:Track.IncreaseRepeatButton>
                  <primitives:RepeatButton Style="{StaticResource CircuitBrowser.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageDownCommand"/>
                </primitives:Track.IncreaseRepeatButton>
              </primitives:Track>
            </Grid>
          </Border>
          <primitives:RepeatButton Grid.Row="2"
                                   Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Button}"
                                   Command="ScrollBar.LineDownCommand">
            <Viewbox Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Data="M1,3 L4,7 L7,3 Z"
                    Fill="{DynamicResource CED.Brush.IconMuted}"
                    Stretch="Fill"/>
            </Viewbox>
          </primitives:RepeatButton>
        </Grid>
        <ControlTemplate.Triggers>
          <Trigger SourceName="PART_Track" Property="IsMouseOver" Value="True">
            <Setter TargetName="TrackStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
          </Trigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
      <ControlTemplate x:Key="CircuitBrowser.ScrollBar.Menu.Template.Horizontal" TargetType="{x:Type ScrollBar}">
        <Grid Background="Transparent">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
          </Grid.ColumnDefinitions>
          <primitives:RepeatButton Grid.Column="0"
                                   Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Button}"
                                   Command="ScrollBar.LineLeftCommand">
            <Viewbox Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Data="M7,1 L3,4 L7,7 Z"
                    Fill="{DynamicResource CED.Brush.IconMuted}"
                    Stretch="Fill"/>
            </Viewbox>
          </primitives:RepeatButton>
          <Border x:Name="TrackChrome"
                  Grid.Column="1"
                  Margin="0"
                  Background="{DynamicResource CED.Brush.SearchBackground}"
                  BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
                  BorderThickness="1"
                  CornerRadius="4">
            <Grid>
              <Border x:Name="TrackStateOverlay" Background="Transparent" CornerRadius="4"/>
              <primitives:Track x:Name="PART_Track"
                                IsDirectionReversed="False"
                                VerticalAlignment="Center"
                                Height="8"
                                Margin="0"
                                Minimum="{TemplateBinding Minimum}"
                                Maximum="{TemplateBinding Maximum}"
                                Value="{Binding Value, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                ViewportSize="{TemplateBinding ViewportSize}">
                <primitives:Track.DecreaseRepeatButton>
                  <primitives:RepeatButton Style="{StaticResource CircuitBrowser.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageLeftCommand"/>
                </primitives:Track.DecreaseRepeatButton>
                <primitives:Track.Thumb>
                  <primitives:Thumb Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Thumb}"/>
                </primitives:Track.Thumb>
                <primitives:Track.IncreaseRepeatButton>
                  <primitives:RepeatButton Style="{StaticResource CircuitBrowser.ScrollBar.Menu.TrackButton}" Command="ScrollBar.PageRightCommand"/>
                </primitives:Track.IncreaseRepeatButton>
              </primitives:Track>
            </Grid>
          </Border>
          <primitives:RepeatButton Grid.Column="2"
                                   Style="{StaticResource CircuitBrowser.ScrollBar.Menu.Button}"
                                   Command="ScrollBar.LineRightCommand">
            <Viewbox Width="8" Height="8" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Path Data="M3,1 L7,4 L3,7 Z"
                    Fill="{DynamicResource CED.Brush.IconMuted}"
                    Stretch="Fill"/>
            </Viewbox>
          </primitives:RepeatButton>
        </Grid>
        <ControlTemplate.Triggers>
          <Trigger SourceName="PART_Track" Property="IsMouseOver" Value="True">
            <Setter TargetName="TrackStateOverlay" Property="Background" Value="{DynamicResource CED.Brush.ButtonStateOverlayHover}"/>
          </Trigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
      <Style x:Key="CircuitBrowser.ScrollBar.Menu" TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource CED.Brush.IconMuted}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Width" Value="9"/>
        <Setter Property="Height" Value="Auto"/>
        <Setter Property="MinWidth" Value="9"/>
        <Setter Property="MinHeight" Value="9"/>
        <Setter Property="Template" Value="{StaticResource CircuitBrowser.ScrollBar.Menu.Template.Vertical}"/>
        <Style.Triggers>
          <Trigger Property="Orientation" Value="Horizontal">
            <Setter Property="Height" Value="9"/>
            <Setter Property="Width" Value="Auto"/>
            <Setter Property="MinHeight" Value="9"/>
            <Setter Property="Template" Value="{StaticResource CircuitBrowser.ScrollBar.Menu.Template.Horizontal}"/>
          </Trigger>
        </Style.Triggers>
      </Style>
      <ControlTemplate x:Key="CircuitBrowser.ScrollViewer.Overlay.Template" TargetType="{x:Type ScrollViewer}">
        <Grid Background="{TemplateBinding Background}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <ScrollContentPresenter x:Name="PART_ScrollContentPresenter"
                                  Grid.Row="0"
                                  Grid.Column="0"
                                  CanContentScroll="{TemplateBinding CanContentScroll}"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}"
                                  Margin="{TemplateBinding Padding}"/>
          <ScrollBar x:Name="PART_VerticalScrollBar"
                     Grid.Row="0"
                     Grid.Column="1"
                     Orientation="Vertical"
                     Margin="1,1,1,1"
                     Maximum="{TemplateBinding ScrollableHeight}"
                     ViewportSize="{TemplateBinding ViewportHeight}"
                     Value="{TemplateBinding VerticalOffset}"
                     Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                     Style="{StaticResource CircuitBrowser.ScrollBar.Menu}"/>
          <ScrollBar x:Name="PART_HorizontalScrollBar"
                     Grid.Row="1"
                     Grid.Column="0"
                     Orientation="Horizontal"
                     Margin="1,1,1,1"
                     Maximum="{TemplateBinding ScrollableWidth}"
                     ViewportSize="{TemplateBinding ViewportWidth}"
                     Value="{TemplateBinding HorizontalOffset}"
                     Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"
                     Style="{StaticResource CircuitBrowser.ScrollBar.Menu}"/>
          <Border x:Name="PART_Corner"
                  Grid.Row="1"
                  Grid.Column="1"
                  Background="{DynamicResource CED.Brush.ListBackground}"
                  BorderBrush="{DynamicResource CED.Brush.DataGridCellBorder}"
                  BorderThickness="1"
                  Visibility="Collapsed"/>
        </Grid>
        <ControlTemplate.Triggers>
          <Trigger Property="CanContentScroll" Value="False">
            <Setter TargetName="PART_ScrollContentPresenter" Property="CanContentScroll" Value="False"/>
          </Trigger>
          <MultiTrigger>
            <MultiTrigger.Conditions>
              <Condition Property="ComputedHorizontalScrollBarVisibility" Value="Visible"/>
              <Condition Property="ComputedVerticalScrollBarVisibility" Value="Visible"/>
            </MultiTrigger.Conditions>
            <Setter TargetName="PART_Corner" Property="Visibility" Value="Visible"/>
          </MultiTrigger>
        </ControlTemplate.Triggers>
      </ControlTemplate>
      <DataTemplate x:Key="CompactTemplate">
        <Border Style="{DynamicResource CED.Circuit.CompactContainer}"
                MaxWidth="{Binding item_max_width}"
                Padding="4,3,4,3"
                HorizontalAlignment="Stretch"
                ClipToBounds="True">
          <Grid ClipToBounds="True">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <CheckBox Grid.Column="0"
                      IsChecked="{Binding is_checked, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Click="item_checkbox_clicked"
                      Margin="0,0,3,0"/>

            <Grid Grid.Column="1" VerticalAlignment="Center">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Style="{DynamicResource CED.Badge.Base}"
                        Background="{Binding type_tag_bg}"
                        BorderBrush="{Binding type_tag_fg}"
                        Width="28"
                        Padding="1,0"
                        Margin="0,0,3,0"
                        Visibility="{Binding type_tag_visibility}">
                  <TextBlock Text="{Binding type_tag_text_compact}" Foreground="{Binding type_tag_fg}" Style="{DynamicResource CED.Badge.Text}" HorizontalAlignment="Center" TextAlignment="Center"/>
                </Border>
                <TextBlock Text="{Binding panel}" FontWeight="Bold"/>
                <TextBlock Text="/ "/>
                <TextBlock Text="{Binding circuit_number}" FontWeight="Bold"/>
              </StackPanel>
              <TextBlock Grid.Column="1"
                         Margin="4,0,0,0"
                         VerticalAlignment="Center"
                         Text="{Binding load_name_display}"
                         Visibility="{Binding load_name_visibility}"
                         ToolTip="{Binding load_name}"
                         TextTrimming="CharacterEllipsis"/>
            </Grid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="2,0,0,0">
              <TextBlock Text="{Binding rating_poles}" Width="76" TextAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
              <Border Style="{DynamicResource CED.Badge.Info}" Width="18" Margin="4,0,0,0" Visibility="{Binding neutral_badge_visibility}">
                <TextBlock Text="N" Style="{DynamicResource CED.Badge.Text.Info}" HorizontalAlignment="Center" TextAlignment="Center"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Warning}" Width="20" Margin="4,0,0,0" Visibility="{Binding ig_badge_visibility}">
                <TextBlock Text="IG" Style="{DynamicResource CED.Badge.Text.Warning}" HorizontalAlignment="Center" TextAlignment="Center"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Alert}" Width="16" Padding="2,0" Margin="4,0,0,0" Visibility="{Binding override_badge_visibility}" ToolTip="User override">
                <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.OverrideIcon}"/>
              </Border>
              <Border Style="{DynamicResource CED.Badge.Alert}"
                      Width="16"
                      Padding="2,0"
                      Margin="4,0,0,0"
                      BorderBrush="{DynamicResource CED.Brush.AccentRed}"
                      Visibility="{Binding sync_lock_badge_visibility}"
                      ToolTip="{Binding sync_lock_tooltip}">
                <ContentPresenter ContentTemplate="{DynamicResource CED.Template.Badge.SyncBlockedIcon}"/>
              </Border>
            </StackPanel>

            <Button Grid.Column="3"
                    Style="{DynamicResource CED.Circuit.AlertButtonInteractive}"
                    Background="{Binding alert_bg}"
                    BorderBrush="{Binding alert_border}"
                    Margin="4,0,0,0"
                    Visibility="{Binding alert_visibility}"
                    ToolTip="{Binding alert_summary}"
                    Click="alert_tag_clicked"
                    MouseEnter="alert_button_mouse_enter"
                    MouseLeave="alert_button_mouse_leave">
              <TextBlock Text="!" FontWeight="Bold" Foreground="{Binding alert_text_color}"/>
            </Button>
          </Grid>
        </Border>
      </DataTemplate>

